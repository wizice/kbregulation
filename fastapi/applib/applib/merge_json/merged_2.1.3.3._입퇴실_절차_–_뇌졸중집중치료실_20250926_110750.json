    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "뇌혈관 조영술 CP(Critical Pathway) 환자",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "뇌혈관 조영술 CP(Critical Pathway): 스텐트 삽입 후 1년이 경과한 환자를 대상으로 추적 확인하기 위해 시행하며 검사 후 악화되거나 새롭게 발생한 신경학적 증상이 없는 경우 익일 퇴원한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "입실 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "입실 기준에 따라 주치의(담당교수)가 환자의 입실을 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "의료진은 입실 시 환자 및 보호자에게 입실 필요성을 설명하고 동의를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "입실 시점의 환자 상태를 평가하고 입실 기준에 부합하는지를 의무기록에 기록한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "퇴실 기준: 퇴실하는 환자는 급성기를 지나 환자의 신경학적 증세가 안정화된 경우 주치의 (담당교수)의 결정에 의해 이루어지며 그 기준은 아래와 같다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "발병 후 7일 이내의 급성기 뇌졸중 환자 또는 재관류치료를 받은 환자: 24시간 이상 NIHSS(National Institutes of Health Stroke Scale) 점수의 악화가 없는 상태에서 초기 뇌경색 평가가 종료된 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "뇌경색이 진행하는 환자: 48시간 이상 NIHSS(National Institutes of Health Stroke Scale) 점수의 악화가 없는 경우",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "반복되는 일과성 허혈 발작 환자: 24시간 이상 발작이 없는 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "뇌헤르니아증이 진행하는 환자: 뇌헤르니아증의 위험성이 사라졌거나 고삼투성 제재를 최고용량에서 최소한 2단계 이상 감량할 수 있는 경우",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "중재적 치료 또는 뇌혈관 조영술 CP (Critical Pathway) 환자: 검사나 시술 후 악화되거나 새롭게 발생한 신경학적 증상 없이 12시간이 경과한 경우",
      "번호": "5)",
