    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "세균 증식 예방 및 음식과 식품의 안전한 제공을 통한 수인성 및 식품매개감염병 발생 위험의 감소를 위해 식재료, 조리기구 및 장비, 조리장 환경, 직원의 개인위생을 관리하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "식재료 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "식재료 선정 및 검수",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "식재료는 위생상태가 확보된 공급업체로부터 공급받는다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "육안으로 이물질 유무, 선도, 포장상태를 확인하고 용기가 훼손된 식품은 오염 가능성이 있으므로 납품받지 않는다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "식재료는 검수 시마다 품질검사를 실시하고, 수량, 규격, 품질, 위생상태, 유통기한 등을 검수일지에 기록한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "식재료 보관",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "식재료는 보관 장소별(실온, 냉장, 냉동 등), 종류별(어패류, 육류, 채소류), 조리상태(조리 전 식품, 조리 후 식품)에 따라 분리 보관한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "모든 식재료는 외부포장(박스)을 제거한 후 청결한 포장 및 용기에 밀봉상태로 유통기한이 보이도록 보관한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "보관된 식재료는 선입 선출의 원칙을 기본으로 불출한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "보관장소는 정기적으로 청소 및 소독을 실시한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "보관고 온도는 냉동고: -18℃ 이하, 냉장고: 5℃ 이하로 유지하고, 보관 창고는 28℃ 이하, 습도 70% 이하로 유지한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "식재료는 매일 필요량만 구입하여 사용한다(냉동 식재료 및 통조림, 곡류 예외).",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "경장영양액은 제조사 설명서에 근거하여 보관하고, 조제하며, 개봉한 제품은 폐기한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "조리기구 및 장비 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "식기 및 조리기구 관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "식재료 종류별 조리기구 분리 사용: 도마와 칼은 채소류, 생선류, 육류, 과일류, 조리된 음식별로 색을 구분하여 사용하여 2차 오염을 방지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "도마와 칼은 사용 후 약제소독 및 세척하여 건조시켜, 전용 소독고에 보관한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "행주와 장갑은 용도별로 구분하여 사용하며, 행주는 사용 후 깨끗이 삶아 건조시켜 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "조리용 소도구는 사용 후, 매회 세제를 이용하여 세척 건조 후 사용한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "작업대는 사용 후 매회 약제소독 및 세제를 이용하여 세척한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "스팀솥, 가스그릴, 가스레인지, 오븐은 사용 후 매회 세척하여 오물이 부착되지 않도록 한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "식기 위생",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "환자 식기는 사용 후 자동식기세척기를 이용하여 세척한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "식기세척기 전용 세제와 린스를 사용하며 세척 단계별 적절한 물온도를 유지한다(헹굼온도는 82℃이상 유지).",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "수저는 세척한 후 열탕 소독하여 건조시킨다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "식기 소독",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "식기소독은 제1급 법정감염병 중 페스트, 디프테리아, 제2급 법정감염병 중 콜레라, 장티푸스, 파라티푸스, 세균성이질, 장출혈성대장균, A형간염, 성홍열, 수막구균성수막염인 경우 적용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "식기소독을 진행하는 시기는 격리 진행기간 동안이다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "식기소독 상 처리방법은 다음과 같다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 5,
      "내용": "식기소독상은 쟁반의 색깔로 구분하여 식사를 제공한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 5,
      "내용": "퇴식상 수거 시 배식원은 일회용 장갑을 끼고 비닐봉투에 식기 소독상을 넣는다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 5,
      "내용": "수거된 식기는 별도의 지정된 식기소독구역에서 잔식을 턴 후 약제소독을 시행한다[차아염소산나트륨(락스) 200ppm 염소계 소독제 20분 침적].",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 5,
      "내용": "소독 후 식기세척기로 세척한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 5,
      "내용": "음식물 잔식은 의료폐기물 전용용기에 넣어 폐기한다.",
      "번호": "⑤",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "배식차 관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "배식차의 온도는 보온 60℃ 이상, 보냉 10℃ 이하를 유지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "배식차 및 퇴식차는 사용 후 매회 행주로 닦은 후 알코올계 소독액을 분무하여 자연건조시키고, 주 1회 중성세제를 이용하여 청소한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 4,
      "내용": "매일 적정온도 유지여부, 작동상태 등을 점검하며, 연 1회 온도검교정을 실시한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 3,
      "내용": "식기세척기 관리",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "1일 3회 식기세척기의 세척 및 행굼 온도를 기록한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 4,
      "내용": "세척 작업 후 중성세제로 세척기 외부를 깨끗이 닦는다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 4,
      "내용": "세척기 거름망의 음식물찌꺼기를 제거하고 세척한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 4,
      "내용": "물분사가 용이하도록 월 2회 노즐을 청소한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "매일 적정온도 유지, 작동 상태 등을 점검한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "연 1회 전문업체를 통해 헹굼온도 유지를 확인하고, 잔류세제 여부 등을 점검한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "냉장고, 냉동고 관리",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 4,
      "내용": "냉장고는 5℃ 이하, 냉동고는 -18℃ 이하를 유지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 4,
      "내용": "염소소독액(200ppm)으로 매일 청소하며, 주 1회 선반의 내용물을 옮긴 후 세제를 이용하여 세척하고 염소소독액으로 소독한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "조리장 환경 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "구역 구분",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 4,
      "내용": "오염(일반)구역: 검수구역, 전처리구역, 식기세척구역",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "위생(청결)구역: 조리구역, 상차림구역",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 4,
      "내용": "조리장 바닥은 건조 상태를 유지한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 3,
      "내용": "청소",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 4,
      "내용": "조리장은 매일 작업 후 청소하고, 바닥은 항상 청결한 상태로 유지되도록 관리하며, 주 1회 강력 세척제를 이용하여 세척한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 4,
      "내용": "천장은 먼지가 쌓여 있거나 응결수가 떨어지지 않도록 수시로 점검하고 보수하며, 연 1회 외부업체에 의뢰하여 세척한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 4,
      "내용": "조리장 전역은 배수 및 환기가 잘 되도록 매일 점검하고 트렌치는 매일 뚜껑을 열고 세척한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 3,
      "내용": "음식물쓰레기 관리",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 4,
      "내용": "남은 음식을 처리하는 곳은 식기세척 장소에 위치하며, 식품의 조리생산 및 보관 장소와 분리하여 놓는다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 4,
      "내용": "음식물쓰레기 수거통은 내수성 재질의 전용 용기를 사용하며, 매회 세척하고 1일 1회 소독하여 해충, 바퀴벌레, 쥐 등이 접근할 수 없도록 관리를 철저히 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 66,
      "레벨": 4,
      "내용": "물기를 제거한 음식물 쓰레기는 음식물처리기기를 사용하거나 계약된 업체를 통해 외부로 반출한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 67,
      "레벨": 4,
      "내용": "발생한 음식물 쓰레기는 당일 처리한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 68,
      "레벨": 3,
      "내용": "구충, 구서 관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 69,
      "레벨": 4,
      "내용": "쥐, 파리, 바퀴벌레 등은 식중독이나 경구 감염병 발생의 원인이 된다. 해충이 서식하지 않도록 음식물 찌꺼기나 남은 음식, 수분 등을 남겨 놓지 않도록 청결을 유지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 70,
      "레벨": 4,
      "내용": "구충구서 작업은 월 2회 전문회사에 의뢰하여 작업종료 후 실시한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 71,
      "레벨": 3,
      "내용": "조리장의 실내온도는 28℃, 습도 70% 이하를 유지한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 72,
      "레벨": 2,
      "내용": "직원 개인위생 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 73,
      "레벨": 3,
      "내용": "조리 시에는 청결한 위생복, 위생모, 위생화를 착용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 74,
      "레벨": 3,
      "내용": "손은 전용 세면대에서 물과 비누를 사용하여 철저히 씻는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 75,
      "레벨": 4,
      "내용": "조리장에서 근무 시작 전·후",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 76,
      "레벨": 4,
      "내용": "화장실 출입 후",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 77,
      "레벨": 4,
      "내용": "세척 안 된 식재료 및 오물 취급 후",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 78,
      "레벨": 4,
      "내용": "기구나 설비사용 전·후",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 79,
      "레벨": 4,
      "내용": "신체부위를 만진 후(머리, 코, 감염부위 등)",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 80,
      "레벨": 4,
      "내용": "다른 종류의 식재료 취급 및 조리 전",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 81,
      "레벨": 3,
      "내용": "손톱은 짧게 자르고 반지 및 매니큐어는 금한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 82,
      "레벨": 3,
      "내용": "유증상 직원의 관리: 건강에 이상이 있을 때는 조장이나 관리자에게 보고하여 적절한 조치를 받고 다음의 경우 치유 전까지 급식관련 업무에 근무를 제한한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 83,
      "레벨": 4,
      "내용": "식품위생법 시행규칙 제 50조(영업에 종사하지 못하는 질병의 종류)에 명시된 질병에 이환된 경우",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 84,
      "레벨": 5,
      "내용": "감염병의 예방 및 관리에 관한 법률에 의한 제2급 법정감염병 중 콜레라, 장티푸스, 파라티푸스, 세균성이질, 장출혈성대장균감염증, A형간염, 결핵(비전염성 결핵인 경우 제외)",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 85,
      "레벨": 5,
      "내용": "피부병 또는 그 밖의 화농성 질환",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 86,
      "레벨": 4,
      "내용": "열이 나거나 설사, 구토 등의 증세 및 피부에 배농병소가 있는 경우",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 87,
      "레벨": 4,
      "내용": "특히, 급성 설사의 증세가 있는 경우 직장 도말(rectal swab) 또는 대변 검체로 배양검사를 실시하여 감염성 병원체를 확인한다. 전염력이 있는 위장관감염이 확인되면 감염력이 완전히 소실되었음을 확인할 때까지 근무를 제한한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 88,
      "레벨": 3,
      "내용": "급식 종사자는 월 1회 위생교육을 받는다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 89,
      "레벨": 3,
      "내용": "급식 종사자는 연 1회 정기 건강검진을 받아야 한다. 정기 건강진단 항목은 장티푸스, 파라티푸스, 폐결핵이다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 90,
      "레벨": 2,
      "내용": "환자 급식시설은 식품위생 관련 법규 및 식품위해요소 중점관리기준(Hazard Analysis Critical Control Point, HACCP)에 근거하여 관리한다.",
      "번호": "5.",
      "관련이미지": []
    },
