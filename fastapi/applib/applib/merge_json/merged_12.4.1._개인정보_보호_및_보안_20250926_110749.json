    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "[부록3. 정보자산관리 지침] 제5조 및 제7조에 따라 자산을 식별, 분류하여 중요성을 평가하고 자산 반출입을 관리한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 2,
      "내용": "물리적 보안",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "주요 인프라 시설 구역, 서버실, 통신실, DR센터 등을 제한구역 및 통제구역으로 지정하여 인가자에 한해 출입을 허용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "제한구역은 출입허용 여부를 식별하기 위하여 정맥인식기, 디지털 도어록, 출입증(출입카드) 등을 사용할 수 있다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "통제구역은 출입허용 여부를 식별하기 위하여 정맥인식기, 디지털 도어록, 출입증(출입카드) 등을 사용하며, 필요 시 CCTV 시스템을 통한 모니터링 및 출입기록 관리를 시행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 2,
      "내용": "시스템 개발 시 보안관리",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "시스템 개발 및 테스트 시스템은 운영시스템과 분리하는 것을 원칙으로 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "[부록4. 개발 및 응용시스템 보안 지침]에 따라 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 2,
      "내용": "접근통제관리",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "정보시스템 접근통제",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "방화벽, 웹방화벽, 침입방지 시스템(IPS, Intrusion Prevention System), 시스템 접근제어 통제시스템 등을 설치하여 운영한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "백신 및 매체제어 등의 보안프로그램을 설치하여 운영한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "정보시스템 접근권한",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "전자 의무기록, 영상 의무기록과 전자화 된 환자 정보(처방전달시스템(OCS, Order Communication System), 의료영상저장전송시스템(PACS, Picture Archiving and Communication System), 검사결과지 등)의 접근 범위 및 권한은 직종별, 목적별, 부서별, 업무별, 서식별 등으로 분류하여 조회(열람), 입력(수정 포함), 출력, 삭제로 차등 부여한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "의료정보시스템 사용자는 개인별 ID 와 비밀번호를 부여하며, 신원확인을 위한 공인인증서 등의 인증시스템을 추가 적용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 4,
      "내용": "전보, 휴직, 퇴직 등 인사변동 발생 시 자동 접근통제 되며, 재할당 또는 유효일자 조정을 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 4,
      "내용": "세부사항은 [12.1.3. 의무기록/의료정보 접근 권한]을 따른다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "의료행위와 관련된 정보시스템 접속기록의 보관 및 위변조 방지를 위한 방안",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "OCS/EMR(Electronic Medical Record) 접속이력을 관리하며, 기록된 접속이력 정보는 변경할 수 없다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "접속이력 기록은 사용자의 계정, IP(Internet Protocol) 주소, 접속시간/로그아웃 시간을 남겨야 하며, 쓰기, 수정, 삭제, 출력에 대한 접근기록을 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 4,
      "내용": "비정상적인 접속기록(허용된 권한 외의 접속, 비정상적으로 많은 데이터 다운로드 등)에 대해서 관리한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 4,
      "내용": "접속이력은 최소 2년 이상 보관한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 3,
      "내용": "규정 위반 사례 관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 4,
      "내용": "정보시스템 접근 권한을 정기적으로 재검토하며 필요시 조치를 취한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 4,
      "내용": "접속현황에 대해 정기적으로 모니터링하여 비인가자에 의한 정보시스템 접속을 방지한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 4,
      "내용": "규정 위반 사례 발생 시 관련 절차에 따라 위원회를 개최하여 사례 분석 및 개선활동을 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 2,
      "내용": "PC 및 개인용 휴대 단말기 관리",
      "번호": "9.",
      "관련이미지": []
    },
    {
