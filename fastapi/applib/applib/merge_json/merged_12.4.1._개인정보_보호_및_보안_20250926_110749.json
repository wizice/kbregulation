    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "개인정보 외부위탁관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "개인정보를 취급하는 외주용역업체 직원의 경우 정보 보호 서약서를 제출한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "[부록2. 외주용역 보안관리 지침]에 따라 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "정보자산관리",
