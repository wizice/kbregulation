      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "의약품 회수 절차",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "식품의약품안전처, 정부부처(관할 보건소 등), 제조업체, 공급업체에서 발표 또는 송부한 의약품 회수 공문을 접수한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "약무국은 ‘회수 의약품 안내 및 회수’ 공문을 작성하여 원내에 공지하고, 식품의약품안전처의 지침에 따라 환자에게 회수에 협조하도록 안내한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "약무국은 원내 보유 중인 회수 의약품 재고를 파악하고, 회수한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "약무국에서는 처방 현황과 대체 가능 의약품을 파악하여 병원장에게 보고한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "필요 시 해당 회수 의약품 코드를 삭제하여 회수 시행일로부터 처방을 금지하도록 한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "약사위원장은 회수 사안에 따라 약무국 또는 관련 임상과와 협의를 거쳐 의약품의 회수 범위, 방법 등 처리 절차를 결정하여 진행할 수 있으며, 필요 시 대체 의약품 선정 및 구매를 진행한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "약사위원장은 필요 시 약물관리위원회를 긴급 소집하여 의약품의 회수 건에 대해 논의할 수 있다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "회수한 의약품을 도매상에 반품하거나 통보된 처리절차에 따라 처리하며, 회수 의약품 관리 기록부를 작성한다",
      "번호": "8)",
      "관련이미지": []
    },
