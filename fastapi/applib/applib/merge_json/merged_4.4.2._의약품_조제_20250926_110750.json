{
  "문서정보": {
    "규정명": "4.4.2. 의약품 조제",
    "내규종류": "규정",
    "규정표기명": "4.4.2. 의약품 조제",
    "제정일": "2006.05.",
    "최종개정일": "2025.03.25.",
    "최종검토일": "2025.03.25.",
    "담당부서": "약물관리위원회, 약무국",
    "관련기준": [
      "4주기 의료기관인증기준: 4.4 처방 및 조제",
      "JCI Standard 7th Edition: MMU.5, 5.1, 5.2"
    ],
    "조문갯수": 79,
    "이미지개수": 1
  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "4.4.2. 의약품 조제",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "의약품 처방의 적절성 검토(감사) 절차를 수립하여 안전하고 정확한 조제를 수행하고, 청결한 조제환경 관리를 수행하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "의약품의 조제는 관련 법과 규정, 전문적 실무 규정을 준수하며 조제 전 감사(처방의 적절성 검토), 조제, 조제 후 감사의 단계로 진행한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "조제 전 처방 감사(처방의 적절성 검토)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "감사 수행자: 일정기간 조제 실무를 수행하고 관련 교육을 이수한 약사",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "감사 시점: 조제 전",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "감사 내용",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "약품명, 용량, 용법(빈도), 투여경로의 적절성, 중복처방, 알레르기 유무, 의약품 간 또는 의약품과 음식 간 상호작용, 환자의 체중 및 생리학적 정보, 잠재적 장기 독성, 식품의약품안전처 허가사항, 기타 금기사항 등",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "약사는 처방 감사 시 의약품안전사용서비스(DUR, Drug Utilization Review)를 활용하여 투여 중인 의약품과 병용/연령/임부금기, 동일성분/동일효능군 중복약품이 있는지 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "약사는 처방 감사 시 적절하지 않거나 처방 내용에 대해 확인이 필요한 경우 반드시 처방 의사를 통해 처방 내용 및 근거를 확인하며 그 내용을 기록한다. 위험한 결과가 예상되는 처방의 중재가 되지 않는 경우 처방 의사에게 사유 및 근거를 요청하고, 필요시 주치의(담당교수)에게 재확인한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "병동이나 임상구역에서 응급 상황 시 비품약이 투여되는 경우에는 처방 적절성 검토를 수행하며, 세브란스병원 내규 [4.3.3. 비품약 관리]에 따른다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "조제",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "조제자격: 면허를 갖추고 관련 교육을 이수한 약사",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "조제시간: 약무국에서는 토, 일, 공휴일 및 야간을 포함하여 상시적으로 조제업무를 수행한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "조제원칙",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "조제는 [부록1. 조제지침]에 따라 안전하고 청결하며, 일관성 있고 정확하게 수행하며, 병원 전체적으로 일관된 조제 및 공급 시스템을 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "약사는 조제의 각 단계 수행 시 확인 서명을 하고, 기록할 사항이 있는 경우 처방전에 기록한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "약무국은 조제 전 처방 감사, 조제, 조제 후 감사를 수행하는 약사에 대해 처방 감사 및 조제 관련 교육을 실시한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "조제과정에서 발생하는 조제근접오류는 [부록2. 약물사용 오류 예방 및 처리지침]에 따른다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "주사용 의약품 취급 시 [감염관리지침] ‘안전주사실무’의 감염 및 안전관리를 준수한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "직원 위생관리: 조제 전 손위생을 시행하고, 필요 시 장갑을 착용한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "직원 안전관리: 필요 시 개인보호구를 착용(구비)하고 관리한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "조제 시 주의를 요하는 의약품 관리",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "완전비경구영양제(TPN, Total Parenteral Nutrition)는 [부록1-8. TPN 조제지침]에 따라 조제한다",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "항암제는 [부록1-6. 항암제 조제지침]에 따라 조제한다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "조제 후 감사",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "감사 수행자: 관련 교육을 이수하고, 일정기간 조제 업무를 수행한 약사",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "감사 요소: 처방의 적절성, 조제의 정확성, 라벨링 등 최종 조제내용",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 2,
      "내용": "의약품 조제 환경 관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "조제구역은 보안 등 안전을 유지하기 위하여 외부인의 출입을 제한한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "조제공간은 구획하여 청결하고 안전하게 관리되어야 하며, 조제도구(조제대 및 조제기기)는 청결하게 관리한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "가루약 조제구역, 무균조제구역 등에 환기시설을 설치하고 유지 및 관리한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "안전하고 청결한 조제를 위해 직원위생, 직원안전, 환경안전, 조제도구 관리를 수행하며, 이는 [부록3. 조제안전관리지침]을 따른다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "주사용 의약품 취급의 감염 및 안전관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "주사용 의약품 사용법 및 취급 시 주의사항",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "의약품의 보관과 사용은 제조사의 지침에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "의약품을 사용하기 전 제조사의 약품 정보(약품명, 용량, 유효기간, 투여경로 등)를 확인한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "주사용 의약품을 육안으로 확인하여 손상되었거나 성상의 변화(변색, 혼탁 등)가 보이면 사용하지 말고 즉시 폐기한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "일회용 의약품을 분할하여 사용하지 않는다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 4,
      "내용": "수액백/수액병과 수액주입세트는 한 환자에게만 사용한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "수액백/수액병에서 수액을 뽑아 여러 환자에게 관류(flush)용으로 사용하지 않는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 3,
      "내용": "주사기와 주사바늘 관리",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 4,
      "내용": "주사기와 주사바늘은 멸균된 일회용 제품을 사용하며 재사용하지 않는다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 4,
      "내용": "주사기와 주사바늘은 포장된 상태로 보관한다. 멸균주사제품들이 오염되지 않도록 사용직전에 포장을 제거하고 포장이 개봉되어 있거나 손상된 경우에는 오염된 것으로 간주하고 폐기한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 4,
      "내용": "주사바늘은 세브란스병원 내규 [11.3.2. 의료폐기물 관리]에 따라 전용 용기에 폐기한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "카테터, 수액세트 교체",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "카테터 및 수액세트 교체와 관련된 사항은 [감염관리지침 Ⅵ. 부위별감염관리 - 1. 혈관내 카테터 관련 감염증]을 따른다.",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 2,
      "내용": "조제된 의약품의 라벨링",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "조제된 의약품은 안전하고 정확한 투여를 위해 적절한 방법으로 환자이름, 등록번호, 의약품명, 1회 투여용량, 투여경로, 투여시간/횟수, 보관방법(냉장, 차광), 유효기간을 표기한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 3,
      "내용": "투여 전까지 냉장보관이 필요한 경우 별도 보관 방법을 명기한다.",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "운반",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "조제된 의약품은 파손 및 분실 예방을 위한 운반용기를 사용하며, 보관조건(냉장, 차광 등)을 준수하여 안전하게 운반한다.",
      "번호": "9.",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 2,
      "내용": "원외처방전에 대한 관리는 [부록4. 원외처방전 관리지침]을 따른다.",
      "번호": "10.",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 2,
      "내용": "교육",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 3,
