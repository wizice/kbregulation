    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "우선순위를 고려하여 의료의 질과 환자안전 향상을 위한 주요 영역을 선정한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "주요 영역의 핵심 질지표를 선정한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "질지표의 과학적 근거 혹은 벤치마킹 자료를 검토한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "선정된 질지표는 의료질향상 및 환자안전위원회의 심의과정을 통해 확정한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "필요 시 질지표는 변경 가능하며, 변경 시에는 의료질향상 및 환자안전위원회의 심의를 받는다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "질지표 관리방법",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "질지표 관리계획서(Measure Profile)를 작성한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
