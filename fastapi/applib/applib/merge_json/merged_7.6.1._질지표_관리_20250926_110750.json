    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "목표수준 수립과 선정근거",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "자료수집방법(조사 대상, 방법 및 빈도 등)",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "자료출처 및 분석방법",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 4,
      "내용": "담당부서 및 보고받는 위원회, 보고 주기 등",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "자료수집계획에 따라 모니터링을 실시한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "자료를 분석한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "결과가 목표수준 이하인 경우 근본 원인을 분석하고 개선활동 계획을 세운다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 3,
      "내용": "개선활동 성과를 지속적으로 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 3,
      "내용": "위의 일련의 활동을 PDCA(Plan-Do-Check-Act) 방법 등을 적용하여 진행한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 2,
      "내용": "질지표 담당 직원에게 매년 질지표 관리방법에 대해 교육을 실시한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 2,
      "내용": "질지표 모니터링 결과 보고 및 공유",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 3,
      "내용": "질지표 모니터링 및 개선활동 결과와 관련하여 부서장(위원회), 의료질향상 및 환자안전위원회에서 검토한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 3,
      "내용": "병원운영위원회에 질지표 관련 결과를 보고한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 3,
      "내용": "세브란스병원장과 병원 거버넌스 위원회에 질지표 관련 결과를 최종 보고한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "질지표 모니터링 및 개선활동 결과를 병원차원의 질향상 및 환자안전 활동에 통합하여 관리하고 질지표 모니터링 결과 및 개선활동 성과 등을 관련 직원과 공유한다.",
