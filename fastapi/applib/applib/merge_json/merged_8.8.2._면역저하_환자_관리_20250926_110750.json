      "내용": "8.8.2. 면역저하 환자 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "면역저하 환자의 감염발생 위험을 최소화하기 위해 감염성질환의 유입을 차단하고 면역저하 환자를 보호하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "면역저하 환자: 선천적 혹은 후천적, 일시적 혹은 지속적으로 숙주의 반응에 장애가 생겨 감염위험도가 높은 환자(암 또는 AIDS, 이식 환자 등)",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "감염위험성에 따른 보호격리 대상",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "조혈모세포 이식환자로서 감염위험이 있는 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "ANC(Absolute Neutrophil Count) 수치가 500/μl이하인 경우로서 감염의 위험이 있다고 판단하는 경우",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "조혈모세포이식 등 이식환자에서 Grade II 이상의 급성 이식편대 숙주질환(GVHD)이 발생한 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "후천성면역결핍증(AIDS, Acquired Immune Deficiency Syndrome) 환자 등",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "격리기간: 보험인정기준에 준한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "ANC가 3일간 계속하여 500/μl이상 또는 감염의 위험이 소실될 때까지",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "Grade II 이상의 급성 GVHD가 Grade I으로 호전될 때",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "면역기능이 현저히 회복될 때까지",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "보호격리실",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "배치",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "조혈모세포이식환자를 위해 보호격리 시설을 운영한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "조혈모세포이식환자는 HEPA Filter를 통해 공기가 공급되는 무균병실을 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "면역저하환자는 HEPA Filter가 설치된 병실이나 1인실을 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "보호격리실 제공이 불가능하거나 기타 필요한 경우 이동식 HEPA Filter를 설치할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "시설 설치 기준 및 관리",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "설치 기준",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 5,
      "내용": "지름 0.3㎛이상의 먼지를 99.97% 제거하는 HEPA Filter를 통해 공기를 공급한다",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 5,
      "내용": "시간당 12회이상 공기를 통풍시키는 환기장치를 사용하고, 필요 시 비상환기 장치를 준비해 둔다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 5,
      "내용": "외부의 공기가 유입되지 않도록 창문이나 문틈이 잘 봉합되어 있어야 하며, 출입문은 저절로 닫히도록 한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "양압유지를 위한 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 5,
      "내용": "보호격리실은 양압(복도 등 외부에 비해 2.5㎩ 이상 높은 기압)을 유지한다. (차압계 및 Relief damper로 양압 유지 여부를 확인한다.)",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 5,
      "내용": "양압시설이 있는 부서는 다음과 같이 점검을 시행한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 5,
      "내용": "보호격리실 사용을 시작할 때 점검한다.",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 5,
      "내용": "보호격리실을 사용하고 있는 경우 매일 점검한다.",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 5,
      "내용": "보호격리실을 사용하지 않는 경우에는 최소 1회/월 점검한다.",
      "번호": "c.",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 5,
      "내용": "양압시설 문제 발생 시 시설관리팀 등 관련부서에 연락하여 해결한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 5,
      "내용": "무균병동의 공조시설 유지보수는 별도의 관리지침을 따른다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "준비물품",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 5,
      "내용": "환자에게 사용할 의료기기 또는 물품은 필요시 환자 별도로 소독된 장비(BP기계 등)를 사용한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 5,
      "내용": "보호격리실 출입 시 필요한 물품(마스크, 멸균가운, 멸균장갑, 모자 등)을 병실 밖에 준비해 놓는다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 4,
      "내용": "환경 관리",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 5,
      "내용": "격리 진행 전 환경소독제를 이용하여 병실 내 집기를 포함한 모든 표면을 닦는다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 5,
      "내용": "주 2회 환경소독제를 이용하여 집기, 비품을 청소하고, 직물류를 교체한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 5,
      "내용": "병실과 복도에 카페트를 사용하지 않는다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 5,
      "내용": "장난감은 세척과 소독이 가능한 재질로 소독하여 개별로 사용하고 다른 환자와 공유하지 않는다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 5,
      "내용": "꽃이나 화분은 허용하지 않는다.",
      "번호": "⑤",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 2,
      "내용": "환자관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 3,
      "내용": "보호격리가 결정되면 격리실 사용 신청을 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 3,
      "내용": "감염관리지침에 따른 손위생을 준수한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 3,
      "내용": "처방에 따라 피부, 구강 및 회음부 관리를 시행한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "환자와의 신체적 접촉을 최소화하고 부득이하게 접촉해야 하는 경우 손위생을 시행한 후 접촉한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "침습과정은 최소화하며, 침습 기구(예: 카테터, 튜브)는 의학적 상태가 회복되는 즉시 제거한다. 편의를 위해 침습 기구를 사용하지는 않는다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 3,
      "내용": "환자 간호 및 면회 시 감염증상(발열, 호흡기 증상 등)이 없어야 하며, 손위생 등의 무균법과 위생을 철저히 준수하여야 한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "감염증상(발열, 호흡기 증상 등)이 있는 경우 해당 진료참여를 제한하고, 부득이하게 진료에 참여해야 하는 경우 마스크를 착용한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "발열 등 감염증상을 모니터링하며 필요 시 검사를 시행한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 3,
      "내용": "보호자는 1인까지만 상주할 수 있으며, 방문객의 출입을 제한한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "환자 및 보호자 대상으로 보호격리 관련 준수사항 교육",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "손위생 수행방법, 시기, 손소독제를 설명한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 3,
      "내용": "구강위생 관리방법(소독액, 가글, 칫솔관리 등)을 설명한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 3,
      "내용": "항문주위 피부간호, 청결유지 방법, 변비예방을 설명한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 3,
      "내용": "식사(음료, 간식 포함) 시 주의사항을 설명한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 3,
      "내용": "기타 면역저하환자 주의사항을 교육한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 2,
      "내용": "환자에게 사용한 의료기기 또는 물품 관리",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 3,
      "내용": "환자에게 사용한 장비, 기구 및 장치의 관리는 표준주의에 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 2,
      "내용": "직원 간 정보공유 방법",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 3,
      "내용": "보호격리를 적용하는 경우 병실 문앞에 ‘보호격리’, ‘조혈모세포이식’ 등의 표식을 부착한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 2,
      "내용": "환자 이송방법",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 3,
      "내용": "면역저하환자는 이동을 최소화하며, 검사실이나 외부이동 시에는 개인보호장구(모자, 마스크, 멸균가운 등)을 착용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 66,
