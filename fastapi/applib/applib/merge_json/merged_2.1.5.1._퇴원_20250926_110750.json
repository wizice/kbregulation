  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.1.5.1. 퇴원",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "진료의 연속성을 유지하기 위해 퇴원 결정과정에 환자가 참여하며, 퇴원계획 수립, 퇴원 설명, 퇴원 후 추후관리 정보제공, 필요시 가정간호 등을 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "퇴원계획",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "퇴원 계획 시 환자를 참여시킨다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "퇴원 계획은 입원 초기부터 수립되며, 환자의 상태가 변경되면 퇴원 계획을 재수립한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "퇴원 전 환자와 퇴원예정일, 퇴원 후 거주 장소, 퇴원 시 적합한 이송 수단을 확인한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "퇴원 후 환자에게 제공되어야 하는 의학적 사항과 환자의 요구 및 준비도를 파악하여 퇴원 시 이를 반영한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "환자의 상태에 따라 퇴원예정일, 예상 진료비 내역 등의 정보를 제공한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "퇴원요약 작성",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "작성 시기: 퇴원 전",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "의사용 퇴원요약의 작성 책임자는 주치의(담당교수) 또는 담당의사이다. 담당의사가 작성 시 주치의(담당교수)가 공동 서명한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "환자용 퇴원요약은 다음 내용을 포함한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "진단명 및 동반 질환",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "진단 및 치료를 위해 행한 수술/시술명, 처치명",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "입원사유, 경과요약",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "의미있는 약물 및 치료, 신체적 혹은 기타 발견사항",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "퇴원 시 환자상태",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "추후관리 계획",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "퇴원 약물, 집에서 복용할 모든 약물 목록",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "퇴원 시 정보제공",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "환자에게 환자용 퇴원요약을 제공하고 설명한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "퇴원요약에는 치료 및 효과, 투약, 주의사항, 의료기관에 문의를 요하는 증상 및 연락처, 추후관리 등이 포함된다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "가정간호가 필요한 경우 서비스를 연계하고 관련 정보를 제공한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "퇴원약 안내",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "의료진은 환자 또는 대리인에게 약품명, 투여목적 및 방법, 부작용, 보관방법 등을 설명하고 교육 내용을 기록한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "복약안내문과 환자용 퇴원요약지를 제공하여 퇴원약에 대해 설명하고 내용을 잘 이해했는지 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "퇴원처방",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "퇴원 승인은 의사의 퇴원 처방에 의해서 가능하다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "환자의 의학적 상태에 대한 주치의(담당교수) 소견에 따라 환자의 퇴원여부를 결정한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "퇴원약, 다음 외래진료예약, 다음 진료 시 필요한 검사 등을 포함하여 퇴원처방을 한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "퇴원일 0시 전에 전일 퇴원 처방을 권장한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "환자의 요청이 있을 경우 필요한 서류(입퇴원증명서, 진단서, 의무기록 사본 등)를 발부한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 2,
      "내용": "퇴원수속",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "환자의 요청이 있을 경우 필요한 서류(입퇴원증명서, 진료비상세내역서, 납입증명서 등)를 발부한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "퇴원 계산 준비가 완료되면, 환자에게 퇴원수속안내문을 교부하고 진료비를 수납하도록 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "각 병동에서는 퇴원수납영수증을 확인한 후 퇴원요약을 제공하고 설명한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 2,
      "내용": "환자가 의료진의 권고 없이 스스로 퇴원하는 경우, 세브란스병원 내규 [2.1.5.3. 진료·치료 거부 및 무단이탈 환자 관리]에 따른다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 1,
      "내용": "(참고)",
      "번호": "제5조",
      "관련이미지": []
    }
