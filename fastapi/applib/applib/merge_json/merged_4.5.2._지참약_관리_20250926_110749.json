    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "지참약 확인 절차",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "의사, 약사, 간호사는 입원 시점에 환자에 대해 지참약 반입 여부를 확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "의약품 식별",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "지참약은 처방전 또는 실물 약품으로 확인하며, 약품을 투약받은 장소 및 시기, 보관방법에 대해 확인한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "지참약 내역(약품명, 용량, 투여경로, 용법(투여횟수) 또는 투여시간)을 의무기록에 입력하고, 약품 식별이 필요한 경우 약무국으로 요청한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "입원 당일 지참약 식별이 불가능한 경우 건강보험심사평가원 ‘내가 먹는약! 한눈에’ 서비스를 이용할 수 있다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "지참약 정보공유",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "의무기록에 입력된 지참약의 세부내역(약품명, 용량, 투여경로, 용법(투여횟수) 또는 투여시각)을 통해 관련 의료진이 정보를 공유한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "지참약 처방",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "의사는 지참약 내역을 확인한 후 입원 기간 중 사용 여부를 결정하고, 지속적 사용이 필요하다고 판단된 경우에는 원내 보유약품으로 변경하여 처방한다. 단, 예외적으로 일부 지참약(희귀의약품, 고가약 등)은 의사처방 하에 지참약으로 입원 중에 투여할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "퇴원 시 의사는 지참약의 복용 지속 여부를 재확인하여 결정하고, 필요한 경우 처방한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "한약, 건강식품, 성분이 확인되지 않은 의약품, 보관상 변질되었거나 안전성이 확인되지 않은 지참약은 사용하지 않는다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "지참약 보관",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "입원 중 사용이 허용된 지참약은 간호사가 안전하게 보관하며, 의사 처방 하에 간호사가 투여한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "입원 중 사용이 허용되지 않은 지참약은 ‘입원 중 복용 금지’ 봉인 스티커를 부착하여 환자 또는 보호자에게 돌려주고 관리하며, 환자 임의로 복용하지 않도록 교육을 시행한다.",
      "번호": "2)",
