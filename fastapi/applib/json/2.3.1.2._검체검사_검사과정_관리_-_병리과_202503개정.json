    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "검사 처방",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "검사 처방 시 환자이름, 등록번호, 검사명, 채취방법, 검체종류, 채취부위, 채취일, 임상진단, 기타 임상정보가 포함된 병리검사 의뢰서를 작성하고 처방한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "검체 획득 절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "정확한 환자확인: (2) 적절한 검체 용기의 선택: 조직의 크기 및 특성에 따라 포르말린, 검체 비닐 전용봉투 등 전용용기를 사용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "검체 용기 라벨링: 검체 용기에 검체 바코드를 부착한다. 바코드의 환자이름, 등록번호, 검체종류, 검체채취일 등을 확인한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "검사실 전달까지의 관리사항",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 5,
      "내용": "모든 검체는 병리검체 전용용기를 사용하고 바코드가 부착되어 있어야 한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 5,
      "내용": "모든 조직·세포 검체는 감염의 가능성이 있는 것으로 간주하여 다룬다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 5,
      "내용": "검체가 발생되면 신속히 검사실로 접수한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 5,
      "내용": "검체 취급 전 장갑을 착용하고 취급 후 반드시 손을 씻는다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "접수할 때 조직과 의뢰서 기재 사항을 확인하고 병리번호를 부여한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "정확한 검체검사를 위한 확인 절차",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "조직 검사물은 검사의뢰서와 함께 접수되어야 하고 검사물과 의뢰서 내용이 일치하여야 한다. 상이한 점이 발견되면 그 내용을 의뢰처에 통보하고 의뢰서에 기재한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "필요시 검사요청일, 검사의뢰 목적 등을 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "[부록3. 병리과 업무규정]에 따라 검사 종류에 따른 검사를 수행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 5,
      "내용": "유전자검사는 유전자검사동의서, 연구 시 인체유래물 등의 기증동의서 제출이 필요하다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "검사결과를 확정하기 전 검체적합성 확인",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 5,
      "내용": "부적합 검체",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 6,
      "내용": "환자를 확인할 수 없는 검체 (검체 번호의 표기가 불명확한 경우)",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 34,
