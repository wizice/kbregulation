    },
    {
      "seq": 53,
      "레벨": 4,
      "내용": "재난 위험도 평가 결과에 따라 취약한 재난 유형에 대처하고자 재난 훈련 주제를 선정하고 재난 훈련을 연 1회 시행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "개선 활동 효과의 모니터링 및 평가",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "환자안전",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 4,
      "내용": "실패 유형 및 영향 분석(FMEA)의 경우 개선 활동 전후 효과 평가를 시행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "위해 사건에 대한 사안별 개선 활동 전후 효과 평가를 시행한다.",
