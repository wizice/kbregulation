    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "위탁서비스 범위와 성격",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "외주용역: 청소, 보안, 급식, 세탁, 주차, 환자운송 등 업무에 대해 계약서에 명기된 서비스 제공",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "입점업체: 음식점, 편의점 등 병원 내에 입주하여 제품을 판매하는 서비스 제공",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "독자적인 진료를 수행하는 전문의는 외주용역으로 수급하지 않는다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "위탁검사업체 관련 제반사항은 진단검사의학과], [2.3.1.2. 검체검사 검사과정 관리 – 병리과]에 따른다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "위탁서비스 운영 및 유지관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "위탁서비스 업체 선정은 [부록1. 구입 및 계약 사무규정]에 의거하여 실시하며, 위탁서비스에 대한 선정 및 총괄 관리는 병원운영위원회의 책임하에 수행된다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "위탁서비스 업체는 서비스 특성에 따라 계약서에 명기된 범위내에서 업무를 수행하며, 각 관리부서는 위탁서비스 업체가 계약된 범위 내에서 효율적이고 안정적인 서비스를 제공하도록 관리할 책임이 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "위탁서비스 업체의 계약 연장 및 계약 종료 시기는 환자 서비스에 영향을 미치지 않도록 연속성을 고려하여 실시한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "위탁서비스 업체 직원 선정은 업체 자체 기준에 따른다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "위탁서비스 모니터링 및 사후 조치",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "위탁서비스 업체의 성과를 모니터링하며, 관리부서는 주기적으로 의료질향상 및 환자안전 위원회에 보고하고 필요 시 적절한 조치를 취한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "위탁서비스 직원의 교육 관리 9.1.3. 위탁서비스 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "위탁서비스 업체는 세브란스병원에 상주하는 소속 직원에게 다음과 같이 필수 교육을 제공한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "오리엔테이션: 병원소개, 질향상과 환자안전, 소방안전, 감염관리, 환자의 권리와 책임(서비스 마인드), 개인정보보호, 배정된 업무 교육 실시",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "정기 교육: 1년 이상 근무한 직원에 대해 매년 질향상과 환자안전, 소방안전, 감염관리, 환자의 권리와 책임(서비스 마인드), 개인정보보호 교육 실시",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "기본심폐소생술 교육: 위탁서비스 업체 직원에 대해 최소 2년마다 기본심폐소생술 교육 실시",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "기타 교육: 기타 업무에 필요한 내용에 대해 필요 시 추가 교육 실시",
      "번호": "(4)",
