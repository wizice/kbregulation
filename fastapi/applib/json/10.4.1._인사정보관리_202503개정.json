      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "채용 시 제출된 면허/자격증, 졸업증명서(교육수준), 수련/경력 증명서에 대해 발급기관으로부터 직접 발급사실을 확인하고 기록을 남긴다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "매 3년마다 정기적으로 자격과 면허의 유효성을 재확인한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "확인 대상",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "의사, 간호사, 약사, 영양사, 의료기사, 보건의료정보관리사 등의 자격 및 면허 정보",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "방사선 안전관리책임자, 의공기사, 소방안전관리자 등 직무 수행에 필수적인 자격",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "관련 법에 따라 성범죄 및 아동학대, 노인학대, 장애인학대 관련 전력/경력을 조회하고, 관련 법에 따라 전력/경력이 있는 자는 취업과 근무를 제한한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "근무경력",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "근무경력 정보는 인사운영팀에서 관리한다.",
