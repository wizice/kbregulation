    },
    {
      "seq": 23,
      "레벨": 6,
      "내용": "기본심폐소생술(BLS, Basic Life Support)은 심폐소생술]에 따라 1회/2년 이수한다.",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 24,
