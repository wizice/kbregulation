      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "채용 전 근무/수련 경력을 포함하여 모든 근무/수련 경력 사항을 인사파일에 보관한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "교육 및 훈련",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "직원의 교육 및 훈련 이수 여부를 점검하고, 이수 내역을 정기적으로 인사파일에 기록한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "오리엔테이션: 신규 직원 대상 교육",
