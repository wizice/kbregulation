      "내용": "3.2.1.5. 인공호흡기 적용 환자 관리 4주기 의료기관인증기준: 8.4 의료기구 감염관리 관 련 기 준 JCI Standard 7th Edition: COP.3",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "인공호흡기 적용 환자에게 안전하고 질적인 의료서비스를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "인공기도(Endotracheal Tube): 기관 내 삽관술을 통해 구강이나 비강을 경유해 기관에 삽입된 관",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "의료진은 인공호흡기 적용 전 인공호흡기 치료와 관련된 전반적인 과정 및 치료계획에 대해 환자 또는 대리인에게 설명한다. 응급 상황 시에는 인공호흡기 적용 후 설명할 수 있다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "인공호흡기 적용 환자 진료 시 고려 사항",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "의사는 인공호흡기 시작 및 지속 시 24시간마다 처방한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "인공기도 관리",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "인공기도 삽입 직후와 필요 시 Chest X-ray를 확인하여 인공기도의 위치를 확인한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "인공기도의 삽관일수, 규격, 삽입 깊이, 커프압(공기량) 등을 1일 1회 이상 확인하고 기록한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "교환주기: 인공기도의 교환은 의사의 판단에 따른다. 2주 이상 인공기도의 지속적인 유지가 필요한 경우 기관절개술(Tracheostomy)을 고려할 수 있다",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "비계획적인 인공기도 제거 예방",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 5,
      "내용": "가능하다면 환자에게 인공기도와 인공호흡기의 필요성 및 의사소통 방법을 교육하고 의사소통 도구를 준비한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 5,
      "내용": "환자의 진정 상태와 통증을 평가하고 필요 시 진정제와 진통제를 처방하고 투여한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 5,
      "내용": "필요 시 신체보호대를 사용하며 세브란스병원 내규 [3.2.5.1. 신체보호대 적용 환자 관리]에 따른다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "인공호흡기 적용환자 간호",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "모니터링 및 기록",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 5,
      "내용": "인공호흡기 적용을 시작하거나 Mode 및 설정값을 변경하는 경우 변경 내용을 확인하고 기록한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 5,
      "내용": "근무번마다 인공호흡기 Mode, 설정값 및 환자의 호흡 상태를 평가하여 기록한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 5,
      "내용": "산소포화도를 지속적으로 모니터링한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "인공호흡기 알람 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 5,
      "내용": "인공호흡기의 알람이 울리는 즉시 알람 원인을 확인한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 5,
      "내용": "알람 발생 원인이 환자에게 있는지 인공호흡기에 있는지 감별하고 원인에 따라 적절한 조치를 취한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "응급상황 발생 시 대처",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "인공 호흡기를 적용하고 있는 환자 옆에는 응급상황에 대비하여 소생백(Resuscitation Bag), O2 등 산소 공급 관련 물품을 항시 준비한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "응급상황 발생 시 의사에게 알리고 적절한 조치를 시행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "인공기도가 우발적으로 발관된 경우, 기도 유지 후 적절한 방법으로 산소를 공급하면서 환자 상태에 따라 처치를 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "합병증 예방 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "인공호흡기 관련 감염 관리는 [감염관리지침]을 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "처치 전, 후 반드시 손위생을 하고 필요 시 장갑을 착용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "기관삽관 시 환자의 호흡기 분비물 노출 위험이 높으므로 외과용 마스크와 안면가리개를 착용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "인공기도 적용 환자의 구강간호는 생리식염수를 사용하여 1일 2회 이상 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "금기가 아닌 경우 환자 상체를 30 ~ 45˚올려 위 내용물의 흡인에 의한 폐렴을 예방한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "스트레스성 궤양 예방치료를 시행한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 4,
      "내용": "금기가 아니라면 심부정맥혈전 예방치료를 시행한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 4,
      "내용": "기관절개관 적용 환자의 경우 절개부위 간호를 1일 1회 이상 시행한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "기관 흡인 시 매회 멸균장갑, 멸균카테터, 멸균 생리식염수를 교체하여 사용한다.",
      "번호": "(8)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "환자의 흡인 시에는 의료인의 비강 내 전파를 예방하기 위하여 시행자가 외과용 마스크를 착용한다.",
      "번호": "(9)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "인공호흡기 관리",
      "번호": "(10)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 5,
      "내용": "인공호흡기의 회로(Ventilator circuit)는 멸균된 것 또는 1회용을 사용한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 5,
      "내용": "결핵환자의 경우 1회용 호흡회로를 사용한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 5,
      "내용": "회로에 눈에 보이는 오염이 있거나 환자가 바뀔 때, 결함이 있는 경우 교환한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 5,
      "내용": "인공호흡기에 부착된 가습기에는 멸균증류수를 사용하며 사용직전에 연결하여 무균적으로 보충한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 5,
      "내용": "재사용하는 호흡기 관련 물품은 멸균하여 사용한다.",
      "번호": "⑤",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 5,
      "내용": "응축수가 환자에게 들어가지 않도록 인공호흡기 회로에 고여 있는 응축수는 정기적으로 제거하고, 제거 시에는 장갑을 착용한다.",
      "번호": "⑥",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 5,
      "내용": "이동형 연무기 본체는 사용 후 환경소독제로 닦고, 키트는 환자마다 개별로 사용하며, 매번 사용 후 흐르는 물에 세척하여 건조시키고 매일 교체한다.",
      "번호": "⑦",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "욕창 예방 및 관리는 세브란스병원 내규 [3.1.6.1. 욕창관리]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 2,
      "내용": "인공호흡기 적용 일반병동 침상운영",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "환자진료를 위해 인공호흡기 적용이 필요하나 중환자실 내 가용 침상이 없을 때 적용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "환자의 상태에 따라 의사의 판단 하에 적용한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 2,
      "내용": "병동환자 인공호흡기 적용 시 연락체계",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 3,
      "내용": "일반병동의 입원환자 중 인공호흡기 적용 사유가 발생한 경우, 해당과의 담당의사는 중환자실 전담 내과 의사에게 연락하고 중환자실 호흡기대여 전담 교수에게 협의진료를 의뢰한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "중환자실 전담 내과 의사는 인공호흡기 전담팀에 연락하여 인공호흡기를 준비하도록 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 3,
      "내용": "병동에서 인공호흡기 적용 중 문제가 발생할 경우 중환자실 전담 내과 의사 또는 인공호흡기 전담팀에게 연락한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 2,
      "내용": "병동환자 인공호흡기 적용절차 일반병동 인공호흡기 적용 환자 발생 중환자실 전담 내과 의사에게 연락( 44631)",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 2,
      "내용": "의료기기 관리 및 안전점검",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 3,
      "내용": "정기예방점검: 2회/년 (담당부서: 의공기술팀) 3.2.1.5. 인공호흡기 적용 환자 관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 3,
      "내용": "수시점검: 사용 전 (담당부서: 사용부서)",
      "번호": "2)",
