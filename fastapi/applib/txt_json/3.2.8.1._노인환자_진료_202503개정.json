  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.2.8.1. 노인환자 진료 4주기 의료기관인증기준: 6.2 취약환자 권리보호 관 련 기 준 JCI Standard 7th Edition: PCC.1.5, AOP.1.6, COP.3",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "정신적, 육체적으로 취약하고 의존적인 노인에 대한 적절한 진료지침 및 절차를 마련하여, 이들의 의학적 필요를 파악하고 이를 해결하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "노인환자: 65세 이상의 환자",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "ADL: Activities of Daily Living",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "CGA: Comprehensive Geriatric Assessment",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "노인환자의 치료계획",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "담당 의료진은 노인환자의 영양상태, 운동능력, 인지기능 등을 평가하고, 초기평가 결과에 따라 심층평가가 필요한 경우 노년내과 의료진 등 전문가에게 진료를 의뢰한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "환자의 근력약화를 방지하기 위해 최대한 보행을 독려하고 필요 시 적절한 운동치료를 받을 수 있도록 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "노인환자의 경우 다약제 사용으로 인한 문제 발생의 가능성이 높아(Polypharmacy) 가능한 약물의 치료요법(Regimen)을 간단하게 하고, 자주 검토한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "감염예방을 위해 가능한 빨리 정맥주사(IV Line)와 삽입관(Catheter)을 제거한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "가능한 신체보호대 사용을 피한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "적응증이 되는 상태일 때만 섬망 약물요법(Delirium Medication)을 사용하며 정신건강 의학과와 협의하여 적절한 약물/인지행동치료를 시행한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "과도 진정(Over-Sedate)은 금지한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "의사결정에 환자 및 가족 구성원을 참여시킨다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "신체적으로 제한이 있는 경우 적절한 보조기구를 제공한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "학대와 방임(의심) 노인환자의 경우 세브란스병원 내규 [6.2.1. 취약환자 서비스]에 따라 관리한다.",
      "번호": "10)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "입원 시 보호자 교육",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "ADL 감소가 있는 노인환자는 낙상, 골절, 섬망, 감염, 욕창, 요실금 및 이외의 합병증이 3.2.8.1. 노인환자 진료",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "환자의 간병을 수행할 수 있도록 지속적으로 교육 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "동의서 작성이 필요한 경우",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "이해하기 쉬운 용어로 천천히 설명하고 의사소통한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "인지능력에 따라 대리인을 의사결정에 참여시킨다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "모니터링",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "담당 의료진은 주기적으로 노인환자의 영양상태, 운동능력, 인지기능 등을 평가하고 변화가 있을 경우에는 필요 시 해당 진료과에 협의진료를 의뢰한다. 단, 노년내과 환자의 경우 CGA와 같은 노인포괄기능평가를 통해 평가가 시행된다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "협의진료를 통해 환자의 포괄적 관리가 적절하게 이루어지는지에 대해 주기적으로 평가한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "취약한 노인환자를 고려한 환자의 권리 보호와 안전을 지속적으로 확인한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "담당 의료진은 진료 및 교육 등 일체의 내용을 기록하고 공유한다.",
