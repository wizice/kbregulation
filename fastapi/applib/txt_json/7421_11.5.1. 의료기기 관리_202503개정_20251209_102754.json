  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "11.5.1. 의료기기 관리 제 정 일 2008.09. 최 종 개 정 일 2025.03.25. 최 종 검 토 일 2025.03.25.",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "의료기기에 대한 예방 및 안전점검, 효율적인 관리를 통하여 기기 최적 기능 상태를 유지함으로써 안전한 양질의 진료와 치료를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "의료기기: 의료기기법 제2조 1항에 의한 사람에게 단독 또는 조합하여 사용하는 기구, 기계, 장치, 재료를 이용하여 질병 및 상해 또는 장애를 진단, 치료, 경감, 처치, 연구 또는 예방의 목적으로 사용되는 기기",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "고위험도 의료기기: 교류 전원을 사용하는 기기로 환자의 유해 정도가 높으며 잠재적 위험성 및 중대한 기능 장애에 직면할 가능성이 높은 기기로, 사용부서에서 자체 정기점검이 불가능한 의료기기",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "저위험도 의료기기: 교류 전원을 사용하지 않는 의료기기 및 전원을 사용한다고 하여도 고장이나 이상으로 인하여 인체에 미치는 영향이 없는 기기로, 사용부서에서 자체 정기점검이 가능한 의료기기",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "기타 의료기기: 수술 및 처치에 사용하는 수술기구 및 공구, 각종 세척기 및 단순 기기로 인체에 미치는 영향이 없는 기기",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "의료기기 위원회",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "위원회 구성: [세브란스병원 제위원회 및 위원명단]에 의거하여 구성",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "위원회 역할",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "시설안전관리위원회: 의료기기 목록 관리, 고위험 의료기기 운영 및 예방점검, 의료기기 회수 절차 관리, 의료기기에 대한 사용자 교육 등에 대한 사항 등",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "기자재위원회: 의료기기 도입 및 선정 등에 대한 사항 등",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "의료기기 안전성정보 판별위원회: 의료기기 부작용 및 안전관리 모니터링, 부작용 발생 시 보고 등",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "위원회 운영",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "정기적 운영: 시설안전관리위원회(반기별), 의료기기 안전성정보 판별위원회(월별)",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "비정기적 운영: 기자재위원회(필요 시) 11.5.1. 의료기기 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "위원회 운영 결과 경영진 보고: 위원회 운영 결과는 회차별 경영진에게 보고된다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "의료기기 관리 직원",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "직원 자격 및 면허: 최소 1개 이상 해당",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "의용 공학 및 전자∙전기 관련 학과를 전공한 초대졸 이상 학력 소지자",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "국가에서 인정하는(산업인력관리공단) “의공기사”, “의공산업기사 자격증” 소지자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "대한의공협회에서 발행하는 “의료기기안전관리자 자격증” 소지자",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "대한의용생체공학회에서 발행하는 “의공기사 자격증” 소지자",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "교육: 자격 유지에 필요한 교육을 이수한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "고위험도 의료기기는 의공기술팀에서 안전 관리한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "정기점검에 필요한 측정기를 선정하고 구입한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "해당 부서와 협의하여 예방 점검 계획을 수립하고 점검 관련 Data를 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "점검 시 확인된 문제점을 해결하거나 미해결 시 사용부서에 통보하여 수리한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "신규 장비 도입 시 고위험도 의료기기에 한하여 검수와 동시에 정기점검을 주관하고 점검보고서(QMR; Quality Maintenance Report) 작성 및 관리한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "저위험도 의료기기는 사용부서 자산 관리 담당자 또는 자체에서 안전 관리한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "사용부서의 저위험도 의료기기의 목록 관리",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "정기점검(기기의 청결 유지, 성능 및 동작상태 등) 및 보고서 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "기기의 이동 및 반납 시 신고",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "고∙저위험도 의료기기로 분류할 수 없는 냉장고, 냉동고 및 온장고와 공조 시설을 이용한 장치와 기구 등의 유지보수 및 예방점검은 관련 부서(시설관리팀 등)에서 실시하며 온도 등의 기록이 필요한 경우는 사용부서에서 기록하고 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "의료기기 목록 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "목록관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "의료기관 전체의 의료기기 목록은 의료원 자산관리규정에 의거하여 유형자산, 부외자산 등으로 등록된 의료기기를 list up하며, ERP system을 통해 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "위험 수준에 따른 의료기기 분류를 통하여 의료기기 목록을 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 3,
      "내용": "목록별 점검 주기",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "의료기기 목록 점검 및 작성은 정기적으로 연 1회 ERP system을 통해 실시 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "목록 갱신",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "의료기기 목록은 정기적으로 연 1회 갱신한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "의료기기 목록은 비정기적으로 필요시 갱신하여 의공기술팀에서 보관한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 2,
      "내용": "의료기기 예방점검",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 3,
      "내용": "예방점검은 일상점검과 정기점검으로 구분한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "일상점검은 사용부서에서 주관하며, 부서에서 사용중인 의료기기를 대상으로 시행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "의료기기 일상 점검은 매일 사용하는 의료기기에 대해서 일 1회 시행하며, 매일 사용하지 않는 의료기기의 일상 점검은 월 1회 사용부서에서 시행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "일상 점검은 기기의 동작상태, 기기의 청결상태, 고정 및 지지의 안정상태, 기기의 11.5.1. 의료기기 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "정기점검은 고위험도 의료기기를 대상으로 연 1회 의공기술팀에서 주관하여 시행하는 점검과 저위험도 의료기기를 대상으로 연 1회 이상 사용부서에서 주관하여 시행하는 점검으로 나눈다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 4,
      "내용": "고위험도 의료기기 정기점검",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 5,
      "내용": "계획수립",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 6,
      "내용": "고위험도 의료기기 정기점검을 위해 의공기술팀은 년간 계획을 수립하고 해당 부서와 협의하며 필요 시 협력업체에게 점검을 의뢰할 수 있다.",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 6,
      "내용": "정기 유지보수로 계약된 기기는 계약서 내용에 준하여 점검 계획을 세우고 점검한다.",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 6,
      "내용": "특수부서의 정기점검은 부서의 특수성 고려하여 협의하여 결정한다(단, 당해 연도 회기를 초과할 수는 없다).",
      "번호": "c.",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 5,
      "내용": "방법",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 6,
      "내용": "고위험도 의료기기 정기점검은 필요시 측정기기를 사용하여 Q.M(Quality Maintenance) 방식으로 진행하며, 제조사 혹은 협력업체의 점검 자료도 첨부(포함)할 수 있으며, 모든 점검 자료는 의공기술팀 기기별 QMR(Quality Maintenance Report) 작성을 기준 (원칙)으로 한다.",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 6,
      "내용": "정기 유지보수로 계약된 의료기기 중 고위험도 의료기기는 협력업체의 점검 방법에 따른다.",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 6,
