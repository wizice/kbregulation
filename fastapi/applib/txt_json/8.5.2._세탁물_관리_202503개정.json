    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "의료기관세탁물: 의료기관 종사자와 환자가 사용하는 침구류(이불, 담요 시트, 베갯잇 등), 의류(환자복, 신생아복, 수술복, 가운 등), 수술포, 커튼, 수거자루 등 세탁과정을 거쳐 재사용 가능한 세탁물",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "오염세탁물: 전염성 물질에 오염되었거나 오염될 우려가 있는 세탁물",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "법정감염병 환자가 사용한 세탁물과 감염성 병원균에 오염될 우려가 있는 세탁물",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "환자의 피, 고름, 배설물, 분비물 등에 오염된 세탁물",
