    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "데이터 검증 시점",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "새로운 질지표 사용",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "의료기관의 홈페이지 혹은 기타 방법으로 데이터를 공개하는 경우",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "데이터 측정방법이 변경된 경우(측정도구, 절차 및 추출방법, 및 담당자 변경 등)",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "데이터 결과가 기존자료와 비교 시 달라졌으나 그 원인을 설명할 수 없는 경우",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "데이터 출처가 변경된 경우(의무기록의 서식 변경 등)",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "환자의 평균 연령, 동반 질환, 연구프로토콜의 변경, 신규 임상지침의 도입, 신의료기술 및 새로운 치료방법의 도입 등 자료수집 대상이 변경된 경우",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "데이터 검증 절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "최초 자료 수집에 참여하지 않은 제2인이 자료를 재수집한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "최초 자료원에서 통계적으로 의미있는 표본수를 추출하여 사용한다(단, 원자료의 수가 매우 적은 경우 전수 조사한다).",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "최초 자료와 재수집된 자료를 비교한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "최초 자료와 재수집된 자료간 일치 여부로 정확도를 산출한다. 정확도가 90% 이상 인 경우 적절한 것으로 판단한다(정확도: 일치하는 표본수/전체 표본수×100).",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "자료 요소가 일치되지 않는 경우, 원인을 파악하여 개선한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "문제 요소를 개선 후, 새로운 표본을 추출하여 정확도를 재확인한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "담당부서는 데이터 검증 결과를 의료질향상 및 환자안전위원회에 보고한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "전산프로그램을 구축하여 자동으로 질지표 결과를 산출하는 경우, 전산프로그램 최초 구축 7.6.2. 데이터 검증",
