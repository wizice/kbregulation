    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "사명과 비전",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "사명(Mission): 하나님의 사랑으로 인류를 질병으로부터 자유롭게 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "비전(Vision)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "연세의료원 첨단진료, 전문화, 의료기관간 유기적 관계구축을 통하여 양질의 진료를 제공하고 고객을 섬김으로써 가장 신뢰받는 의료기관이 된다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "개척정신과 협동정신으로 새로운 연구영역을 창출하여 의학기술을 선도하는 연구기관이 되며, 다양하고 인간적인 교육으로 가장 배우고 싶어하는 교육기관이 된다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "알렌, 에비슨, 세브란스의 정신을 이어받아 의료소외지역에 의료와 복음을 전파하여 사랑을 실천하는 의료선교기관이 된다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "이를 위해 우리는 상호 존중하는 성숙한 인격과 책임의식을 갖춘 전문가가 되고, 진취성과 실천력을 겸비한 지도력을 발휘하여 열정과 창의가 살아 숨쉬는 연세의료원을 만들어 나갈 것이다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "사명과 비전 제정 및 승인",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "세브란스병원은 직원, 환자 및 보호자의 건강증진 등을 고려하여 사명과 비전을 제정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "병원운영위원회는 제정된 병원의 사명과 비전을 승인한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "사명과 비전의 이행",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "사명과 비전을 이행하기 위해 중 · 장기적인 목표를 수립하고 목표를 달성하기 위한 구체적인 활동을 수행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "중장기 목표를 달성하기 위해 수행한 활동 내용에 대해 평가를 실시하고 다음 목표 9.2.1. 세브란스병원 사명과 비전",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "세브란스병원의 사명과 비전을 전 직원 및 환자 또는 보호자, 지역사회에 게시판, 병원 홈페이지 등을 통해 공지한다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "직원은 병원의 사명과 비전을 숙지하고 이해한다.",
