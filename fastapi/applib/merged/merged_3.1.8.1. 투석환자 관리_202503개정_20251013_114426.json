    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "투석기계에 공급되는 물은 일반적인 물과는 분리되어 공급해야 하며, 발열물질(pyrogen)의 감소를 위하여 여과나 역삼투압 방식을 거쳐야한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "투석액은 세균과 중금속이 없는 여과수여야 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 4,
      "내용": "투석액과 투석용수는 매월 1회 정기적으로 배양검사(미생물 수를 계산) 및 내독소 검사를 진행하며 세부사항은 [감염관리지침] VII. 부서별 감염관리_11. 인공신장실에 따른다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 4,
      "내용": "미세물질 검사: 연 1회 주기적으로 미세물질 검사를 시행한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "혈행성 감염환자 관리",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "혈액매개 질환 감염환자는 표준주의 지침을 준수한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "HBV(Hepatitis B Virus) 감염 환자는 지정된 투석기계를 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "물품관리: 혈액투석에 사용되는 투석기(Dialyzer)는 1회용을 사용한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "환경관리: 린넨류는 매 환자마다 교체하며, 바닥 청소는 매일 실시한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 3,
      "내용": "감염관리 세부사항은 [감염관리지침]에 따라 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "의료진은 처음 투석 시작 시 환자 및 대리인에게 투석의 전반적인 과정 및 관리 방법에 대해 설명하고 동의서를 받는다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 2,
      "내용": "투석환자 진료과정을 기록한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 2,
      "내용": "의료진은 투석환자 관리에 대한 교육을 받는다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 2,
      "내용": "투석환자 관리 성과를 모니터링하여 병원 전체 질향상 프로그램과 통합 관리하며, 결과를 병원운영위원회 및 세브란스병원장에게 보고하고 관련 직원과 공유한다.",
