  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "10.3.1. 직무관리 및 평가 4주기 의료기관인증기준: 10.3 전문의를 제외한 직원의 직무 확인과 평가 관 련 기 준 JCI Standard 7th Edition: SQE.1, 1.1, 3, 4, 5",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "직무기술서를 체계적으로 작성하고 직무 수행의 적절성을 평가하여, 인력 운영의 효율성을 높이고 인사관리를 체계적으로 운영하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "직무기술서 작성 및 확인",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "대상: 직무기술서는 병원에 근무하는 개개인에 대해 작성한다. 단, 전문의는 작성 대상에서 제외한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "직무기술서 내용: 직무기술서는 다음의 내용을 포함하며, 작성 기준은 직원별, 직종별, 부서별로 상이할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "직무 개요",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "직무 내용 및 책임(직무의 범위)",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "자격 요건",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "필수교육 및 훈련 이수",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "직무능력 평가항목",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "직무기술서 작성",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "직무기술서는 대상자와 부서장이 함께 작성하며, 대상자의 자격요건, 조직과 부서의 서비스 범위 및 책임 등을 고려하여 구체적으로 기술한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "직무기술서 자격요건은 교육정도, 업무역량, 건강상태 등 직무 수행에 필요한 최소한의 자격을 측정 가능한 항목으로 명확히 기술한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "정기적 검토 및 재설계",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "직무기술서는 정기적으로 3년마다 검토하며, 필요 시 개정한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "직무기술서의 개정은 작성과 동일한 절차를 거친다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "직무기술서 확인 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "대상자는 직무기술서의 내용을 충분히 숙지한 후 그에 대한 책임을 수행한다는 의미로 직무기술서에 서명한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "부서장이 대상자의 직무기술서를 검토하고 서명함으로써 직무기술서의 효력이 발생한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "직무능력 평가",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "평가항목: 직무기술서에 명시된 직무 내용을 기반으로 직무 수행의 적절성을 평가할 수 있도록 구성한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "평가주기",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "부서장은 직무기술서에 기술된 내용을 바탕으로 직무능력을 평가하며, 최소 연 1회 이상 평가한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "부서장은 평가 결과를 대상자에게 피드백하여 직무 수행 개선에 반영될 수 있도록 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "평가 결과 활용: 직무능력 평가 결과는 직원 재배치, 직원 교육 및 훈련 등 인력관리에 활용되며, 인사고과에 반영할 수 있다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "필요 시 직무평가를 개정하며, 작성과 동일한 절차를 거친다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "직무기술서와 직무평가서는 부서내 인사파일 또는 ESS(Employee Self Service)에 보관한다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
