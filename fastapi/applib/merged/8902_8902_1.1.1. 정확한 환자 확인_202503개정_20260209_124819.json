    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "모든 상황과 장소에서 일관된 방법으로 정확한 환자 확인을 시행한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "입원환자 대상 정확한 환자 확인 방법 1.1.1. 정확한 환자 확인",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "모든 입원환자는 환자 이름과 등록번호가 기재된 팔찌(또는 발찌)를 착용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "의료진은 환자 입원 시 가능한 빨리 정확한 환자 확인 절차를 거쳐, 환자의 이름과 등록번호가 기재된 팔찌(또는 발찌)를 적용하고, 팔찌(또는 발찌)의 중요성을 설명한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "환자 팔찌(또는 발찌) 적용 시, 혼수상태 환자 또는 의사소통이 어려운 환자와 같이 환자 스스로 이름과 등록번호를 확인해 주는 것이 불가능한 경우 대리인에게 대신 정확한 환자 확인을 하여 환자 팔찌(또는 발찌)를 적용한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "정확한 환자 확인 시, 혼수상태 환자 또는 의사소통이 어려운 환자와 같이 환자 스스로 대답하는 것이 불가능한 경우 환자 팔찌(또는 발찌)의 이름과 등록번호 두 가지 지표를 확인한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "병원에서 출생한 이름이 정해지지 않은 신생아는 친모 이름에 아기(OOO아기)를 붙여 이름을 부여하며, 부여된 이름과 등록번호가 기재된 발찌(또는 팔찌)를 서로 다른 위치에 2개 이상 적용한다. 출생신고 후 아기 이름과 등록번호가 기재된 발찌(또는 팔찌)로 모두 교환한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "응급진료센터에 신원을 확인할 수 없는 환자가 내원한 경우, 임시 이름(미상 등록년월일 – 미상00000000)과 등록번호를 부여하여 팔찌(또는 발찌)를 적용한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "신원미상 환자가 여러 명인 경우, 임시 이름 ‘미상A 등록년월일, 미상B 등록년월일, 미상C 등록년월일…’로 구분한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "신원 확인 시, 수정된 이름과 등록번호가 기재된 팔찌(또는 발찌)를 즉시 적용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "팔찌(또는 발찌) 손상 또는 유실을 확인한 직원은 즉시 정확한 환자 확인 절차를 거쳐 다시 팔찌(혹은 발찌)를 적용한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "신체 또는 치료 특성으로 팔찌(또는 발찌)를 할 수 없는 경우 환의에 부착한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "환자가 팔찌(또는 발찌) 착용을 거절하는 경우, 거절 사유를 파악하여 이를 해결하고 반드시 팔찌(또는 발찌)를 적용하도록 한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "외래환자 및 가정간호 환자 확인 방법",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "환자 이름과 등록번호가 기재된 진료카드 또는 처방 안내문을 확인하여 정확한 환자 확인을 시행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
