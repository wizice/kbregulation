  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "12.1.6. 의무기록 관련 표준코드 4주기 의료기관인증기준: 12.1. 의무기록 관리 관 련 기 준 JCI Standard 7th Edition: MOI.4",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "표준분류체계에 따라 진단, 수술(시술), 암등록 등에 대한 코드마스터를 체계적으로 관리하여 각 용어에 대한 정확한 코드를 부여함으로써, 다양한 이용에 도움이 되게 하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "표준분류체계: 보건의료분야 자료의 표준을 위하여 정해진 표준분류체계를 말한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "사용자 정의어: 사용자가 임상에서 사용하는 용어로서, 의무기록에 기재하는 용어를 말한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "원칙",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "각 용어를 이용하여 자료의 수집, 검색, 통계 생성, 진료비청구업무 등이 원활하게 수행될 수 있도록 코드마스터는 정확성과 최신성을 유지해야 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "분류체계 별로 코드의 길이를 결정하며 확장을 고려하여 충분한 자리 수를 설정한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "분류체계의 특성에 따라 정확한 코드가 선택될 수 있도록 코드마스터 관리항목 설계 테이블을 구성한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "코드마스터의 버전 관리: 장기간 시계열 자료분석을 대비하여 코드별 변경 이력이 관리되어야 한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "적용범위",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "진단코드는 국내 표준으로 통계청이 고시하는 최신 [한국표준질병사인분류(KCD, Korean Standard Classification Of Disease)]를 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "수술 및 처치코드는 국가보건통계사업에 필요한 분류체계에 따라 최신 [국제의료행위분류(ICD-9-CM, International Classification of Disease 9th Revision Clinical Modification)] 또는 [EDI(Electronic Data Interchange)-Code]를 사용한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "암등록코드는 중앙암등록본부가 선정한 국제종양분류(ICD-O)를 따른다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "진단명과 수술명에 대하여는 SNOMED CT(Systematized Nomenclature of Meidicine Clinical Terms)코드를 추가 등록한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "진단, 수술(시술), 처치 등의 마스터는 의무기록팀에서 관리하며, 간호관련용어 등은 간호국에서 표준코드에 따라 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "용어 신청 절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "사용자는 u-Severance 상의 용어신청화면 또는 다른 원하는 방법으로 용어등록을 신청할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 2,
      "내용": "용어 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "u-Severance 용어 마스터에 진단, 수술, 처치, 간호, 약물 등의 마스터를 관리하며, 각 개별 마스터 마다 정의된 필수 항목을 빠짐없이 입력한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "사용자가 새로운 용어 등록 신청을 하는 경우, 특별한 사유가 없는 한 지체 없이 등록하여 즉시 사용할 수 있게 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "용어 마스터에서 목적에 따라 소그룹 마스터를 생성하여 활용할 수 있다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "용어 중 보험 수가의 연결이 필요한 경우, 해당 부서(보험심사팀)에 연락하여 각종 청구관련 마스터와 연결하게 한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "새로운 분류체계가 고시되는 경우 시행일을 기준으로 코드마스터는 최신의 분류체계로 개정하여 사용한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "용어에 대한 등록현황을 정기적으로 확인, 통계 내어 효율적으로 관리한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 1,
      "내용": "(참고)",
      "번호": "제5조",
      "관련이미지": []
    },
    {
      "seq": 30,
