    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자와 보호자가 함께 참여하는 병원문화를 조성하고 무연고 환자(독거노인 등)에 대하여 적정한 대응을 통해 환자안전을 실천하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "무연고 환자(독거노인 등): 입원 후 일정기간 보호자(의사결정의 법정대리인)가 내원하지 않거나 연락이 되지 않는 환자",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "입원원무팀(암병원 원무팀, 각 전문진료기관 원무파트, 이하 입원원무팀으로 표기)은 입원 당일 환자 및 대리인에게 보호자 동반 필요성에 대하여 안내한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "안내에도 불구하고 보호자 없이 입원수속을 하는 경우 보호자 내원이 필요한 사유(의료진이 수행하는 수술, 검사, 치료에 대한 설명 등)를 환자에게 구두설명하여 보호자 동반 필요성을 재안내한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "입원 후 무연고 환자로 판단되고 문제발생 우려(환자상태 악화 등)가 있는 환자임이 인지되는 경우 지체 없이 입원원무팀, 암병원원무팀, 각 전문진료기관 경영지원팀 원무 파트에 협조(보호자 소재파악 등)를 요청한다. 정규 업무시간 외에는 응급진료센터 원무담당자에게 협조요청한다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "입원원무팀, 암병원원무팀, 각 전문진료기관 경영지원팀 원무파트에서는 의뢰된 무연고 환자에 대하여 병동과 협조하여 신속히 보호자 소재파악을 실시하며 파악이 어려운 경우 환자의 주소지 관할 시·군·구청에 협조를 요청하고 진행상황을 해당 병동과 공유한다.\n(예: 서대문구청 복지정책과 ☎ 02-330-1616)",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
