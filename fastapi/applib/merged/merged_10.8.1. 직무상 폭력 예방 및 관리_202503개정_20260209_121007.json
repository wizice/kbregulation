    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "폭력 발생 시 대응",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "폭언, 폭행 및 협박 등 문제 발생 시 보안요원(44915)에게 연락한다. 단, 폭력 발생 응급상황 시 중계대(112)에 코드그레이 3 방송을 요청할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "현장에 도착한 보안요원은 폭언, 폭행 및 협박 등에 대한 일차적인 제제 및 경고를 실시하고 가해자를 현장에서 격리시킨다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "사무팀/경영지원팀/암병원 기획경영팀, 원무팀, 법무팀, 환자안전팀 등 관련 부서가 함께 가해자와 면담을 실시하고 추후 발생 시 녹음, 녹화를 실시함을 사전 고지한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "폭언, 폭행 및 협박 등 관련 정식 경고를 시행하고 필요 시 법적 처리를 준비한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "폭언, 폭행 및 협박 등 발생 시 의무기록에 반드시 기록한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "정보공유를 위해 u-Severance 환자상세정보에 관련 정보를 등록한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "직장 내 괴롭힘·성희롱·성폭력 발생시에는 그룹웨어 열린상담실 또는 통합신고센터 (원내129)으로 신고하여 상담 받을 수 있다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "환자(보호자) 및 직원에 대한 폭력 발견 시 신고할 수 있도록 신고처를 게시 및 안내한다.",
