    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "직장 내(업무 중) 폭력에 노출된 경우 대처와 추후 관리에 대한 세부 지침을 정하여 안전한 진료환경 조성 및 직원 존중을 위해 의료기관 내 폭력 예방 활동을 수행하고 관리하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "폭력의 범위: 폭언, 폭행, 협박, 성폭력, 성희롱, 직장 내 괴롭힘 등",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 3,
      "내용": "폭언: 욕설 등으로 상대의 정신에 악역향을 미치는 행위 또는 상대방의 인격권을 침해하는 욕설, 기타 모욕적인 언사",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "폭행: 사람의 신체에 대한 직·간접적 유형력의 행사",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "협박: 남에게 어떤 일을 하도록 위협하는 행위로 상대에게 공포심을 일으키기 위하여 생명·자유·명예·재산에 해(害)를 가할 것을 통고하는 행위",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "성폭력: 타인에게 성(性)과 관련해 위해를 가하는 폭력적 행위와 상대방의 의사에 반하는 성적인 접근을 통틀어 이르는 말로 강간, 강제추행, 성희롱 등을 포괄하는 개념",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "성희롱: 지위를 이용하거나 업무 등과 관련하여 성적 언동 등으로 상대방에게 성적 굴욕감이나 혐오감을 느끼게 하는 행위(단체협약 제29조의1 ②지위를 이용하거나 업무 등과 관련하여 성적 굴욕감 또는 혐오감을 느끼게 하거나 성적 언동 기타 요구 등에 대한 불응을 이유로 불이익을 주는 행위)",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "직장 내 괴롭힘: 직장에서의 지위 또는 관계 등의 우위를 이용하여 업무상 적정범위를 넘어 다른 근로자에게 신체적·정신적 고통을 주거나 근무환경을 악화시키는 행위",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "폭력 발생 응급상황",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "보안요원이 대처하기에 불가항력적인 상황",
