    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "약어와 금지약어에 관한 지침을 제정하여 의무기록에서 약어 사용에 대한 기준을 확립하고, 약제 등을 처방하는데 잠재적으로 위험한 약어 및 용량 표현을 제한함으로써 정확성과 책임성의 제고를 통하여 환자의 안전을 도모하고 진료서비스의 질을 향상시키기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "약어: 의무기록에 사용되는 영문 의학용어를 간략한 형태로 줄인 용어 또는 기호",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "금지약어(금지기호): 의무기록 상에 사용하지 말아야 할 약어 및 기호",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "공식약어: 의무기록위원회에서 사용 승인되어 약어마스터에 등록된 약어",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "약어 사용 원칙",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "의무기록에는 가능한 약어를 사용하지 않는 것을 권고한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "약어 사용 시에는 승인된 공식약어를 사용한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "각 약어는 한 가지의 의미를 가진다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "동의서, 퇴원안내문, 퇴원요약 및 환자와 가족이 전달받는 문서에는 약어를 사용하지 않는다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "절차 및 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "의무기록위원회는 의무기록 작성에서 사용할 수 있는 약어와 금지약어(금지기호) 목록을 정하며 의료진에게 해당 사항을 공지한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "금지약어(금지기호) 목록과 병원에서 사용이 승인된 약어는 u-Severance ‘EMR(Electronic Medical Record) 약어사전’에서 확인할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "승인된 약어는 ‘EMR 약어사전’에 최신의 것으로 업데이트 되고 관리되어야 한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "주기적(분기별)으로 공식약어 및 금지약어(금지기호) 사용 현황을 모니터링하여 관리한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "금지약어(금지기호) 목록은 정기적(연 1회)으로 관리하며 필요 시 재검토하여 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
