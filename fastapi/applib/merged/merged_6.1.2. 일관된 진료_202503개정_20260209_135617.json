  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "6.1.2 일관된 진료 JCI Standard 7th Edition: COP.1, ACC.3.1, PCC.1.3 관 련 기 준",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "동일한 건강상의 문제 및 의학적 중재가 필요한 환자는 일관된 진료를 제공받음을 기술하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "병원 내에서 동일한 건강상의 문제 및 의학적 중재가 필요한 환자에게 일관된 의료서비스를 제공할 수 있도록 진료를 계획하고 실행한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "환자의 인종, 피부색, 성, 언어, 종교, 경제적 상태, 국적 등의 이유로 진료를 거부하지 않는다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "일관된 진료를 위해 다음 사항을 준수한다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "환자는 환자의 소득 또는 지불능력과 관계없이 적절한 진료를 받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "환자는 자격을 갖춘 의료진으로부터 진료를 제공받으며, 요일이나 시간에 구애 받지 않는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "환자상태의 중증도에 따라 환자의 요구에 맞는 의료자원이 환자에게 제공된다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "환자가 제공받는 진료수준은 병원의 내규와 지침에 따라 일관성 있게 시행된다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "병원 전체적으로 동일한 간호요구를 가진 환자에게 동일한 수준의 간호가 제공된다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "입원 및 외래 환자 등록절차가 병원의 내규와 지침에 따라 환자에게 일관성 있게 시행된다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "병원은 법과 규율에 따라 일관된 진료를 환자에게 제공한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "병원의 부서 리더들은 일관된 진료 과정을 제공하기 위해 협업한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
