  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.2.2.2. Emergency Cart 관리 4주기 의료기관인증기준: 3.2.2 심폐소생술 관리 관 련 기 준 JCI Standard 7th Edition: MMU.3.1, COP.3.3",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "Emergency Cart (이하 E-Cart) 내 응급 약품 및 물품의 종류, 수량, 유효기간에 대한 관리 규정을 두어 안전하게 보관하며, 응급 상황(심정지, 호흡정지, 아나필락시스 등) 시 신속하게 사용하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "Emergency Cart(E-Cart): 응급상황에 신속한 투여가 필요한 의약품 및 물품을 보관하는 Cart",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "E-Cart 구비",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "심폐소생위원회에서 정한 환자 진료 구역에 E- Cart를 구비한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "E-Cart의 구성은 성인용과 소아용이 있으며, 환자 진료구역의 특성에 따라 성인용 또는 소아용을 구비한다. E-Cart 구비 시 주 진료과를 우선으로 고려한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "E-Cart 신설과 폐기",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "E-Cart의 신설과 폐기는 심폐소생위원회에서 결정하며 필요 시, 공문 형식으로 요청한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "E-Cart 응급의약품과 물품 목록의 결정",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "E-Cart 내 응급의약품 및 목록은 심폐소생위원회에서 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "심폐소생위원회는 E-Cart 내 응급의약품 및 물품 목록을 연 1회 검토하며 유지 및 관리하고 분실과 도난 방지 방법을 개발하고 시행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "환자 진료구역의 특성에 따라 E-Cart 내 응급의약품이 기본 수량 이상 보유가 필요할 때에는 약무국에 공문 형식으로 요청한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "E-Cart의 점검 및 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "E-Cart 내 응급 약품 및 물품의 일상적인 점검 및 관리는 해당 진료구역의 관리 담당자가 실시하며, 관리 담당자는 사용 후 수시점검 및 매월 정기점검을 시행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "진료구역의 관리 담당자는 매일 E-Cart의 Security Seal의 일련번호를 확인하고, Security Seal 점검표를 작성한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "E-Cart 내 응급의약품의 관리는 세브란스병원 내규 [4.3.2. Emergency Cart 내 응급의약품 3.2.2.2. Emergency Cart 관리",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "E-Cart의 사용",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "E-Cart는 응급 상황(심정지, 호흡정지, 아나필락시스 등)에 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "사용한 E-Cart는 상황 종료 직후 관리 담당자가 재충진한다.",
