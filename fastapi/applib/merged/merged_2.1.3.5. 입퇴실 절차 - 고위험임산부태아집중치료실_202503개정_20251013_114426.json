      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "집중치료가 필요한 환자에게 한정된 자원을 효율적으로 활용하여 적절한 의료서비스를 제공하기 위해 표준화된 고위험임산부태아집중치료실 입퇴실 절차를 준수하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "MFICU(Maternal Fetal Intensive Care Unit): 고위험임산부태아집중치료실",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "입실기준: 고위험임산부태아집중치료실 입실을 위해 아래의 조건 중 하나 이상에 해당되는 임산부로서 집중치료가 필요하다고 의사가 판단한 경우",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "자궁 수축 검사상 20분 동안 4회 이상 또는 1시간 동안 8회 이상의 자궁수축이 관찰된 임신 34주 이내의 조기진통",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "임신 34주 이내의 조기 양막파열",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "자궁경부무력증으로 응급수술 전·후 경과관찰을 요하는 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "중증 전자간증 또는 자간증",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "양수과소증 또는 양수과다증",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "자궁내 발육지연",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "쌍태간 수혈증후군 환자",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "산과적 출혈",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "38도 이상의 고열이 있는 임산부",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "입실 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "입실기준에 따라 주치의(담당교수)가 환자의 입실을 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "의료진은 입실 시 환자 또는 대리인에게 입실 필요성을 설명하고 동의를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "입실 시점의 환자 상태를 평가하고 입실 기준에 부합하는지를 의무기록에 기록한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 2,
      "내용": "퇴실 기준",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
