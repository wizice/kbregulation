    "규정표기명": "8.8.3. 개인보호구 사용",
    "제정일": "2014.04.",
    "최종개정일": "2025.03.25.",
    "최종검토일": "2025.03.25.",
    "담당부서": "감염관리실",
    "유관부서": "",
