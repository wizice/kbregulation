  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "8.3. 개인보호구 사용",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "감염 전파 차단을 위하여 의료진과 환자의 오염을 최소화하기 위해 사용하는 개인보호구의 지침을 마련하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "개인보호구: 마스크(Masks), 보안경 및 안면보호구(Goggles and Face shield), 가운(Gowns), 장갑(Gloves)이 포함된다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "Level D: 질병관리청 및 본원 내부 지침에 따라 감염병 대응 시 적용하는 개인보호구의 등급 기준 중 하나로 가장 낮은 단계에 해당한다. 전신 보호복, N95 동급의 호흡기 보호구, 장갑, 보안경 또는 안면보호구, 신발 덮개 등이 포함된다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "개인보호구는 환자 개별로 교체하여 사용한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "개인보호구는 사용장소에서 사용 후 즉시 벗는다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "개인보호구를 벗은 후에는 손위생을 실시한다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "개인보호구는 감염성 질환이 의심되지 않더라도 혈액이나 체액에 노출될 우려가 있는 경우 피부, 점막, 의복 등을 보호하기 위해 착용한다. 노출 예상 수준에 따라 위험도를 평가하여 적절한 개인보호구를 선택하며, 필요한 보호 수준에 따라 마스크, 가운, 보안경(안면보호구), 장갑 등을 단독으로 또는 병용하여 사용한다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "마스크(Masks)",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "일반적인 마스크의 적응증은 공기 또는 비말로 전파되는 호흡기 감염을 예방하기 위함이며 감염이 의심되지 않더라도 혈액, 체액, 분비물, 배설물 등이 튈 염려가 있을 때 착용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "마스크 종류",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "외과용 마스크",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 5,
      "내용": "수술실, 중심정맥관 삽입 및 드레싱, 척추강내 혹은 경막하공간 시술 시, 흉강천자, 복수천자, 기관삽관 및 발관, 호흡기 증상이 있는 경우 사용한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 5,
      "내용": "면역저하자 및 공기매개 감염환자의 이동 시 환자가 착용한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "KF94 마스크: 대규모 호흡기 감염병 유행 시 원내 지침에 따라 사용할 수 있다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "N95 Respirator: 공기매개감염 질환이 의심되거나 확진된 환자의 에어로졸 생성 시술이나 검사, 공기매개감염 격리실 출입 시 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "마스크(Mask)의 사용원칙을 준수한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "1회 사용을 원칙으로 하며 목에 걸치거나 주머니에 보관하지 않는다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "사용 중 마스크의 모양이 변형되거나 손상되는 경우, 유기물이나 체액/혈액이 묻은 경우에는 즉시 교체한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "마스크를 벗을 때는 앞면에 손이 닿지 않도록 하고 벗은 즉시 손위생을 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "보안경 및 안면보호구(Goggles and Face shield)",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "혈액, 체액, 분비물 등이 튈 우려가 있을 경우 개인선호도에 따라 보안경 또는 안면보호구를 선택하여 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "장갑(Gloves)",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "멸균장갑과 청결장갑으로 구분되며 노출 수준에 따라 재질을 선택하여 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "1회 사용을 원칙으로 하며 착용 전·후에 손위생을 실시한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "같은 환자에게 사용하더라도 사용 부위가 달라지면 교체한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "멸균 장갑을 사용할 경우에는 무균술을 사용하여 착용한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "사용 중 장갑이 파손될 경우 즉시 교체하고 장갑을 벗을 때는 장갑 표면과 접촉하지 않도록 주의한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "침습적 처치 시에는 멸균장갑을 사용하고 멸균부위가 아닌 경우의 접촉 시에는 청결장갑을 사용한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "가운(Gowns)",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "멸균가운과 청결가운으로 구분되며 접촉의 수준과 방수 여부를 고려하여 재질을 선택하여 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "사용 즉시 벗고 벗은 직후 손위생을 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "사용한 가운의 바깥쪽은 오염된 것으로 간주하여 벗을 때 안쪽이 바깥으로 나오도록 주의하여 벗는다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "수술, 분만 및 침습적 시술 시, 무균실 출입 시에는 멸균가운을 사용하며 격리환자 접촉 시에는 청결가운을 사용한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "개인보호구는 사용이 편한 위치에 비치한다.",
      "번호": "9.",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 2,
      "내용": "신규 직원은 적절한 개인보호구 선택과 올바른 사용방법에 대한 교육을 받는다.",
      "번호": "10.",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 2,
      "내용": "의료진은 필요 시 환자 및 보호자에게 개인보호구 사용방법 및 주의사항을 교육한다.",
      "번호": "11.",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 2,
      "내용": "Level D 수준 이상의 개인보호구 및 PAPR(Powered Air Purifying Respirator)의 사용이 요구되는 감염성질환과 접촉하는 직원은 매년 관련 보호구 사용에 대한 훈련을 받고 진료 투입 전 교육과 훈련을 추가로 받는다.",
      "번호": "12.",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
