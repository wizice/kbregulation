  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.3.6.2. 영상검사 결과 보고 – 핵의학과 4주기 의료기관인증기준: 2.3.6 영상검사 결과 보고 절차 관 련 기 준 JCI Standard 7th Edition: AOP.5.1, 5.4, 5.5, 5.9.1, 6.1, 6.3~6.6, IPSG.2, 2.1",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자의 생명을 위협하거나 위해를 줄 수 있는 핵의학과 영상검사 결과 보고체계 및 관련 의사소통 절차를 확립하여 적절한 진료 및 환자의 안전을 도모하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "PACS(Picture Archiving Communication System): 의료 영상을 디지털 형태로 저장, 전송, 진단하는 시스템",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "EMR: Electronic Medical Record",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "핵의학과 영상검사 결과보고",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "검사종류별 보고방법",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "검사 보고방법: 촬영한 영상에 대해 처방, 환자정보 및 검사 목적에 적합한지 확인하고 PACS 시스템으로 영상을 전송하여 판독이 되도록 지원한다. 판독이 완료되면 판독결과를 EMR로 전달하여 관련 의료진이 조회할 수 있도록 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "검사부서는 각각의 검사결과의 판독 및 보고에 대한 기준 범위(참고치)를 확립하며 세부지침은 부서별 업무규정에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "검사결과 보고시간(Turn-Around Time, TAT)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "검사결과 보고시간이란 검사 완료시부터 판독 완료시까지의 시간을 말한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "정규검사",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 5,
      "내용": "입원: 입원 환자 검사 시 TAT는 48시간 이내로 하되 단, 금오일 시행한 환자는 96시간 이내로 한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 5,
      "내용": "외래: 외래에서 처방되어 시행하는 핵의학 영상검사 TAT는 7일 이내로 한다. 외래 진료예약이 7일 이전에 예약된 환자는 외래 진료예약 이전 시간까지로 한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "응급검사: 환자가 수술을 요하거나 임상과에서 긴급검사 요구 시 TAT는 24시간 이내로 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "이상 검사결과 보고(Critical Value Report, CVR)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "보고 대상 및 기준: 핵의학과 검사 유형에 따라 이상검사결과 보고 기준을 확립하며, 세부지침은 [부록 2. 핵의학과 CVR 지침]을 참고한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "이상검사결과 확인 시 보고 절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "검사결과에서 Critical Value가 확인되면 핵의학과 판독의사 또는 전문의가 담당 의료진에게 판독 결과를 문자 전송 또는 유선으로 알린다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "검사부서에서는 이상검사결과 리스트 및 보고 현황을 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "보고된 검사결과가 변경될 경우 보고절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "동일검사 결과보고의 결론이 변경된 경우에는 의료진에게 문자 또는 유선으로 알린다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "유선으로 검사결과 보고 시, 세브란스병원 내규 [1.2.1. 구두/전화처방]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "검사의 판독과 결과 보고에 필요한 경우 임상적 이유가 처방 또는 판독의뢰서에 포함된다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "결과보고소요시간(TAT)은 병원에서 정한 지침에 따르며, 세부적인 지침은 부서별 및 검사항목별로 정한다. TAT 결과를 모니터링하고 분기별로 보고하며, 이를 의료진간 공유한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 29,
