  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "4.3.1. 의약품 보관 4주기 의료기관인증기준: 4.3 약품의 보관 관 련 기 준 JCI Standard 7th Edition: MMU.3, 3.1, 3.2, 6.2.1",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "의약품을 도난 또는 분실의 위험으로부터 안전하게 보관하고, 적시에 사용하기 위해 허가된 보관 조건을 준수하여 모든 의약품을 적절하게 보관 및 관리하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "의약품의 보안",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "의약품 보관 부서(또는 구역/장소)는 도난 또는 분실을 방지하기 위해 외부인의 출입을 제한하거나 보관 부서의 특성에 적절한 보안장치를 설치하여 관리 책임자의 감독 하에 관리한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "의약품 보관 부서: 약무국, 병동 간호구역, 중환자실, 수술실, 응급진료센터, 주사실, 검사실, 구급차 등",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "보안장치: 잠금장치, 출입문 안면(또는 정맥) 인식 장치, CCTV 등",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "보안장치를 설치하기 어려운 장소에 의약품을 보관할 경우 적절한 방법으로 외부인을 통제한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "마약류는 세브란스병원 내규 [4.3.4. 마약류 관리]에 따라 관리한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "의약품 보관 및 유지",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "의약품 보관 시 약품명(또는 성분명), 유효기간, 필요 시 주의사항 등에 대해 라벨링한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "약무국은 모든 의약품 보관 부서의 비치의약품 목록을 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "의약품별로 식품의약품안전처로부터 허가받은 보관 조건을 준수하여 보관한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "약품을 보관하는 부서는 보관 환경 및 설비에 대한 정기적인 점검을 실시한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "다량의 약품이 보관되어 있는 설비의 경우 시설관리팀 또는 설비업체를 통해 정기점검을 시행한다. (예: 약무국 약품 보관 냉장고 – 월 1회 점검)",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "냉장, 냉동, 냉소 보관이 필요한 약품은 각 기준에 맞는 환경, 설비에서 저장, 관리하며, 보관 시, 아래의 온도를 준수하고 매일 자체적으로 온도를 점검하고 기록한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "냉장: 2 ~ 8℃",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "상온: 15 ~ 25℃",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "실온: 1 ~ 30℃ 4.3.1. 의약품 보관",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "냉소: 1 ~ 15℃ 이하 (별도 규정이 없는 경우)",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "냉동: -25 ~ -10℃ (USP General Notices)",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "샘플 의약품은 환자 치료 목적으로 사용하지 않는다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 2,
      "내용": "의약품 보관에 대한 정기적 감사",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "시행: 약무국",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "대상: 의약품 보관 부서",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "주기: 연 4회(분기별)",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "의약품별 보관방법(냉장, 차광 등) 준수, 유효기간, 목록 및 수량 일치, 잠금장치 등 보관상태 및 관리현황에 대해 점검 후 점검사항을 기록한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "손상 및 파손된 의약품, 유효기간이 만료된 의약품 등은 회수하여 부서장에게 보고하고 처리(교체)한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "의약품의 유효기간 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "유효기간 만료일이 12개월 이상 확보된 의약품을 입고하는 것을 원칙으로 한다. 다만, 재고 확보에 문제가 있는 것은 예외로 할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "모든 의약품(조영제, 수액 등 포함)은 수령 시 유효기간을 확인한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "의약품 보관 부서는 분기별(연 4회)로 유효기간을 점검한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "유효기간이 6개월 미만인 의약품은 점검표에 기록 후 ‘유효기간 주의’ 라벨을 부착하여 관리하고, 유효기간이 근접한 약을 먼저 사용할 수 있도록 한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "원내 처방에 따라 조제, 투여된 의약품은 투여 예정일까지 사용한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "낱알 포장 또는 소분하여 조제된 퇴원약과 외래약의 유효기간은 투여 완료일 이후 90일까지로 한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "PRN(필요시) 처방이나 장기간 투여하도록 처방된 의약품은 약품에 표기된 유효기간을 준수하며, 유효기간이 경과된 의약품은 폐기 조치한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "원내에서 무균 조작법에 따라 조제된 의약품은 약품별 허가된 보관 기준에 따라 저장, 관리한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "유효기간이 만료된 의약품은 부서장에게 보고하고 세브란스병원 내규 [11.3.2. 의료폐기물 관리]에 따라 폐기하며 폐기의약품 목록을 관리한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 2,
      "내용": "의약품 유효기간 관리지침",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 43,
