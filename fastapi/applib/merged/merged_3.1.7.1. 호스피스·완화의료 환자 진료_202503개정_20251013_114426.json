      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "말기환자(Terminally Illness)",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 3,
      "내용": "의사와 해당분야의 전문의 1명으로부터 수개월 이내에 사망할 것으로 예상되는 진단을 받은 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "적극적인 치료에도 불구하고 근원적인 회복의 가능성이 없고 점차 증상이 악화되는 환자",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "임종과정",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "회생의 가능성이 없고, 치료에도 불구하고 회복되지 아니하며, 급속도로 증상이 악화되어 사망에 임박한 상태",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "임종과정에 있는 환자",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "의사와 해당 분야의 전문의 1명으로부터 임종과정에 있다는 의학적 판단을 받고 임종과정에 있는 환자 판단서 서식이 작성된 자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "연명의료중단등결정",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "임종과정에 있는 환자에 대한 연명의료를 시행하지 아니하거나 중단하기로 하는 결정",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "완화의료(Palliative Care) 환자",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "주 질환 치료가 아닌, 질환으로 인한 통증 등의 증상을 완화시키고, 정신적, 사회적, 영적, 종교적 지지를 통해 투병과정 중 삶의 질을 향상시키며, 편안하고 존엄한 임종을 위해 완화의료가 필요하여 완화의료센터로 협의진료가 의뢰되거나 완화의료병동에 입원한 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "말기·임종기 환자 진료",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "말기·임종기 진료 시 고려사항",
