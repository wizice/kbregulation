    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "이상 검사결과 보고(Critical Value Report, CVR)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "보고 대상 및 기준: 병리과 검사 유형에 따라 이상검사결과 보고 기준을 확립한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "병리과로 접수된 모든 검체(조직; 생검, 수술, 동결 절편; 세포) 중에서 다음 각 호에 해당 시 이상검사결과로 보고한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "이상검사결과 확인 시 보고 절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "검사결과에서 Critical Value가 확인되면 판독의사 또는 전문의가 30분 이내 담당 의료진에게 문자 전송 또는 유선 또는 이메일로 알린다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "검사부서에서는 이상검사결과 리스트 및 보고 현황을 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "중간결과 보고",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "실시 기준 및 보고 대상: 파라핀 재포매, 재박절, 각종 염색, 자문 등 다양한 원인으로 인하여 확정적인 진단이 지연되는 경우에 실시한다",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "보고방법: EMR에 임시진단명과 임시진단을 하는 이유와 계획에 대해서 주석을 이용하여 언급한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "중간보고를 한 경우 해당 부서에서 중간 보고된 리스트를 관리한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 2,
      "내용": "보고된 검사결과가 변경될 경우 보고절차",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 3,
      "내용": "동일검사 결과보고의 결론이 변경된 경우에는 의료진에게 문자 또는 유선으로 알린다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "유선으로 검사결과 보고 시, 세브란스병원 내규 [1.2.1. 구두/전화처방]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 2,
      "내용": "결과보고소요시간(TAT)은 병원에서 정한 지침에 따르며, 세부적인 지침은 부서별 및 검사항목별로 정한다. TAT 결과를 모니터링하고 분기별로 보고하며, 이를 의료진간 공유한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
