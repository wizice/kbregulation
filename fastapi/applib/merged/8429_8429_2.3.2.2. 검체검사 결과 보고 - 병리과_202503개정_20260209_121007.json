      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "검체검사의 결과 보고체계 및 관련 의사소통 절차를 확립하여 적절한 진료 및 환자의 안전을 도모하고, 환자의 생명을 위협하거나 위해를 줄 수 있는 검사결과 이상치 발생 시 신속하게 대응하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "검체검사 결과보고",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "검사종류별 보고방법",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "병리과 검체검사에 대한 결과 보고는 병리과 전문의의 판독 및 최종 전자서명 확인을 거친 후 임상과에 보고한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "검사부서는 각각의 검사결과의 판독 및 보고에 대한 기준 범위(참고치)를 확립하며 세부지침은 부서별 업무규정에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "검사결과 보고시간(Turn-Around Time, TAT)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "검사결과 TAT는 검체 접수시간부터 결과보고 시간까지로 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "응급, 비응급 검사의 정의는 아래와 같이 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 5,
      "내용": "응급 검사: 수술 중 동결절편 검사",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 5,
      "내용": "비응급 검사",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 6,
      "내용": "조직 생검: 위, 대장, 전립선 등 내시경 검체",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 6,
      "내용": "일반 검체: 내시경 검체를 제외한 포르말린 병에 담겨오는 조직",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 6,
      "내용": "수술 검체: 부속장기가 확인되는 검체",
      "번호": "c.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 6,
      "내용": "탈석회화 및 특수검사가 필요한 검체: 신장, 간, 근육, 피부, 뇌, 골수, 뼈, 석회화된 검체",
      "번호": "d.",
      "관련이미지": []
    },
