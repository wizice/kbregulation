  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.2.3.1. 수혈환자 관리 4주기 의료기관인증기준: 3.2.3 수혈환자 관리 관 련 기 준 JCI Standard 7th Edition: AOP.5.11, COP.3.4, QPS.7, 8",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "수혈요법과 관련된 절차를 관리함으로써 환자에게 안전하고 효과적인 수혈서비스를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "수혈 전 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "수혈여부 결정",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "수혈의 주된 목적은 부족한 혈액성분을 보충하기 위함이며, 수혈부작용의 발생을 최소화하기 위하여 환자에게 필요한 성분만을 보충하는 성분수혈을 우선 실시한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "수혈은 부작용을 동반할 수 있으므로 수혈의 효과와 부작용, 적정 수혈, 수혈의 대안에 대해 충분히 고려한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "동의서",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "수혈예정 환자 또는 보호자(법정대리인)에게 수혈의 필요성과 부작용 등을 설명하고 동의서를 받는다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "수혈동의서는 입원기간 동안 1회(최초 수혈 전) 작성하고, 외래환자의 경우 연 1회 작성한다. 단, 수술/시술/검사 중에 수혈을 하는 경우에는 별도의 수혈동의서 없이 ‘수술/시술/검사(수혈) 동의서’로 대신할 수 있다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "긴급하게 수혈을 진행할 경우 해당 사유를 기록하며, 수혈 후에 환자 또는 보호자(법정대리인)에게 설명 후 수혈동의서를 받는다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "수혈용 검체 채취",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "검체 채취 전 환자 이름과 등록번호를 확인한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "수혈용 검체는 항응고제가 들어있는 K2 EDTA Tube에 채혈하고 라벨링(환자 이름, 등록번호, 채혈일 등) 후 채혈자를 기록한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "혈액제제 신청",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "혈액제제는 ‘혈액출고의뢰서’(전산 처방 포함)를 통해 혈액은행에 요청한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "‘혈액출고의뢰서’(전산 처방 포함)는 의사가 처방한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "‘혈액출고의뢰서’에는 환자정보(환자 이름, 등록번호, 연령, 성별), 의뢰일, 의뢰자명, 진료과, 혈액제제 사용일 및 혈액제제 명칭, 수량 등의 항목이 포함된다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "수혈전 검사를 생략하고 수혈을 해야 할 응급상황 시에는 ‘초응급혈액출고요청서 (전산 처방 포함)’를 통해 혈액은행에 요청한다. 혈액은행에서는 우선 O형 적혈구 출고를 원칙으로 하며, 환자의 혈액형이 확인되는 경우에는 ABO 동형의 혈액을 교차시험 없이 출고할 수 있다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "혈액전용냉장고 사용 시 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "혈액제제를 보관하는 온도 관련 장비(수술실 포함)에는 실시간 온도기록이 가능한 온도기록계와 이상 온도 경보 장치가 설치되어 있어야 하며, 전원이 꺼져도 경보가 가능한 배터리 시설이 되어있는 장비를 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "이상 유무 확인을 위해 실시간 온도기록과 1일 1회 이상 온도 점검을 시행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 2,
      "내용": "혈액전용냉장고가 없는 부서에서의 혈액제제 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "혈액전용냉장고가 없는 부서에서는 혈액은행으로부터 출고된 혈액을 최대한 신속히 수혈한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "병동에서의 혈액보관은 원칙적으로 금한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 2,
      "내용": "수혈 전 혈액제제 확인 절차",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "수혈 전 의료인 2인이 환자 이름, 등록번호, 혈액형, 혈액번호 등을 확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "환자정보와 혈액정보가 불일치하거나 혈액상태의 이상이 발견되는 경우 수혈을 보류하고 혈액은행으로 연락한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "수혈 전 환자 확인",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "수혈 직전 환자 곁에서 교차시험(Crossmatching) 결과 표지가 붙은 혈액제제를 환자의 이름, 등록번호, 혈액형(ABO 및 RhD)과 비교하여 두 명의 의료인이 소리 내어 비교하며 재확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "모바일 u-Severance 시스템을 사용하여 환자와 혈액제제를 확인하는 경우, 의료인 1인이 시행할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 2,
      "내용": "수혈 중 관리",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "수혈 직전 활력징후를 측정하여 기록한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "수혈 시작은 혈액 불출 후 30분 이내에 실시한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "수혈 시작 후 처음 15분 동안 환자상태를 모니터링하면서 천천히 주입하고, 수혈 시작 15분 후 활력징후를 측정하여 기록한다. 필요 시 환자상태를 추가 평가한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "수혈은 최대 4시간 내에 완료한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "적혈구제제와 성분채혈혈소판은 1단위, 농축혈소판은 6단위 마다 활력징후를 측정하여 기록한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "수혈이 완료될 때까지 환자상태를 주기적으로 확인한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 3,
      "내용": "수혈이 끝난 직후 활력징후를 측정하여 기록한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 2,
      "내용": "수혈 시 주의사항",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "모든 혈액제제는 혈액응괴와 다른 찌꺼기들을 제거하기 위해 반드시 미세필터가 3.2.3.1. 수혈환자 관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 3,
      "내용": "혈액제제는 각 제제별 적절한 속도와 시간에 따라 수혈한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 3,
      "내용": "혈액제제는 세균증식의 위험 때문에 오랜 시간 실온에 방치하지 않는다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 3,
      "내용": "원칙적으로 혈액제제에 약제를 같이 주입하지 않는다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 2,
      "내용": "수혈부작용 발생 시 대처방안",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "호흡곤란, 발열, 오한, 두드러기, 혈압변화 등 수혈부작용이 확인되면 즉시 수혈을 중단하고 환자상태 평가 후 의사에게 알려 처방에 따른 적절한 조치를 취하고, [부록2.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "환자가 안정될 때까지 15분마다 혈압, 맥박 등 활력징후를 평가한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 3,
      "내용": "혈액은행 책임자는 발생한 수혈이상반응 종류와 건수를 혈액안전감시체계에 보고한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 3,
      "내용": "의료기관의 장은 특정 수혈부작용의 경우 혈액관리법에 따라 신고한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 2,
      "내용": "혈액제제 별 수혈지침",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "수혈부작용 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 1,
      "내용": "(참고)",
      "번호": "제5조",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 2,
      "내용": "수혈가이드라인 제5판 (보건복지부 국립장기조직혈액관리원, 대한수혈학회, 2022)",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 2,
      "내용": "한국혈액감시체계 운영규정(질병관리본부, 2018)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 2,
      "내용": "환자안전 주의경보 ‘잘못된 혈액형의 수혈 오류 발행’(의료기관평가인증원 환자안전본부, 2018.7.)",
