  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.6.1. 영상검사 결과 보고 – 영상의학과",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "정확하고 안전한 검사 결과를 적시에 제공하기 위해 영상의학과 영상검사 결과 보고체계 및 관련 의사소통 절차를 확립하여 적절한 진료 및 환자의 안전을 도모하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "PACS(Picture Archiving Communication System): 의료 영상을 디지털 형태로 저장, 전송, 진단하는 시스템",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "EMR: Electronic Medical Record",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "영상검사 결과보고",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "검사종류별 보고방법",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "검사 보고방법: 촬영한 영상에 대해 처방, 환자정보 및 검사 목적에 적합한지 확인하고 PACS 시스템으로 영상을 전송하여 판독이 되도록 지원한다. 판독이 완료되면 판독결과를 EMR로 전달하여 관련 의료진이 조회할 수 있도록 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "검사부서는 각각의 검사결과의 판독 및 보고에 대한 기준 범위(참고치)를 확립하며 세부지침은 부서별 업무규정에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "검사결과 보고시간(Turn-Around Time, TAT)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "검사결과 보고시간이란 검사 완료시부터 판독 완료시까지의 시간을 말한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "정규 판독: 외래환자 판독은 검사 완료 후 7일 이내 판독함을 원칙으로 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "응급 판독: 진료과에서 응급 판독 요청 시 24시간 이내 하는 것을 원칙으로 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "이상 검사결과 보고(Critical Value Report, CVR)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "보고 대상 및 기준: 영상의학과 검사 유형에 따라 이상검사결과 보고 기준을 확립하며, 세부지침은 [부록2. 영상의학과 CVR 지침]을 참고한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "이상검사결과 확인 시 보고 절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "검사결과에서 Critical Value가 확인되면 영상의학과 판독의사 또는 전문의가 담당 의료진에게 판독 결과를 문자 전송 또는 유선으로 알린다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "CVR 내용: 환자의 안전과 생명연장에 중요한 영향을 미칠 검사 및 시술의 결과를 포함한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "보고 확인: CVR 보고 후에는 EMR에 보고자, 보고 시간, 보고 내용, 수신자, 수신 번호, 수신 일시 및 판독결과 확인 시간이 기록된다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "보고된 검사결과가 변경될 경우 보고절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "동일검사 결과보고의 결론이 변경된 경우에는 의료진에게 문자 또는 유선으로 알린다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "유선으로 검사결과 보고 시, 세브란스병원 내규 [1.2.1. 구두/전화처방]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 2,
      "내용": "검사의 판독과 결과 보고에 필요한 경우 임상적 이유가 처방 또는 판독의뢰서에 포함된다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "결과보고소요시간(TAT)은 병원에서 정한 지침에 따르며, 세부적인 지침은 부서별 및 검사항목별로 정한다. TAT 결과를 모니터링하고 분기별로 보고하며, 이를 의료진간 공유한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 2,
      "내용": "영상의학과 TAT 지침",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 29,
