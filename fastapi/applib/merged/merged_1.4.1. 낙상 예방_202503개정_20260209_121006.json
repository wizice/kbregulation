      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 5,
      "내용": "‘Environment management’ 프로토콜을 이용하여 기본적인 낙상예방 간호중재를 실시하고 기록한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "낙상 예방 중재 활동",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "공통",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 5,
      "내용": "입원 시 모든 환자를 대상으로 ‘낙상 예방 지침’을 사용하여 환자 및 보호자에게 교육하고, ‘낙상주의’ 게시물을 침상에 부착한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 5,
      "내용": "보호자가 바뀔 경우 ‘낙상 예방 지침’ 내용을 인계하도록 교육한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 4,
      "내용": "병동",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 5,
      "내용": "병실 순회 시 낙상위험요인이 있는지 점검한다. (예: 보호자 유무, 침대난간 위치, 침대바퀴 고정상태 등)",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 5,
      "내용": "낙상 예방법에 대한 교육: 환자 및 보호자에게 낙상 예방법에 대한 교육을 시행한다. (예: 수면 전 화장실 다녀오기, 보호자 동반하여 거동하기, 낙상 예방을 위한 시설물 이용 방법, 미끄럽지 않은 신발 착용 등) 1.4.1. 낙상 예방",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 5,
      "내용": "필요 시 의학적, 약학적 중재를 실시한다. (예: 낙상 관련 의약품의 용량 또는 투여시간 조절 검토, 협의진료, 물리치료 시행 등)",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 5,
      "내용": "환경 및 시설을 관리한다. (예: 바닥 미끄럼, 조명, 환자주변 정리, 사이드레일 사용, 휠체어 고정 등)",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "중환자실",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 5,
      "내용": "침대에서 계속 움직이며 불안정한 모습을 보이는 환자는 필요 시 침대 난간사이에 낙상방지판을 끼운다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 5,
      "내용": "본인이 침대 높이를 조절하지 않도록 고정하는 것을 고려한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 5,
      "내용": "필요 시 의사의 처방에 따라 신체보호대를 적용한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 5,
      "내용": "필요 시 침대이탈 알람 등의 사용을 고려할 수 있다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 4,
      "내용": "소아 환아",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 5,
      "내용": "낙상 위험이 있는 소아는 혼자 두지 않고 반드시 보호자와 함께 있도록 한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 5,
      "내용": "침대위에 서서 옷을 갈아입거나 침대위에서 뛰지 않도록 한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 5,
      "내용": "유모차 이용시에는 환아에게 안전바와 안전벨트를 착용시키도록 한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 66,
      "레벨": 5,
      "내용": "환아가 복도에서 뛰어다니지 않도록 하고, 수액걸이(IV Pole)를 혼자 밀고 다니거나 그 위에 올라서서 타고 다니지 않도록 한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 67,
      "레벨": 4,
      "내용": "환자 이동/이송 시 낙상 예방 중재 활동",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 68,
      "레벨": 5,
      "내용": "보행이 가능한 환자 이송 시 보행속도에 맞춰 이동한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 69,
      "레벨": 5,
      "내용": "환자를 침대 또는 이송침대로 옮길 때에는 바퀴를 고정하고 침상 난간은 올린 상태에서 이동한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 70,
      "레벨": 5,
      "내용": "이송을 마친 후 침대나 휠체어, 유모차 바퀴는 고정하고 환자침대 높이는 최저로 낮춘다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 71,
      "레벨": 5,
      "내용": "이동/이송 시 IV Pole, 엘리베이터 턱, 보행기구 등에 발이 걸려 넘어지지 않도록 주의한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 72,
      "레벨": 2,
      "내용": "외래환자 및 가정간호 환자의 낙상위험 스크리닝 및 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 73,
      "레벨": 3,
      "내용": "낙상위험 스크리닝 대상: 모든 외래 및 가정간호 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 74,
      "레벨": 3,
      "내용": "낙상평가 방법: ‘외래초기평가’의 낙상 스크리닝 항목(12개월 이내 낙상 경험, 보조기 사용, 당일 진정제 사용(예정) 유무)을 이용하여 낙상위험요인 평가 시행",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 75,
      "레벨": 3,
      "내용": "낙상 고위험군: 낙상 스크리닝 항목 3개 중 1가지 이상 해당되는 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 76,
      "레벨": 3,
      "내용": "낙상 고위험군 환자의 낙상 예방 활동",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 77,
      "레벨": 4,
      "내용": "외래 환자는 ‘낙상주의’ 스티커를 이용하여 낙상 고위험 환자임을 의료진, 환자 및 보호자와 정보를 공유한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 78,
      "레벨": 4,
      "내용": "환자 및 보호자에게 ‘낙상예방’ 안내문을 제공하고 주의사항에 대해 교육한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 79,
      "레벨": 4,
      "내용": "외래 진료 구역마다 특성에 맞는 낙상 예방활동을 수행한다. [부록1. 낙상예방 관리지침] 참고",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 80,
      "레벨": 2,
      "내용": "낙상 발생 가능 검사실 및 치료실 환자의 낙상 예방활동",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 81,
      "레벨": 3,
      "내용": "진정 하 검사 또는 시술 시행, 검진대로 옮기거나 눕는 과정에서 몸의 위치가 변경되는 경우, 낙상 위험이 높은 기구 사용 등 낙상 발생 가능성이 높은 경우, 부서 특성에 맞는 1.4.1. 낙상 예방",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 82,
      "레벨": 2,
      "내용": "응급진료센터 환자의 낙상 예방활동",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 83,
      "레벨": 3,
      "내용": "응급진료센터 내원 시 모든 환자를 대상으로 낙상예방지침을 사용하여 환자 및 보호자에게 교육하고, ‘낙상주의’ 게시물을 침대에 부착한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 84,
      "레벨": 3,
      "내용": "보호자가 바뀔 경우에는 낙상예방지침 내용을 인계하도록 교육한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 85,
      "레벨": 3,
      "내용": "낙상위험평가 결과에 따른 낙상예방활동을 수행한다. (입원환자와 동일)",
