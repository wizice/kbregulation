      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "입실기준: 중환자실 설치 및 운영 목적에 따라, 신체생리적 상태의 악화로 집중 감시와 치료가 요구되는 환자로서 회복 가능성이 있는 고위험 급성 환자군을 대상으로 하며 기준은 아래와 같다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "심혈관계",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "성인",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 5,
      "내용": "급성 관동맥 증후군(심근경색, 불안정형 협심증), 심인성 쇼크, 심부정맥, 심부전 등과 같은 생명을 위협하는 심혈관계 장애",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 5,
      "내용": "맥박 40회/분 이하, 맥박 150회/분 이상, 수축기 혈압 80mmHg 이하 등 혈역학적 급성 변화로 집중 감시 및 약물 투여가 요구되는 환자",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 5,
      "내용": "심폐정지가 임박하여 심폐소생술이 예측되거나 심폐소생술로 회복되어 집중 감시가 필요한 환자",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "소아",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 5,
      "내용": "심인성 쇼크, 심부정맥, 심부전 등과 같은 생명을 위협하는 심혈관계 장애",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 5,
      "내용": "혈역학적으로 불안정하여(맥박 또는 수축기 혈압이 연령별 기준으로 10% 미만) 집중감시 및 약물 투여가 요구되는 환자",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 5,
      "내용": "심폐정지가 임박하여 심폐소생술이 예측되거나 심폐소생술로 회복되어 집중 감시가 필요한 환자",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "호흡기계",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "급성 호흡 부전증, 만성 호흡부전 환자, 기도폐쇄 환자",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "산소 투여 없이 동맥혈 검사상 PaO2 60mmHg 미만, PaCO2 50mmHg 초과, 산소 포화도가 90% 미만 등에 해당하거나 호흡부전으로 지속적인 감시 및 인공호흡기 치료가 필요한 환자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "신경계",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "신경계 질환이나 손상으로 신경학적 상태가 위중하여 집중적인 감시 및 치료가 필요한 환자",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "두부/뇌 또는 척추/척수 수술 또는 중재적 시술 전후 집중적인 감시, 치료 및/또는 인공호흡기 치료가 요구되는 환자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "신경계 질환이나 손상 환자로 내과적 또는 외과적 합병증이 발생하여 집중적인 감시, 치료 및/또는 인공호흡기 치료가 요구되는 환자",
      "번호": "(3)",
      "관련이미지": []
    },
    {
