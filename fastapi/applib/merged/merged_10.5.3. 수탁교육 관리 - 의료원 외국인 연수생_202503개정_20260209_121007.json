      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "연수 승인 및 등록 절차",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "해당 임상과 또는 부서에서 외국인(개인 또는 기관)의 연수 요청을 승인한 경우, 이를 제중원보건개발원 행정팀에 등록한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "연수 신청 서류 접수 및 안내",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "제중원보건개발원 행정팀은 외국인 연수생에게 비자 및 연수 관련 서류에 대해 안내하고, 다음의 서류를 접수한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "지원서",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "CV(Curriculum Vitae) 및 각종 증명서(여권사본, 졸업증명서, 재직증명서 등)",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "직종에 따른 자격사항 증빙서류(의사 면허증, 전문의 자격증 등)",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "연수 계획서",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "면역력 점검표(B형 간염, 홍역/풍진/볼거리, 수두 면역력 증빙 및 결핵, HIV 감염 여부",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "통장 잔고확인 증명서 등 경제력 입증 서류(필요한 경우)",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "추천서(임상과 요청 시 또는 제한적 의료행위 신청 연수생만)",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "기타 제한적 의료행위 승인 신청을 위한 필수서류",
      "번호": "(8)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "명찰 및 관련 증명서 발급",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "제중원보건개발원 행정팀은 접수 서류를 확인한 후, 해당 부서에 다음을 신청하고 연수생에게 배부한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "명찰(ID Card): 인사팀에서 발급",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "도서관 열람증(Medical Library Pass): 의학도서관에서 발급",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "수술실 통행증(Vein Recognition Pass for OR): 중앙관제실에서 발급(단, 연수 수행과에서 10.5.3. 수탁교육 관리 – 의료원 외국인 연수생",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "오리엔테이션 및 연수 진행",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "연수생은 병원 소개, 병원 생활 안내, 병원의 미션 및 비전, 환자의 권리와 책임, 개인정보 보호, 질 향상과 환자 안전, 감염 관리, 소방 안전 등을 포함한 오리엔테이션 자료를 안내받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "연수생은 병원 관계 규정에 대한 설명을 듣고, 연수 동의서에 이를 준수할 것임을 서명한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "외국 의사 연수 규정 및 관리",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "외국 의사 연수생은 단독으로 의료행위를 시행할 수 없으며, 반드시 보건복지부의 공식 승인 후 연수지도전문의 또는 연수협력전문의 지시 및 감독하에 제한적 의료행위를 시행한다. 단, 이는 세브란스병원장이 승인한 제한적 의료행위 자격신청 범위 내에 한한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "외국 의사 연수 관련 심의가 필요한 경우, 관련 [부록1. 의료원 외국인 연수 운영 규정] 및 고시를 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "준수 사항",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "연수생이 병원 관계 규정을 위반할 경우, 연수허가가 취소될 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "감염관리 서류가 미비하거나 결격사유가 있는 경우, 연수를 연기 또는 취소할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "연수생이 병원 장비 및 비품을 파손하거나 분실한 경우, 이를 변상하여야 한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "연수 종료 후 절차",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "제중원보건개발원 행정팀에서는 연수 종료 후 명찰을 반납 받아 폐기한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "기타 규정 준수",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "본 지침에 명시되지 않은 사항은 연세의료원 외국인 연수 운영 규정 및 의료법 제 27조 제1항 및 시행규칙 제18조 제2호의 규정에 따른 「외국인 의사·치과의사의 국내연수 중 제한적 의료행위 승인에 관한 고시」에 의거하여 처리한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "의료원 외국인 연수 운영 규정",
      "번호": "1.",
