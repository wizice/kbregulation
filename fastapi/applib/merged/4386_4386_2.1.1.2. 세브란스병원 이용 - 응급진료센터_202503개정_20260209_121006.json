  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "1.1.2. 세브란스병원 이용 - 응급진료센터",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "세브란스병원에 응급 진료를 위해 방문하는 환자의 표준화된 등록을 위해 응급환자의 등록에 대한 절차를 제공하고 준수하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "응급환자의 등록: 본원에 처음 내원하는 환자는 환자의 기본 정보를 수집하여 병원등록번호를 생성한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "응급진료 제공이 어려운 경우의 절차: 병원 내 자원의 부족이나 환자 전원요구 등 응급진료 제공이 어려운 경우 환자 중증도를 고려하여 외래진료 연계, 전원여부를 의사가 결정하며 필요 시 진료협력센터, 응급진료센터 전원코디네이터와 협의하여 결정한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "신원미상 환자에 대한 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "응급진료센터에 신원을 확인할 수 없는 환자가 내원한 경우, 무연고(독거)환자 표준 진료지침(Critical Pathway)에 의거하여 진행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "임시 이름(미상 등록 년월일 - 미상00000000)과 등록번호를 부여한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "신원미상 환자가 여러 명인 경우, 임시 이름 ‘미상A등록년월일, 미상B등록년월일, 미상C등록년월일…’로 구분한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "신원이 확인되면 즉시 수정된 이름과 등록번호를 다시 적용한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "환자에게 설명해 주어야 하는 정보",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "진료기록보존 및 개인정보 수집·이용 동의서, 일반 동의서에 대해 환자에게 설명하고 서명받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "응급의료관리료: 응급증상(중증도)에 따라 응급의료관리료가 다르게 적용되며, 외래 재진 경증환자의 경우 진료비 전액을 본인이 부담한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "환자유형에 따른 보험적용 여부, 요양급여 및 의료급여의뢰서 지참에 대해 설명한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "진료비 확인 방법에 대해 설명한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "환자 권리와 의무에 대하여 설명한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 1,
      "내용": "(참고)",
      "번호": "제5조",
      "관련이미지": []
    },
    {
      "seq": 21,
