  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "12.1.8. 전자의무기록의 복사기능 사용 JCI Standard 7th Edition: MOI.8 관 련 기 준",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "전자의무기록 작성 시 사용할 수 있는 복사 기능에 대한 사용 절차 및 지침을 제공함으로써 의무기록의 정확성 및 질을 향상시키고 환자 안전에 기여하고자 한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "복사: 다음 동의어 중 하나를 의미한다. 복사 및 붙여넣기(Copy & Paste), 재활용, 템플릿 저장 및 다른 기록으로 이동 등 작성된 내용을 재사용(활용) 하는 것",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "의무기록 작성자는 작성한 기록에 대해 책임을 가진다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "의무기록의 복사기능을 사용할 때에는 복사 내용이 붙여 넣는 기록의 시기와 내용 등에 적절한지 신중하게 확인, 수정하여야 한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "복사기능을 사용한 경우에는 복사기능을 이용하여 작성한 자가 정보의 정확성과 의학적 신뢰성에 대한 책임을 가진다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "의료진은 작성한 기록의 오류가 발생한 경우 오류를 수정할 책임을 가지며 의무기록 수정은",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "환자의 현재 상태를 반영하여 작성해야 하는 기록 및 항목은 복사기능을 사용하지 않는다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "과거병력 및 이전 경과, 검사결과는 복사를 허용하되 5항과 구분하여 기재하도록 한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "교육",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "의무기록을 작성하는 신규 직원은 복사기능 사용 절차 및 지침에 대해 교육을 받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "의무기록팀은 의무기록 작성자를 대상으로 의무기록 작성에 대한 교육을 정기적 또는 필요 시 수시로 시행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "관리",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "복사기능 사용 시 복사된 정보의 원작성자, 작성일자 등 출처 로그를 생성하고 복사된 정보의 이력 관리가 가능하여야 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "의무기록팀은 의료진이 복사기능 사용 절차를 준수하는지, 작성한 기록의 오류 및 문제가 없는지를 모니터링 하며 중요한 오류 건에 대해서는 의무기록위원회에 보고한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "의무기록위원회는 관련 정책을 위반하여 병원에 중대한 손실을 가져온 자에 대해서는 인사위원회 및 징계위원회에 회부할 권한을 가진다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 1,
      "내용": "(부록)",
