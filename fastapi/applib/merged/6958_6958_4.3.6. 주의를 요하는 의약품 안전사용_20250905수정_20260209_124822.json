    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "주의를 요하는 의약품 목록 선정, 관리 및 공유",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "주의를 요하는 의약품 목록은 약물관리위원회에서 의료기관 데이터를 기반으로 선정하여 관리한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "주의를 요하는 의약품 목록[부록1~4]은 약물관리위원회에서 연 1회 이상 검토한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "주의를 요하는 의약품 목록은 직원과 공유한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "신규 의약품 도입 시 기 사용 의약품과의 유사모양/유사발음 혼동 영향에 대해 고려한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "주의를 요하는 의약품 사용 및 보관",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "냉장보관이 필요한 의약품(개봉 전·후 의약품 포함)",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "의약품 보관 부서에서는 매일 자체적으로 약품냉장고의 온도(2~8℃)를 점검하고 기록한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "보관 온도가 유지되지 않을 때(정전 등), 아래의 사항에 따라 적절한 조치를 취한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 5,
      "내용": "일시적이고 원인이 파악된 단순 이상인 경우: 부서 내에서 자체적으로 해결한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 5,
      "내용": "이상 원인이 파악되지 않거나 고장인 경우: 즉시 파트장에게 보고하고 시설관리팀에 긴급방문을 요청한다. 온도유지가 불가능하다고 판단되는 경우 상급자의 지시에 따라 약품을 안전한 곳으로 이동시킨다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "실내경보 시스템이 구비되어 있는 냉장고의 경보 시 대처 및 확인 방법은 [부록2. 실내경보 시스템이 구비되어 있는 냉장고 관리지침]에 따라 적절한 조치를 취한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "다량의 약품이 보관되어 있는 설비의 경우 시설관리팀 또는 설비업체를 통해 정기점검을 실시한다. (예: 약무국 약품 보관 냉장고 – 월 1회 정기점검)",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "차광이 필요한 의약품",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "차광 유지 방법: 차광 보관 약품은 개봉한 후에도 원용기를 이용하거나, 불가능한 경우 차광 상태를 유지할 수 있는 장소나 차광 봉투 등을 이용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "유사모양/유사발음 의약품",
      "번호": "3)",
