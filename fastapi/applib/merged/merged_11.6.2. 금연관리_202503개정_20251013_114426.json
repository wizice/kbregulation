  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "6.2. 금연관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원시설 전체를 금연시설로 지정하고, 건물외부에 금연 예외구역을 지정하여 화재의 위험으로부터 환자를 보호하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "금연시설: 간접흡연의 폐해가 심각한 어린이, 청소년 환자의 건강권 보호를 위하여 건물전체를 금연시설로 지정한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "금연구역 지정 및 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "병원 내 방송실을 통하여 본 병원은 금연시설임을 안내 방송한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "병원 내 계단 및 옥외정원, 현관, 화장실에 금연시설 포스터를 부착한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "병원 내 옥외 금연구역 표지 부착 및 옥외 전자게시판을 통해 본 병원은 금연시설임을 고지한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "병원에서 배부하는 각종 안내문(입원수속안내문 등)과 리플렛에 본 병원이 금연시설임을 명시하고 교육한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "병원 내에서는 흡연에 관한 물품을 판매하지 않는다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "병원 내 건설 또는 보수 중인 모든 구역에서 흡연은 금지된다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "흡연실 설치 및 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "외부흡연실은 병원건물 외부에 위치하며, 흡연실임을 나타내는 표지판을 부착한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "외부에 흡연실을 설치하는 경우 환기가 가능하도록 하고, 해당 흡연실을 덮을 수 있는 지붕 및 바람막이 등을 설치할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "흡연자에 대한 조치",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "안내 및 보안업체는 순찰 시 건물로부터 10m이내에 흡연자가 발견되면 금연시설임을 안내하고 금연 예외구역으로 이동조치 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "의학적 또는 정신적인 이유로 주치의(담당교수)가 환자 흡연을 허용하는 경우 해당 환자는 병원건물 외부 흡연실에서 흡연하도록 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 1,
      "내용": "(참고)",
      "번호": "제5조",
      "관련이미지": []
