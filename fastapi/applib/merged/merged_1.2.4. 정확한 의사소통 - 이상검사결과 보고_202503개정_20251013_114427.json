      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "이상검사결과(CVR, Critical Value Report) 보고 대상과 범위는 검사실에서 시행되는 검사, 환자 침상(Bedside)으로 이동하여 시행되는 검사(POCT(Point-of-care-testing))를 포함하여 정한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "진단검사의학과의 이상검사결과 보고 대상 및 범위는 세브란스병원 내규 [2.3.2.1. 검체검사 결과 보고 – 진단검사의학과]를 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "병리과의 이상검사결과 보고 대상 및 범위는 세브란스병원 내규 [2.3.2.2. 검체검사 결과 보고 – 병리과]를 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "영상의학과의 이상검사결과 보고 대상 및 범위는 세브란스병원 내규 [2.3.6.1. 영상검사 결과 보고 – 영상의학과]를 따른다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "핵의학과의 이상검사결과 보고 대상 및 범위는 세브란스병원 내규 [2.3.6.2. 영상검사 결과 보고 – 핵의학과]를 따른다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "심초음파실의 이상검사결과 보고 대상 및 범위는 [부록1. 심초음파실 CVR 지침]을 따른다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "이상검사결과 확인 시 보고 절차 및 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "검사결과에서 이상검사결과가 확인되면 영상의학과·핵의학과·병리과 판독의사 또는 전문의, 진단검사의학과 임상병리사가 30분 이내 담당 의료진에게 문자 전송, 유선연락, 이메일 등으로 알린다. (단, 입원환자인 경우 병동 간호사에게 연락할 수 있으며, 병동 간호사는 담당의사에게 알린다.)",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "이상검사결과 보고 시 의사소통",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "환자이름과 등록번호 2가지 지표를 사용하여 환자를 정확히 확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "검사결과를 들은 자: 검사결과를 즉시 받아 적고(Memo), 검사결과를 알려준 자에게 기록한 내용을 되읽어준다.",
      "번호": "2)",
