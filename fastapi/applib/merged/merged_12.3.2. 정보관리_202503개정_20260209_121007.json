  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "12.3.2. 정보관리 4주기 의료기관인증기준: 12.3. 의료정보수집 및 활용 관 련 기 준 JCI Standard 7th Edition: MOI.1, 2, 2.1, 3, 6, 11, 13",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "의료정보의 수집, 저장, 처리 및 활용 과정에서 개인 정보 보호와 데이터 보안성을 유지하여 체계적인 HIS 관리 운영을 통해 의료서비스의 질 향상과 임상 연구 지원에 목적이 있다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "세브란스병원은 병원 내부와 외부에서 정보를 필요로 하는 자의 요청사항을 검토하여 환자 관련 정보 및 서비스를 제공한다. 구체적인 내용은 다음과 같다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "SR(Service Request) 수요제 접수 및 검토, 심의 위원회 개최",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "진료 관련 정보",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "교육 및 연구를 위한 진료정보",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "경영관리 정보",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "질 향상과 환자안전 지표 관련 정보",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "외부 정부기관 요청 정보",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "신기술 적용을 위한 Pilot System 등",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "자료와 정보는 다음의 방법으로 보호된다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "환자 의무기록 및 정보 접근권한은 세브란스병원 내규 [12.1.3. 의무기록/의료정보 접근권한]에 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "자료의 기밀성",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "업무수행을 위해 반드시 필요한 정보에 한하여 접근할 수 있다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "환자와 사무정보는 직접적인 의료제공자와 관리자에게만 용도에 따라 제한적으로 공개된다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "전산 보안 관리",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "권한이 있는 자만이 의무기록에 접근할 수 있다. 권한 부여 대상과 수준은 의무기록위원회에서 정한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "환자 의무기록 접근한 직원 목록은 저장된다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "EMR, OCS, 기타 전산시스템이 안전하고 안정적으로 운영되도록 관리한다. 이는 12.3.2. 정보관리",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "자료와 정보의 보안관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "의무기록팀 및 디지털헬스실은 시스템에 들어있는 자료를 감시하며, 또한 병원 밖으로 배포되는 자료의 정확성을 유지하기 위한 감시를 지속한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "의무기록팀 및 디지털헬스실은 모든 직원에게 정보에 접근하는 방법을 지도하고, 의사결정을 위한 자료의 사용이나 임상적 절차나 행정적 절차 향상을 위한 정보 활용에 있어서 정보를 수집하는 방법을 지원한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "의무기록, 자료와 정보의 보관 및 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "의무기록은 관련법에서 정한 기한대로 보관하며, 사용 목적에 따라 법률에서 권고하는 그 이상의 기간 동안 보관할 수 있다. 의무기록 보관 관리에 대한 사항은 세브란스병원 내규 [12.1.1. 의무기록/의료정보 관리]에 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "재정 관련 자료나 병원운영자료는 본원 규정에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "기록의 보존",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "기록은 전자의무기록시스템에 안전하게 저장되며 손상, 분실, 변조, 파기, 무권한 접근으로부터 세브란스병원 내규 [12.1.1. 의무기록/의료정보 관리]에 따라 보호된다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "정보관리 원칙의 교육",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "직원은 자신의 의무기록 및 정보 접근 권한 수준에 대해 확인하고 관련 교육을 받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "병원 관리자와 관련 교직원은 모든 보고체계에 있어서 질과 안전을 향상시키는 방향으로 정보를 사용하며, 이를 위하여 개인정보보호 관련 교육을 정기적으로 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 2,
      "내용": "기밀 유지와 보안 위반 시 원내 인사규정에 따른다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "정보기술관련 의사결정",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "의사, 간호사, 정보관리 직원 등으로 구성되는 의료정보위원회에서 논의하여 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "병원정보시스템 개발, 평가와 관련된 사항은 [부록1. 병원정보시스템 개발 및 운영 절차]에 따른다.",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "전산장애(코드화이트) 대응 절차",
      "번호": "9.",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "계획 하 혹은 불시의 전산장애 발생에 대한 대응 프로그램을 개발 및 유지관리하며 연 1회 이상 테스트한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "전산장애가 진료 및 서비스 모든 측면에 미칠 수 있는 영향을 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 3,
      "내용": "전산장애 기간 동안 안전한 진료제공을 위한 전략을 포함한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 3,
      "내용": "전산장애 복구전략 및 데이터 백업프로세스 운영을 파악하고 이행한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "직원은 전산장애 발생 대응 전략에 대해 교육을 받는다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 2,
      "내용": "병원정보시스템 개발 및 운영 절차 12.3.2. 정보관리",
