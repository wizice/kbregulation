  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.1.4.1. 영양관리 4주기 의료기관인증기준: 3.1.4 영양관리 관 련 기 준 JCI Standard 7th Edition: COP.5, 5.1, PCI.9",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자의 영양상태 및 질환, 치료 방법에 적합한 영양공급과 영양관리를 통해 치료효과를 높이기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "식사처방 지침: 식사의 특징, 영양기준량, 식품구성 등 입원환자의 식사처방지침",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "치료식 식단 작성 지침: 식사처방 지침에 제시된 영양기준 및 식품구성에 따른 식단작성방법, 허용식품, 제한식품, 조리법 등에 관한 지침",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "임상영양관리 지침: 입원환자의 영양 초기평가, 영양불량위험환자(고위험영양불량환자), 재평가 및 외래환자에 관한 영양관리 지침",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "식사처방은 [부록1. 식사처방 지침(요약)]에 따라 관리한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "식사처방 지침은 의료진 협의와 영양관리위원회의 인준을 거쳐서 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "의사는 환자상태, 치료계획, 영양상태에 따라 적합한 식사를 처방한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "제공되는 식사의 특징, 영양기준량, 식품구성 등의 내용을 포함한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "치료식 식단 작성은 [부록2. 치료식 식단 작성 지침]에 따라 관리한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "식사처방 지침에 근거하여 작성한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "식사처방 지침에 제시된 영양 기준 및 식품구성에 따른 식단 작성 방법, 허용식품, 제한식품 등의 내용을 포함한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "임상영양관리는 [부록3. 임상영양관리 지침(요약)]에 따른다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "임상영양관리 지침은 의료진 협의와 영양관리위원회의 인준을 거쳐서 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "영양사는 입원 24시간 이내에 영양 초기평가를 시행하고 그 결과를 의료진과 공유한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "영양 초기평가 결과 영양불량위험환자(고위험영양불량환자)에 대해서는 치료계획을 수립하여 적절한 영양관리를 제공하고 주기적으로 모니터링한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "[부록5. 치료식 설명 지침]에 근거하여 치료식을 제공받는 환자에게 치료식사명, 제공사유, 주의사항 등에 대해 설명하고 자료를 제공한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 2,
      "내용": "영양상담",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "필요 시 영양상담 및 교육을 제공하며, 환자의 객관적 자료평가(체질량지수(BMI), 체중변화 등), 식습관 조사, 영양상담과 관련된 치료계획, 영양상담 등의 내용을 포함한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "대상",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "협의진료, 개인교육, 집단교육으로 의뢰되는 모든 환자를 대상으로 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "방법",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "[부록4. 영양상담 지침]에 근거하여 영양상담 및 교육을 시행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "영양상담기록에는 객관적 자료평가(신체계측결과, 체중변화, 혈액검사 등), 식습관 조사, 영양상담과 관련된 치료계획, 영양상담 내용 등을 포함한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 2,
      "내용": "영양불량 위험환자 관리",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "영양초기평가 결과 영양불량 고위험환자는 객관적인 자료(BMI, 체중변화 등), 섭취량 변화 등을 통해 영양상태를 평가한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "영양요구량을 산정하고 영양관리계획 수립 및 시행, 모니터링 등을 시행하여 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 1,
      "내용": "(부록)",
