      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "집중치료가 필요한 환자에게 한정된 자원을 효율적으로 활용하여 적절한 의료서비스를 제공하기 위해 표준화된 장기이식병동 입퇴실 절차를 준수하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "장기이식병동(Transplantation Ward): 간, 신장, 췌장, 소장, 심장, 폐 등 고형장기이식을 위해 수술 전 준비 및 수술 후 관리를 할 수 있는 병동",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "입실기준",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "장기이식을 받기 위해 준비 중인 수혜자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "장기이식을 받은 후 수술 후 관리를 받고 있는 환자",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "면역억제제 치료를 받고 있는 환자로 집중관리 또는 격리가 필요하다고 주치의 (담당교수)가 판단한 환자",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "그 외 장기이식병동에 입원 관리가 필요하다고 주치의(담당교수)가 판단한 환자",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "입실 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "입실기준에 따라 주치의(담당교수)가 환자의 입실을 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "의료진은 입실 시 환자 및 보호자에게 입실 필요성을 설명하고 동의를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "입실 시점의 환자 상태를 평가하고 입실 기준에 부합하는지를 의무기록에 기록한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "퇴실 기준",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "장기이식을 받기 위해 입원한 수혜자인 경우, 장기이식이 불가피한 사유로 취소되어 이식 병동에 입원할 필요가 없는 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "장기이식을 받은 후 전신 상태의 호전으로 외래 치료가 가능하다고 주치의 (담당교수)가 판단한 경우",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "장기이식 후 면역억제제 치료를 받고 있는 환자가 입원의 사유가 되는 문제가 해결된 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "장기이식 후 면역억제제 치료를 받고 있는 환자가 타과적 질환의 치료를 위하여 해당과의 병동으로 전실이 필요한 경우 2.1.3.7. 입퇴실 절차 – 장기이식병동",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "기도삽관 또는 기계호흡 등의 집중치료가 예상되거나 필요한 경우는 중환자실 입실 기준에 준하여 중환자실로 전실함을 원칙으로 함.",
