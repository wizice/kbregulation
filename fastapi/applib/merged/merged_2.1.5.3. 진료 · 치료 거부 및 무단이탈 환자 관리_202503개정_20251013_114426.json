  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "1.5.3. 진료·치료 거부 및 무단이탈 환자 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "진료 및 치료를 거부 또는 중단하거나 의료진 소견에 반하여 떠나는 환자의 안전을 보장하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "환자 및 보호자가 진료/치료를 거부(중단)함을 의료진에게 알리는 경우 대처",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "환자 및 보호자의 진료/치료 거부(중단)에 대한 내용을 담당의사에게 알린다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "의료진은 환자 및 보호자가 진료/치료를 거부(중단)하는 이유를 알기 위해 노력하며 진료/치료의 거부(중단) 사유가 경제적 문제인 경우 사회사업팀에 협의진료를 의뢰한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "의료진은 진료/치료를 거부(중단)할 경우에 예상되는 결과 대안 및 결과에 대한 책임에 대해 환자 및 보호자에게 설명하고 기록한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "의료진 소견에 반하여 퇴원하는 환자 및 보호자는 자퇴서약서를 작성하고 세브란스병원 내규 [2.1.5.1. 퇴원]에 따라 퇴원한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "의료진은 추후 진료/치료가 연계될 수 있도록 환자 및 보호자에게 필요한 서류(소견서, 퇴원요약지 등)를 발부하고 환자상태에 따라 외래진료 또는 타병원 진료 등을 안내한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "환자 및 보호자가 진료/치료를 거부(중단)함을 의료진에게 알리지 않고 떠난 경우 대처",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "입원 및 응급진료센터 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "환자의 탈원 사실을 주치의(담당교수) 또는 담당의사(전공의)에게 알린다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "환자의 소재 확인이 되지 않는 경우 위치를 확인하기 위해 노력한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "해당 병동은 [부록3. 환자탈원보고서]를 작성하여 입원원무팀에 제출한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "입원원무팀은 환자탈원보고서를 병원장 결재를 득하고 진료비를 시료 또는 후불 처리한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "병동은 해당 환자를 퇴실 처리한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "미납된 진료비는 환자, 보호자, 보증인 등에게 청구하여 납부하도록 하고 최종 미납된 진료비는 보험심사팀 미수파트로 이관하여 관리한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "외래 환자",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "진료일에 내원하지 않는 환자에 대해서는 예약변경 안내 문자 서비스를 제공한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "항암약물요법, 방사선치료, 혈액투석 등 환자가 해당 일정에 방문하지 않은 경우 유선으로 연락하여 미방문 사유를 확인하고 위험성을 고지하고 기록한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "무단이탈 환자 발생 예방을 위한 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "무단이탈 예방을 위하여 환자 및 보호자에게 30분 이상 자리를 비울 경우 그 사실을 반드시 간호사에게 알리고 휴대폰을 지참하도록 교육한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "정기적으로 병실 라운딩을 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "환자 부재를 인지하면 즉시 병동 주변의 환자 위치를 파악하고 환자 및 보호자에게 연락을 취한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "무단이탈 환자 발생 시 대처",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "병동 주변의 환자 위치 파악이 안되는 경우 바로 원내 방송 요청, 보안팀 연락, 부서장과 주치의(담당교수) 또는 담당의사(전공의)에게 알린다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "간호사는 필요시 보호자에게 환자 식별을 위한 자료를 요청하고 [부록2. 초상권 사용 동의서]를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "보호자 부재 시에는 유선 연락하여 환자 식별을 위한 자료를 요청하며 초상권 사용 동의서는 팩스, 이메일, SNS, 녹음 등의 방법으로 작성한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "유선으로 초상권 사용 동의서를 취득할 때는 보호자의 신분을 확인(이름, 생년월일, 주소, 연락처) 하고, 사진 제공에 대한 동의를 받는 내용을 녹음하고 보관한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "보호자에게 가족 중 1명은 자택에 대기하도록 교육한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "보안팀에게 환자 인상 착의와 환자를 식별할 수 있는 자료를 제공한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "보안팀은 원내 및 원외 주변의 환자 위치 파악을 위해 비상연락망을 가동하여 각 단위 보안팀, 승강기감시실, 주차관제실, 사무팀, 경영지원팀에 지원을 요청하고 환자 이동 경로에 대하여 정확한 환자 식별을 위해 보호자와 함께 CCTV를 확인한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "보호자가 부재 상태인 경우에는 간호사가 CCTV 화면의 환자 식별에 도움을 준다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "환자 부재 인지 후 1시간이 지나도 환자를 찾지 못하면 보호자에게 경찰에 신고해야 함을 알리고 보호자가 경찰에 신고하도록 한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "보호자 부재 또는 보호자가 신고를 거부하는 경우에는 의료진이 신고한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "관할 경찰과 연계하여 최대한 협조한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "해당 병동은 다음의 절차를 진행한다.",
      "번호": "10)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "미귀원에 대한 진행 과정을 기록",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "환자안전사건보고",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "[부록3. 환자탈원보고서] 작성 및 입원원무팀에 제출",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 2,
      "내용": "법정감염병 신고 대상인 경우 세브란스병원 내규 [8.8.1. 감염성질환 관리]에 따라 보고한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 2,
      "내용": "본인 및 타인에게 해를 줄 수 있다고 고려되는 환자는 필요 시 공공기관에 신고한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
