    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "화재 시 신고체계",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "신고, 전파: 화재 상황의 유무를 정확히 판단하고, 화재 시 “불이야”라고 외친 후, 가까운 위치의 직원들에게 신속·정확하게 알린다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "즉시 화재발신기의 비상벨을 힘껏 누르고, 화재발생 층 및 위치를 원내 119번으로 명확하게 신고한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "소화",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "최초 발견자가 1차, 화재발생 주변 근무자가 2차로 소화기를 이용하여 소화 실시",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "소화기 사용방법: 안전핀 제거 후 노즐(호스 끝)을 화점의 바닥 방향으로 비를 쓸듯이 방사한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 4,
      "내용": "소화전 사용방법: 옥내소화전을 열고 소방호스와 방사 관창을 꺼내 화재발생 장소로 이동하고, 다른 사람의 밸브 개방(시계 반대방향)에 따라 화점에 방사 관창을 조절하면서 방사한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 3,
      "내용": "피난층 위치, 안전구획 위치, 피난시설 위치 및 피난경로",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 4,
      "내용": "대피·피난: 직원은 화재상황 발생 시 환자(내원객)의 대피를 우선으로 하고, 소화기를 이용한 1, 2차 소화 실패 시, 화재발생 반대편으로 피난을 유도한다. 단, 즉시 피난이 어려운 경우(검사, 시술 중의 환자 등) 피난 유무 및 피난 시점을 소방책임자의 판단 하에 결정하여 행동한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "피난층의 위치: 피난층은 직접 지상으로 통하는 출입구가 있는 층으로 직원들은 위치를 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "피난경로 및 화재대피순서",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 5,
      "내용": "건물 내 피난 시 이용되는 안전구획의 위치는 안전도에 따르며, 일반적인 피난경로는 [병실 ⇒ 복도(1차) ⇒ 방화구획 통과한 복도(2차) ⇒ 비상계단(3차) ⇒ 안전지대(피난층)] 이다",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 5,
      "내용": "1차 화재대피: 전층 수평방향의 피난경로로 중앙계단 혹은 비상계단 방향에 위치",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 5,
      "내용": "2차 화재대피: 화재 발생층 및 직상층, 직하층 총 3개층 우선 수직방향의 피난경로로 중앙계단 혹은 비상계단 방향에 위치",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 5,
      "내용": "3차 화재대피: 전층 수직방향의 피난경로로 중앙계단 혹은 비상계단 방향에 위치",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "환자(보호자)의 대처요령 안내",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 4,
      "내용": "게시판, 입원생활 안내문, 병실 출입구 비상대피안내도 등을 통해 상시 확인한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "화재 시 환자 및 보호자는 안전하고 신속한 대피를 위해 병동 내 소방책임자의 지시에 따라 대피한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 3,
      "내용": "직원 업무분담, 환자 및 직원 등의 대피장소 배치",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 4,
      "내용": "각 부서별로 자위소방대의 업무(경보반, 소화반, 대피유도반)를 편성하고, 각자의 임무를 수행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 4,
      "내용": "환자 및 직원 등은 각 건물별 피난층을 통해 안전지대로 대피한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 3,
      "내용": "환자유형별 대피 계획 및 환자후송",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 4,
      "내용": "환자가 중환자임을 감안하여 대피 중 신중을 기하여 대피토록 하여야 하며, 환자 대피 중대원은 화재층에 투입하여 대피 활동을 지원한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 4,
      "내용": "입원한 환자 중에 경환자(활동이 가능한 환자)는 통제요원의 지시에 따라 침착하게 대피하고, 중환자(활동이 불가능한 환자)는 통제요원의 부축을 받아 이동하거나 고위험군 중증환자 피난경로에 따라 대피한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 4,
      "내용": "대피장비로는 들 것, 매트리스, 침대, 시트커버 등을 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 4,
      "내용": "대피 우선순위는 중증도가 낮은 경증환자부터 이송하며, 중증도가 높은 고위험군 환자 순서로 이송한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 66,
      "레벨": 3,
      "내용": "모든 구성원이 숙지할 수 있도록 [소방계획서]에 포함하여 제작 및 배부한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 67,
      "레벨": 2,
      "내용": "화재안전관리 책임영역",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 68,
      "레벨": 3,
      "내용": "총책임자: 시설안전관리위원장",
