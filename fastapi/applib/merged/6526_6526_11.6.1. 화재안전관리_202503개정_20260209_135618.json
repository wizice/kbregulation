      "관련이미지": []
    },
    {
      "seq": 69,
      "레벨": 3,
      "내용": "총괄부서: 시설관리팀",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 70,
      "레벨": 3,
      "내용": "소방안전관리자: 전반적인 화재안전관리 사항을 담당",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 71,
      "레벨": 3,
      "내용": "소방안전관리보조자: 소방안전관리자의 업무를 보조적으로 수행",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 72,
      "레벨": 3,
      "내용": "소방책임자: 각 부서의 팀장, 파트장, 주임교수 등",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 73,
      "레벨": 4,
      "내용": "시설물 유지관리 및 청결을 철저히 하여 가연성물질이 방치되지 않도록 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 74,
      "레벨": 4,
      "내용": "허가된 전열기구만을 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 75,
      "레벨": 4,
      "내용": "인화성 및 발화성물질 등 위험물질의 무단 사용 또는 반입을 금하며, 지급하지 않은 전열기구 및 가스기구 등 비인가 제품의 사용을 제한한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 76,
      "레벨": 4,
      "내용": "화재 시 자위소방대를 통하여 중증도 분류에 따라 환자대피를 지시한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 77,
      "레벨": 2,
      "내용": "화재안전관리 프로그램",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 78,
      "레벨": 3,
      "내용": "화재 안전점검, 시험 및 유지보수에 관한 화재안전프로그램은 문서로 기록한다.",
