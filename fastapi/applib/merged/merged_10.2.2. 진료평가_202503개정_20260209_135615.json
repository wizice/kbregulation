  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "10.2.2. 진료평가 4주기 의료기관인증기준: 10.2 의사(전문의)의 진료권한 승인과 평가 관 련 기 준 JCI Standard 7th Edition: SQE. 11",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "임상학 교원, 진료교수, 임상강사가 제공하는 환자 진료의 질과 안전을 평가하기 위해 임상성과에 대해 평가하고, 임상권한을 부여받은 의사(전문의)의 진료를 지속적으로 모니터링하기 위한 체계를 마련하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "대상: 임상학 교원, 진료교수, 임상강사",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "임상학 교원, 진료교수, 임상강사의 환자 진료의 질과 안전성을 평가, 향상시키기 위해 매년 전문성 향상(Professional Growth), 행동(Behavior), 임상결과(Clinical Result) 영역에 대한 진료평가를 시행한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "임상학 교원",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "해당 부서장(내과/외과부장 또는 임상과장)은 매년 피평가자의 전문성 향상, 행동 영역뿐 아니라 전체, 과별, 개별 등 진료의 질과 환자안전에 영향을 미치는 전문적 행위의 경향을 파악할 수 있는 항목으로 선정된 평가지표를 활용하여 진료 전반의 적절성을 평가한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "진료교수 및 임상강사",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "임상과장은 매년 대상자의 교육수준, 수련경력 등을 고려하여 전문성 향상 및 행동 영역 등에 대해 평가한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "자격신임위원회에서 진료평가 결과를 검토하고 자격신임위원장이 승인한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "병원장은 진료평가 결과를 검토하고 최종 승인한다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "진료평가 결과가 부적절한 경우 자격신임위원회에서 논의되며, 진료평가 결과는 재임용과 임상권한의 승인, 갱신, 추가 및 제한 시 심의자료로 사용된다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "진료평가 결과가 환자 또는 직원의 안전에 영향을 미친다고 판단된 경우, 자격신임위원회는 그 결과를 해당 부서장 및 피평가자에게 알리고 재발방지 및 개선을 요청한다. 재발 10.2.2. 진료평가",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "진료평가 결과는 경영진에게 보고되고 임상권한에 반영되며, 각 피평가자의 개인 임상권한과 함께 자격신임담당부서에서 관리한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "진료평가와 관련된 모든 기록은 진료평가 이외의 다른 목적으로 사용될 수 없으며 관리된다. 단, 진료평가 관련 기록은 자격신임위원회의 승인 및 심의 시 열람하거나 공개될 수 있다.",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
