  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.3.5.1. 영상검사 검사과정 관리 4주기 의료기관인증기준: 2.3.5 영상검사 검사과정 관리 관 련 기 준 JCI Standard 7th Edition: AOP.5.1, 5.4, 5.5, 5.9.1, 6~6.6",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원에서 이루어지는 영상검사 서비스가 환자에게 안전하고 정확하게 이루어지도록 통합관리 지침을 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "영상검사 시행 및 판독",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "영상검사 시행자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "자격 및 면허: 영상검사 자격요건을 갖춘 영상의학과, 핵의학과 의사 및 방사선사",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "교육: 자격 및 면허 유지를 위한 연간 법정보수교육 이수자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "영상검사 결과 판독자",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "자격 및 면허: 직무기술서 또는 임상권한에 판독 권한을 가진 영상의학과 의사, 핵의학 의사",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "교육: 자격 및 면허 유지를 위한 연간 법정보수교육 이수자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "응급환자를 위한 상시 영상검사 제공 방법",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "영상의학과는 응급환자 및 원활한 진료지원을 위해 24시간 운영하며, 정상근무시간 외 필요시 On-Call System을 운영한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "영상검사 전 준비사항",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "검사와 관련된 전처치 시행 여부를 포함하여 환자의 준비, 가임여성의 임신여부, 인공제세동기 및 심박동기 사용, 섭취금기 식이, 의약품 복용(항응고제, 항혈전제, 메포민",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "정확한 검사결과가 보장되도록 검사 지침서 및 매뉴얼에 따라 영상 검사를 시행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "정확한 영상검사를 위한 절차 2.3.5.1. 영상검사 검사과정 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "세브란스병원 내규 [1.1.1. 정확한 환자 확인]에 따라 환자를 확인하고, 조영제를 사용하는 검사에 대해 동의서를 확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "검사와 관련된 전처치 여부를 확인한 후 환자 및 보호자에게 검사 관련 주의사항을 설명한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "u-Severance에서 검사 요청일 및 검사의뢰 목적을 확인하고 의뢰된 검사에 대해 특별한 요구사항이 있는지 확인한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "검사에 필요한 검사방법은 검사 지침서 및 매뉴얼을 기준으로 하며, 그 외 특별한 사항은 의사와 협의하여 시행한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "판독결과의 신뢰성을 유지하기 위해 정도관리, 장비 예방점검, 판독용 모니터 점검 등을 주기적으로 실시하고, 이상치 발생 시 해당 정보를 이용하여 검사의 질 관리 및 조치를 취한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "정도관리",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "내부정도관리: 부서 자체 또는 기술부서(의공기술팀)의 예방점검 및 장비유지보수 계약업체 등과 함께 정도관리를 시행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "주기: 장비별 특성 및 검사항목에 맞는 주기에 따라 정도관리 주기를 결정하여 실시하고, 장비의 예방점검은 년 1회 실시한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "결과치 보관: 정도관리 관련 보고서는 문서(종이 또는 전자)로 보관한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "결과 이상치 발견 시 조치 및 보고체계",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 5,
      "내용": "정도관리 결과 허용범위를 초과하거나 이상치 발견 시 부서장에게 알리고 필요한 추가 정비를 실시한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 5,
      "내용": "영상 이상으로 환자에게 추가검사가 필요하거나 검사 시행이 불가능할 경우 부서장에게 보고한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "내부정도관리는 영상의학과 의료영상장비 관리 지침에 따라 시행한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "외부 정도관리",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "관련 법령이 정하는 바에 따라 진단용 방사선 발생장치 정기검사는 매 3년, 특수의료장비 품질관리검사는 매년 외부 검사기관에 의뢰하여 검사한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 2,
      "내용": "영상검사는 세브란스병원의 판독 상황에 따라 외부기관으로 판독의뢰를 할 수 있으며, 세부내용은 [부록1. 영상의학과 업무규정]에 따른다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "핵의학과 핵의학 검사는 [부록2. 핵의학과 업무규정 및 지침서]에 따른다.",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 2,
      "내용": "영상의학과, 핵의학과의 모든 진단적 검사의 운영과 관련된 사항, 검사 및 질 관리를 위한 제반 사항의 지침은 통합검사위원회에서 관리한다.",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "영상의학과 업무규정",
      "번호": "1.",
      "관련이미지": []
    },
    {
