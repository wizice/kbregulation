  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.1. 의약품 선정 및 공급",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "세브란스병원의 사명, 의료서비스 영역 및 환자 증상에 따라 적시에 의약품을 제공하기 위해 안전성, 경제성 등을 고려하여 의약품을 적절하게 선정하고 관리, 공급하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "신규 의약품 선정 절차",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "신규 의약품 신청 자격: 의사(또는 치과의사) 면허를 가진 부교수 이상의 교수가 약사위원회에 신청할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "심의 및 승인: 약사위원회",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "심의내용: 심의과정, 적응증, 안전성 및 유효성, 경제성, 소모부진 의약품 등의 기준을 고려",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "신규 의약품 모니터링",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "신규 의약품이 도입된 후 해당 의약품의 사용 현황, 부작용을 모니터링하는 프로세스는 다음과 같다. (단, 제형 및 용량 추가 의약품, 기존 사용 의약품과 동일 성분 의약품은 예외로 한다.)",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "신규 의약품 신청 의사는 해당 의약품의 용량, 용법, 적응증이 포함된 처방 현황 및 의약품부작용을 모니터링하여 의약품부작용감시위원회에 제출한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "의약품부작용감시위원회는 신규 의약품 모니터링 내용에 대하여 효능, 효과 및 부작용 등에 관하여 심의하여 평가한 후 그 내용을 약사위원회에 보고한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "약물관리위원회는 신규 도입 의약품에 대해 안전성과 유효성 정보를 기반으로 연 1회 검토하여 그 내용을 약사위원회에 보고한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "의약품 정보제공",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "신약정보 및 최신 의약품정보를 갱신하여 관련 직원에게 제공한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "세브란스병원 의약품집은 약품 정보 소프트웨어(DIF, Drug Information Framework)로 제공하고, 월 1회 정기적으로 업데이트하고 필요 시 수시로 업데이트한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "의약품 목록 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "의약품 목록은 세브란스병원에서 처방 가능한 의약품이다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "의약품 목록 추가 및 삭제는 약사위원회의 결정에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "약사위원회는 의약품 목록을 유지 및 모니터링하며, 연 1회 안전성과 유효성에 기반하여 의약품 목록에 대하여 검토한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "약무국은 소모부진 의약품 목록을 연 1회 이상 검토하여 약사위원회에 보고하고, 약사위원회는 이를 심의하여 사용 여부를 최종 결정한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "의약품 목록은 관련 직원이 그룹웨어 게시판에서 확인할 수 있다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "의약품 목록 추가 또는 삭제가 있는 경우 관련 직원에게 공지한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 2,
      "내용": "의약품 공급",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "재고가 없는 경우: 원내 사용 중인 의약품이 품절, 생산(수입) 중단 등의 사유로 공급이 되지 않는 경우 다음 절차에 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "약품 수급 문제가 예견되는 경우에는 처방 임상과에 통보하고 대체 의약품을 제시하며, 관련 의료진에게 공지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "정상적인 재고관리에도 불구하고 예상되지 않는 이유로 의약품의 재고가 부족한 경우에는 처방의에게 통보하고 대체 가능한 의약품을 제시하며, 관련 의료진에게 공지한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "원내 사용 가능한 대체 의약품이 없는 경우에는 병원장 승인을 받아 대체 의약품을 구매할 수 있다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "필요한 의약품 확보 절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "원내에서 취급하지 않는 의약품이 필요한 상황에는 의사가 해당 임상과장의 승인을 받아 긴급구매 요청을 하며, 약사위원장을 경유하여 병원장의 승인을 득한 후 사용할 수 있다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "일상적인 공급이 불가능한 상황(토/일요일, 공휴일, 야간 등에 약품 공급이 중단되는 상황 등)이 발생할 경우에는 약무국 관리자에게 보고하고, 절차에 따라 원내에 차질 없이 의약품을 공급할 수 있도록 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "약무국은 원내 원활하고 안정적인 의약품 공급을 위해 토/일요일, 공휴일, 야간을 포함하여 상시적으로 24시간 약국을 운영한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
