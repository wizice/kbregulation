    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "진료의 연속성을 유지하기 위해 회송(전원) 및 의뢰 결정과정에 환자가 참여하며 적절한 절차를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "회송(전원, Inter Hospital Transfer): 외래 및 입원환자 중 연속적, 후속적인 진료가 요구되어 타 병원으로 회송(전원)의뢰 및 이송되는 일련의 과정",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "환자 참여: 환자 및 보호자가 회송(전원)과 회송(전원)과정에서의 정보제공에 동의하면 회송(전원)병원 선정 및 회송(전원)병원 승인을 위한 진료정보 제공 절차를 진행하며, 이 과정에서 환자 및 보호자를 참여시킨다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "회송(전원) 하는 경우",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "병동/중환자실/응급진료센터 등 병상이 부족한 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "병원에서 제공하지 못하는 특별한 서비스가 요구되는 경우(격리실, 중환자실, 분만실 외)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "완화의료서비스가 요구되는 경우",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "급성기 진료가 종료되고, 연속적인 치료가 요구되어 장기 요양이 필요한 경우",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "급성기 진료가 종료되고, 후속적인 관리를 위해 병·의원으로 의뢰하는 경우",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "환자 또는 대리인이 요청한 경우",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "기타 회송(전원)이 요구되는 경우 등",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "회송(전원) 전 의료기관 선정 및 준비",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "의사는 환자 회송(전원)을 결정하고 환자 및 보호자에게 회송(전원)에 대해 설명하고 동의를 구한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "환자의 진료 연속성 요구와 일치하는 회송(전원)기관(완화의료전문기관 포함)을 선정한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "회송(전원)기관의 수용능력을 확인한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "이송수단",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "입원 환자의 회송(전원) 시 적합한 이송수단을 확인하고 이송에 필요한 교통수단(구급차, 항공 등)에 관한 정보를 제공한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "비행기 이송이 필요한 경우, 가능한 항공사 담당부서와 병약승객항공운송에 관한 절차를 연계한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "의사 또는 응급구조사 동승이 필요한 이송의 경우, 본원 구급차 또는 위탁업체 구급차를 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "의료진 동반의 필요성",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "의료진 동반 필요성을 확인하기 위한 회송(전원)환자 분류는 [부록1. 세브란스병원 중환자 이송체계(STARS)]에 따른다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 5,
      "내용": "Class I: 현재 환자의 상태가 불안정하며 이송 중 악화가능성이 높은 환자",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 5,
      "내용": "Class II: 이송 중 악화가능성이 있고 지속적 약물 투입 또는 환자감시가 필요한 환자",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 5,
      "내용": "Class III: 이송 중 악화가능성이 낮은 환자",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "Class I, II에 해당하는 경우 의사 또는 응급구조사가 동행한다. ClassIII에 해당하는 환자는 필요 시 응급구조사가 동행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "동행 시 회송(전원) 중 환자의 상태를 점검하며 필요 시 적절한 조치를 취하고 기록한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "회송(전원) 시 정보제공",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "해당 회송(전원)기관에서 환자 회송(전원)을 승인하면 회송(전원) 시 상태와 치료에 대한 정보, 회송(전원) 사유 등이 기재된 자료(의뢰서 또는 회송서, 환자용 퇴원요약, 의무기록, 영상복사 등)를 첨부하여 회송(전원)기관에 제공한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "회송(전원) 사유, 회송(전원)기관 정보, 이송방법 등을 해당 환자 의무기록에 기록한다.",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 2,
      "내용": "의사는 입원환자의 회송(전원) 및 이송과정에 책임이 있으며, 회송(전원) 후에는 회송(전원)기관과 의료진에게 책임이 이관된다. 회송(전원)받는 병원 소속 의료진이 본원에 와서 환자를 인계받는 경우, 인계 이후 환자 관리 책임은 해당 타 병원으로 이관된다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "타 병원으로 회송(전원)이 불가능한 경우에는 가정전문간호사실 협의진료 의뢰를 고려한다.",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 2,
      "내용": "환자가 타 병원에서 본원으로 의뢰되는 경우 진료정보회신 동의서를 작성한 환자에 한하여 해당 병원으로 진료결과를 회신한다.",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "환자 진료의 연속성을 유지하기 위해 회송(전원)기관과 지속적인 협력 관계를 유지한다.",
      "번호": "9.",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "협력병원(기관) 운영",
      "번호": "10.",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 3,
      "내용": "협력병원(기관)은 특별한 이해관계 없이 진료협력 협약을 체결한 후 진료의뢰, 회송(전원) 및 행정 협력을 위한 진료협력 네트워크를 의미한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 3,
      "내용": "협력병원(기관) 관련 업무는 진료협력센터(SHRC, Severance Hospital Referral Center)에서 주관한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 3,
      "내용": "협력병원(기관) 선정 시 병상수, 진료과목, 전문서비스 및 시설 등을 고려하여 진료협력위원회에서 검토 후 병원장이 결정한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 3,
      "내용": "진료협력 협약 체결 요청 시 '세브란스병원 협력병원(기관) 체결 심의 자료 조사표'를 작성하고 필요한 서류를 구비하여 제출한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "협약기간은 협약을 체결한 날로부터 2년이며 재협약을 체결할 수 있다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 3,
      "내용": "재협약 체결 시 진료협력 실적에 대한 해당 병원의 의견 및 재협약 체결 신청서 등을 제출한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 3,
      "내용": "재협약 기간 동안 진료협력 실적 등을 검토하여 진료협력위원회의 심의를 거쳐 협약을 종결할 수 있다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 3,
      "내용": "협약서의 내용은 진료협력위원회의 심의를 거쳐 병원장이 최종 결정한다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 3,
      "내용": "협력병원(기관) 협약서에 상호 대표자가 날인함으로써 협약을 체결한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "체결 후, 협력병원(기관)에 대한 진료의뢰, 회송(전원), 행정협력에 대한 평가 등을 실시한다.",
      "번호": "10)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "상호간의 진료활동 교류, 정보 교류, 업무상의 협력, 협력병원의 지정표시 등에 관하여 협력한다.",
      "번호": "11)",
