  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "10.7.2. 직무상 재해 관리 4주기 의료기관인증기준: 10.7 직원안전 관리활동 관 련 기 준 JCI Standard 7th Edition: SQE.8.2",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "업무와 관련된 직원의 안전사고를 예방하고, 안전사고 발생 시 대처방법, 처리절차, 추후관리 등에 대한 세부 관리 지침을 규정하여 직원의 건강을 유지, 증진시키기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "직원 안전사고: 위험이 발생할 수 있는 장소에서 안전 교육의 미비, 안전수칙 위반 또는 부주의 등으로 작업과정, 작업기계, 작업환경과 관련하여 인명 피해 또는 재산상 피해를 주는 사고",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "직원 안전사고의 유형",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "직원 안전사고의 유형은 산업재해보상보험법에 적용되는 재해 유형으로 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "재해 유형: 떨어짐, 넘어짐, 부딪힘, 끼임, 깔림·뒤집힘, 물체에 맞음, 무너짐, 절단·베임·찔림, 화재, 폭발·파열, 감전, 교통사고 등",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "직원 안전사고 예방활동",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "순회점검: 노동조합 노동안전국장, 명예산업안전감독관, 안전관리자, 보건관리자로 구성된 안전보건업무 관계자는 월 1회 현장 순회점검을 통하여 유해·위험요인을 파악하고 개선한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "안전보건관리위원회 회의 개최: 산업안전보건법 제24조에 의거 매 분기마다 회의를 개최하여 직원의 안전과 보건을 유지·중진 시키기 위하여 필요한 사항을 이행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "직원 감염노출예방을 위한 지침 및 활동은 [감염관리지침] V.3. 감염성 질환 노출 시 관리에 따른다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "직원 안전사고 발생 시 보고체계",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "안전사고 보고체계",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "보고 대상: 업무 중, 출퇴근 과정 등 직무와 관련된 부상 및 질병이 발생된 교직원",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "보고받는 부서 및 담당자: 사고 발생 시 소속 부서장 및 안전보건팀( 87801)에 신고",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "보고 내용: 직원명, 발생일자, 발생장소 등의 경위사항을 원내 재해발생 신고서에 기재하여 서면 보고한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "감염 노출 시 보고체계",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "보고 대상: 혈액매개감염원 노출(주사침 자상 등), 공기매개감염원 노출(활동성 폐결핵 등), 비말감염원에 노출(대유행중인 호흡기질환 등), 접촉감염원에 노출(옴 등)",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "보고받는 부서 및 담당자: 부서장 및 감염관리실에 신고",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "보고 내용: 직원명, 노출날짜, 노출장소, 노출경로, 노출대상(환자, 주사침, 혈액, 물품",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "직원 안전사고 발생 시 치료 및 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "안전사고 치료 및 관리절차",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "업무와 관계되는 건설물·설비·원재료·가스·증기·분진 등에 의하거나 작업 또는 그 밖의(직원감염노출 외) 업무로 인하여 부상하거나 질병에 걸리는 경우 필요한 응급처치 및 치료를 실시하고 무과실 책임주의의 원칙하에 산업재해보상보험법 및 사립학교연금법에 따라 실손처리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "개인의 질병요양과 관련하여 근로자가 원하거나, 보건관리자가 필요하다고 판단되는 근로자인 경우 보건관리자는 상담 및 사후관리를 시행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "직원 안전사고 발생 시 치료 및 관리절차는 [부록1. 직무상 재해 접수, 처리 및 추후관리 과정]에 따른다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "보건관리자는 직무상 재해에 관한 통계의 유지·관리·분석을 위해 데이터 관리를 한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "안전보건실무소위원회는 직무상 재해의 원인 및 경과에 대한 데이터를 분석 및 관리하고, 그 결과를 관련부서와 공유하며, 시설안전관리위원회에 정기적으로 보고한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "직원 감염 노출 시 치료 및 관리절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "직원 감염 노출 시 처치, 진단검사 및 추적검사, 예방적 투약, 감염원에 따른 근무제한 조치 등의 관리절차는 [감염관리지침] V.3. 감염성 질환 노출 시 관리 및 [부록1. 직무상 재해 접수, 처리 및 추후관리 과정]에 따른다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "감염관리실은 감염 관련 직무상 재해를 입은 직원의 상태 악화 및 유지, 호전 여부 등 경과를 확인하고 이에 대한 데이터를 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "직원 안전사고 처리결과 경영진 보고",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "직원 감염노출(주사침 자상 포함)을 포함한 안전사고 발생현황을 연 1회 이상 해당부서, 관련위원회, 세브란스병원장에게 보고하며 원인을 분석하여 개선활동을 수행한다",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "직원 감염노출(주사침 자상 포함) 자료는 분기별 해당부서와 안전보건실무소위원회에 공유하고, 세브란스병원장에게 보고한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "직원 안전사고의 원인 조사 및 분석, 동종 사고 재발방지를 위한 개선활동을 안전보건관리위원회에 보고한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "직원 안전사고 처리결과를 경영진에게 보고한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
