  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "1.6.1. 외국인 진료",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "외국인 환자의 물리적, 언어적, 문화적 장애요인을 감소시켜 병원에서 적절한 의료서비스를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "외국인 환자는 세브란스병원 홈페이지, 지역사회에 배포된 안내 책자, 예약센터(☎1599-1004)를 통해 세브란스병원과 국제진료센터에 대한 정보를 제공받을 수 있다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "외국인 환자 진료를 위해 필요 시 국제진료센터에 도움을 요청하여 지원을 받거나 무료 전화통역 서비스인 BBB (Before Babel Brigade)을 이용한다(BBB번호 1588-5644).",
      "번호": "1004)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "국제진료센터의 운영시간은 다음과 같으며, 병원 상황에 따라 조정이 가능하다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "월요일-금요일: 08:30-17:30 / 토요일: 08:30-12:30",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "24시 On-call 운영",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "국제진료센터에 내원한 환자 또는 의뢰 받은 외국인환자는 국제진료센터 의사가 평가하고 진료한다. 만약 응급 진료가 필요한 경우 응급진료센터로 이송 의뢰하고, 다른 진료과의 협의 진료가 필요할 때 예약센터 또는 국제진료센터를 통해 예약한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "국제진료센터의 운영시간 이후에 방문한 외국인 환자는 응급진료센터에서 진료를 받거나 국제진료센터의 의료진과 상의하여 적합한 진료과를 안내 받을 수 있다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "외부 병원에서 응급진료센터로 의뢰된 경우",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "사전에 세브란스병원과 전원 시키는 병원 간에 상호 동의된 환자는 응급진료센터에서 응급의학과 의사가 응급처치의 우선순위를 정하고 적합한 진료를 제공한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "이러한 절차를 따르는 동안 언어적 장애 요인을 감소시키기 위해 국제진료센터 의료진에게 진료 상황을 알리고 지원 받을 수 있도록 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "외국인 환자의 입원과 퇴원은 세브란스병원 내규 [2.1.2.1. 세브란스병원 이용 - 입원] 및 [2.1.5.1. 퇴원]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "내원이 용이하지 않은 해외환자와 의료원 해외 자선 사업으로 선정된 환자의 경우 [부록1. 외래예약 및 입원 등에 관한 규정]에 따라 외래 예약 및 진료(신속한 진료, 검사, 수납 및 접수), 입원 병실 배정 등에 편의를 제공할 수 있다.",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "(부록)",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "외래예약 및 입원 등에 관한 규정",
      "번호": "제5조",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "(참고)",
      "번호": "1.",
      "관련이미지": []
    },
    {
