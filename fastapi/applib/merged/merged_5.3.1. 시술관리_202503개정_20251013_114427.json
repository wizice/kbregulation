  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.1. 시술관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자에게 적합한 시술을 안전하게 제공하기 위해 시술 전 수행한 환자평가 결과를 기반으로 시술계획을 수립하여 수행하고, 시술기록을 작성하여 시술 후 치료의 연속성을 보장하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "침습적 시술: 수술실에서 시행되지 않으나 진단 및 치료 목적을 위해 신체의 일부를 절제, 제거, 변경하거나 진단과 치료 목적으로 내시경 시술을 시행하는 경우를 의미하며, 침습적 시술 목록은 세브란스병원 내규 [1.3.2. 시술의 정확한 수행]의 부록을 참고한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "시술 전 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "시술 전 확인, 시술부위 표시, 시술 시작 직전 Time Out은 세브란스병원 내규 [1.3.2. 시술의 정확한 수행]을 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "시술 전 환자 또는 법정대리인에게 세브란스병원 내규 [6.5.1. 동의서]에 따라 동의서를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "시술 전 평가 및 계획",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "의사는 환자의 병력(과거력), 신체적 상태, 진단검사 결과 및 자료, 추정진단 등을 평가하여 시술 계획을 수립한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "의사는 시술실 입실 전에 시술 전 진단명을 기록한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "침습적 시술 기록",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "시술에 참여한 의료진이 시술실 퇴실 전에 시술에 대한 내용을 작성한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "기록내용",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "시술명, 집도의/보조의 이름, 시술 전 진단명, 시술 후 진단명, 검사를 위해 채취한 조직표본검체(조직, 체액 등), 출혈 정도, 기타 시술 중 특이사항, 시술기록 작성일시, 작성자 서명 등",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "시술 후 환자상태 평가 및 치료계획 수립",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "의사는 시술 후(회복실 퇴실 후) 환자상태, 시술 후 발생하거나 가능성이 있는 합병증, 검사결과, 주의관찰 사항 등을 평가하여 24시간 이내 치료계획을 수립한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "간호사는 시술 후 24시간 이내 환자평가를 수행하여, 이를 기반으로 간호계획을 수립하고 기록한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "시술 시 환자안전 보장",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "시술과정에서 발생할 수 있는 환자의 피부화상 및 괴사 등을 예방하거나 조기에 발견하기 위해 시술 전, 후로 피부상태를 확인하고 피부상태에 이상이 있을 시 의사에게 알려 적절한 처치를 시행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "시술 과정에서 채취한 조직표본검체의 안전한 관리를 위해 처방에 따라 조직표본검체 용기에 라벨링을 시행하고 검체를 검사실로 전달한 직원의 이름을 기록한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "채취한 검체는 바로 검사실 또는 해당 병동으로 보내며 보내기 전까지 보관해야 하는 경우 전용장소에 보관한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
