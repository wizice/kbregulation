    {
      "seq": 7,
      "레벨": 2,
      "내용": "혼수상태 환자 진료 계획",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "혼수상태 환자를 Care하는 관련 의료진은 Care plan을 작성하여 환자 진료의 목표를 공유한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "환자가 혼수상태인 경우에는 반드시 환자 팔찌(혹은 발찌)를 착용한다.",
      "번호": "2)",
