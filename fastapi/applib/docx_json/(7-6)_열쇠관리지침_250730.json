  "조문내용": [
    {
      "seq": 1,
      "레벨": 1,
      "내용": "<b>(목적)  </b>이 지침은 열쇠(KEY)에 대하여 사용 및 보관, 관리에 수반되는 제반 절차를 규정 하여 효율적인 관리를 도모하고자 한다.",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "<b>(용어의 정의) </b>이 지침에서 사용하는 용어의 정의는 다음과 같다.",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "「열쇠(KEY)」라 함은 잠금장치 및 출입에 사용되는 모든 열쇠를 말한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 2,
      "내용": "「열쇠 관리」라 함은 열쇠에 대한 구입, 보수, 변경, 등록, 양도·양수 및 이에 관련되는 일체의 업무를 말한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "<b>(열쇠의 종류)</b>  각 부점에서 관리하는 열쇠의 형태별 종류는 다음과 같다.",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "일상용 열쇠(전자카드 포함)",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "비상용 열쇠(전자카드 포함)",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "<b>(적용범위)</b>  이 지침은 본사 및 영업점 모든 열쇠에 적용한다.",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 1,
      "내용": "<b>(준용)</b>  이 지침에서 정하지 아니한 사항은 관계 규정 및 법령을 준용한다.",
      "번호": "제5조",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 1,
      "내용": "<b>(관리 책임자)</b>  ① 주무부서장은 열쇠관리업무를 총괄한다.",
      "번호": "제6조",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "각 부점장을 관리책임자로 한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "각 부점장은 소속직원 중 열쇠관리담당자를 정하여 관리업무를 수행하게 하여야 한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 1,
      "내용": "<b>(관리담당자의 임무)  </b>열쇠관리담당자의 임무는 다음 각 호와 같다.",
      "번호": "제7조",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "열쇠관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 2,
      "내용": "사무실 출입 관련 외주 보안업체 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "“열쇠 관리대장”[별지 제1호 서식], “열쇠 분실·훼손 신고서”[별지 제2호 서식]<span style=\"color:#FF0000\">, “모바일카드 관리대장”</span> <span style=\"color:#FF0000\">[별지 제3호 서식] 관리, “실물카드 관리대장”[별지 제4호 서식](2025. 7. 30. 본호 개정)</span>",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "잠금장치에 대한 점검 및 후속조치 시행",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "사고발생시 처리",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "기타 열쇠관련 업무",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 1,
      "내용": "<b>(관리)</b>  ① 열쇠는 각 부점별로 관리한다.",
      "번호": "제8조",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 2,
      "내용": "각 부점은 모든 열쇠의 불출, 반납 및 기타 관리에 관한 제반 변동사항을 열쇠 관리대장, <span style=\"color:#FF0000\">모바일카드 관리대장, 실물카드 관리대장에 기록하여야 한다.(2025. 7. 30. 본항 개정)</span>",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "각 열쇠는 최소 2개 이상 보유하여야 하며, 1개는 일상용 열쇠로 <span style=\"color:#FF0000\">사용자</span>에게 지급하고, 1개 이상은 비상용 열쇠로 열쇠관리담당자가 보관한다.<span style=\"color:#FF0000\">(2025. 7. 30. 본항 개정)</span>",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "열쇠는 타인에게 전도 할 수 없다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "인사발령 및 기타 등 열쇠 반납사유 발생시 즉시 반납하여야 한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 2,
      "내용": "비상용 열쇠는 긴급사항 발생시 사용을 하되 반드시 부점장에게 보고하여야 한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 1,
      "내용": "<b>(책임)</b>  열쇠를 지급받은 자는 열쇠관리에 철저해야 하며, 열쇠로 인한 모든 사항에 책임이 있다.",
      "번호": "제9조",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 1,
      "내용": "<b>(분실 및 훼손보고) </b> 열쇠 분실 또는 훼손시 부점장 및 열쇠관리담당자에게 즉시 보고 후 “열쇠 분실·훼손 신고서”를 제출 하여야 한다.",
      "번호": "제10조",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 1,
      "내용": "<b>(점검 및 수리) </b> ① 열쇠관리담당자는 수시로 열쇠의 보관관리 상태를 점검하여야 한다.",
      "번호": "제11조",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "열쇠관리담당자는 사무실 출입보안시스템의 점검을 담당외주업체에서 실시토록 확인한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "점검결과 이상이 있을 경우 즉시 필요한 조치를 취하여야 한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "열쇠가 분실 또는 훼손 되었을 경우 부점장 승인 후 복제할 수 있다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 2,
      "내용": "잠금장치가 파손 되었을 경우 부점장 승인 후 관련업체를 통해 수리할 수 있다.",
      "번호": "⑤",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 1,
      "내용": "<b>(보고) </b> 열쇠의 관리소홀로 인한 사건·사고 발생시 즉시 주무부서에 보고하여야 하며, 사건·사고 확대방지를 위하여 최선의 노력을 해야 한다.",
      "번호": "제12조",
      "관련이미지": []
    },
