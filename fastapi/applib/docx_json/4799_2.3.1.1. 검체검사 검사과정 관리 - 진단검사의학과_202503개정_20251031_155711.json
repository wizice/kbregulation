      },
      {
        "seq": 41,
        "레벨": 3,
        "내용": "검체보관",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 42,
        "레벨": 4,
        "내용": "검사가 종료된 검사의 검체는 검사결과 통보 후 재검사를 위해 보관한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 43,
        "레벨": 4,
        "내용": "보관장소 및 기간: 검체 종류에 따라 다음의 일수만큼 냉장보관한다.",
