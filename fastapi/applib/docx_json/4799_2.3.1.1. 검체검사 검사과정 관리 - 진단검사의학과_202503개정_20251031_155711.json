        "내용": "적절한 검체 채취용기 선택: 검체 바코드에 기재된 검체 용기명을 확인하여 검체 용기를 선택한다. 검사 종류에 따라 적절한 검체의 적정한 양을 지정된 용기에 채취한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 20,
        "레벨": 4,
        "내용": "채혈 시 주의사항",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 21,
        "레벨": 5,
        "내용": "채혈량은 검사종목에 따른 검체의 양을 참고로 채혈한다.",
        "번호": "①",
        "관련이미지": []
      },
      {
        "seq": 22,
        "레벨": 5,
        "내용": "채혈 시 울혈 및 혈액농축을 막기 위해 Tourniquet을 1분 이상 묶지 않도록 하고 적당한 속도로 거품이 생기지 않도록 하다.",
        "번호": "②",
        "관련이미지": []
      },
      {
        "seq": 23,
        "레벨": 5,
        "내용": "항응고제 Tube의 경우, 항응고제 혼합이 충분치 않아 Microclot이 생기면 Cell Count, 혈액응고검사 등에 큰 오차가 생길 수 있으므로 모든 채혈관은 채혈 후 5~10회 조심스럽게 혼합하여 충분히 섞이도록 한다.",
        "번호": "③",
        "관련이미지": []
      },
      {
        "seq": 24,
        "레벨": 5,
        "내용": "검체용기 사용 순서: 혈액배양용기 → Sodium Citrate Tube → Plain Tube → Serum separator (Gel) Tube → Heparin Tube → EDTA Tube → EDTA Gel Tube",
        "번호": "①",
        "관련이미지": []
      },
      {
        "seq": 25,
        "레벨": 5,
        "내용": "항응고제 및 Clot Activator가 들어있는 Tube는 검체 채취 후 Tube를 5~10회 즉시 항응고제 및 Clot Activator가 충분히 섞이도록 혼합한다.",
        "번호": "②",
        "관련이미지": []
      },
      {
        "seq": 26,
        "레벨": 4,
        "내용": "검체 용기 라벨링: 정확한 검체 인식을 위해 Tube에 검체 바코드를 부착한다. 바코드의 환자이름, 등록번호, 검사명, 검체종류, 검체채취일 등을 확인한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 27,
        "레벨": 4,
        "내용": "검사실 전달까지의 관리사항",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 28,
        "레벨": 5,
        "내용": "모든 검체는 바코드가 부착되어 있어야 하며, 새지 않고, 오염되지 않도록, 안전하게 닫혔는지 확인 후 이송한다.",
        "번호": "③",
        "관련이미지": []
      },
      {
        "seq": 29,
        "레벨": 5,
        "내용": "검사실로 운반 전 검체 Tube는 밀봉된 이차용기에 넣는다. 이차용기는 커다란 통(플라스틱통, 자주대차, 에어슈터 등) 및 입구를 닫을 수 있는 플라스틱 가방 등을 사용한다.",
        "번호": "④",
        "관련이미지": []
      },
      {
        "seq": 30,
        "레벨": 5,
        "내용": "환자의 모든 검체는 감염원이 될 수 있으므로 취급에 주의한다.",
        "번호": "⑤",
        "관련이미지": []
      },
      {
        "seq": 31,
        "레벨": 3,
        "내용": "정확한 검체검사를 위한 확인 절차",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 32,
        "레벨": 4,
        "내용": "모든 검사물에는 반드시 환자이름과 등록번호가 포함된 바코드가 부착되어야 하며, 자동화 장비로 접수한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 33,
        "레벨": 4,
        "내용": "장비 고장시 접수직원은 검체를 하나씩 확인한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 34,
        "레벨": 4,
        "내용": "필요시 검사요청일, 검사의뢰 목적 등을 확인한다.",
