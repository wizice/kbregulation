    },
    {
      "seq": 59,
      "레벨": 5,
      "내용": "결과 허용범위: 정도관리 자료는 Westgard의 Multirules 등을 적용하여 평가하되, 각 부서의 특성에 따라 [부록4. 진단검사의학과 업무규정]을 참고하여 정해진 범위를 적용한다.",
      "번호": "⑩",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 5,
      "내용": "결과 이상치 발견 시 조치 및 보고체계: 정도관리 결과 지정된 범위를 벗어난 경우, 재검사, 정도관리물질/시약 Lot No. 확인, 장비 상태 점검 등을 실시한다. 정도관리물질 Level이 바뀌었는지 확인하고 새로운 정도관리물질로 재검사한다. 장비를 재점검 후 다시 측정하고 부서장 및 담당 전문의에게 보고한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 4,
      "내용": "외부 정도관리",
      "번호": "(가)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 5,
      "내용": "CAP(College of American Pathologists), RIQAS(Randox International Quality Assessment Scheme), 대한진단검사정도관리협회, 한국유전자평가원 등에서 실행하는 외부 정도관리에 참여한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 5,
      "내용": "외부 정도관리에 포함되지 않는 종목에 대해서는 정확성과 신뢰성 검증을 위하여 같은 방법을 사용하는 타기관과 비교하여 결과 일치도를 분석한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 5,
      "내용": "외부 정도관리 결과는 담당 전문의와 검토하여 문제점이 있을 때 보완하고 서명한 기록을 최소한 2년 보관한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 3,
      "내용": "현장검사(POCT: Point-of-care-testing) 관리",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 66,
      "레벨": 4,
      "내용": "현장검사위원장이 관리∙감독한다.",
      "번호": "(가)",
      "관련이미지": []
    },
    {
      "seq": 67,
      "레벨": 4,
      "내용": "현장검사를 시행하는 직원은 필요한 자격 및 교육을 받는다.",
      "번호": "(나)",
      "관련이미지": []
    },
    {
      "seq": 68,
      "레벨": 4,
      "내용": "현장검사 처방은 필요시 의사 지시에 따라 반복시행 가능하다. 세부사항은 [부록4. 진단검사의학과 업무규정]을 참고한다.",
      "번호": "(다)",
      "관련이미지": []
    },
    {
      "seq": 69,
      "레벨": 4,
      "내용": "이상검사결과 보고는 실제 검사자가 즉시 보고하되, 그 기준은 세브란스병원 내규 [2.3.2.1. 검체검사 결과 보고 - 진단검사의학과]에 따른다.",
      "번호": "(라)",
      "관련이미지": []
    },
    {
      "seq": 70,
      "레벨": 4,
      "내용": "POCT 정도관리: POCT 검사 지침에 따른 [부록4. 진단검사의학과 업무규정] 정도관리 시행 주기에 맞게 해당 검사항목의 실제 검사자가 정도관리를 시행하고 진단검사의학과에서 관리한다.",
      "번호": "(마)",
      "관련이미지": []
    },
    {
      "seq": 71,
      "레벨": 4,
      "내용": "현장검사 모니터링 및 개선활동 결과를 병원 질향상과 환자안전 활동에 통합하여 관리한다.",
      "번호": "(바)",
      "관련이미지": []
    },
    {
      "seq": 72,
      "레벨": 2,
      "내용": "검사외부 의뢰체계",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 73,
      "레벨": 3,
      "내용": "수탁기관의 안전성 확인",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 74,
      "레벨": 5,
      "내용": "의뢰기관의 안전성 확인을 위하여 매년 수탁기관 인증서와 해당기관의 외부 정도관리 인증서 등을 받는다.",
      "번호": "ⅰ)",
      "관련이미지": []
    },
    {
      "seq": 75,
      "레벨": 5,
      "내용": "각 기관별 정도관리는 검사 종목당 1회/월 받으며, 국가에서 진행되는 검사는 예외로 한다.",
      "번호": "ⅱ)",
      "관련이미지": []
    },
    {
      "seq": 76,
      "레벨": 3,
      "내용": "위탁검사 선정 및 조정절차",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 77,
      "레벨": 5,
      "내용": "진료과의 검사종목 요청 시 해당 검사실에서 수행 여부를 검토 후 외부 의뢰 여부를 결정한다.",
      "번호": "ⅰ)",
      "관련이미지": []
    },
    {
      "seq": 78,
      "레벨": 5,
      "내용": "의뢰기관 선정 시 수탁기관 인증서와 해당기관의 외부 정도관리 인증서 등을 근거로 해당 검사실(진단검사의학과 또는 병리과)에서 검토 후 결정한다.",
      "번호": "ⅱ)",
      "관련이미지": []
    },
    {
      "seq": 79,
      "레벨": 3,
      "내용": "수탁기관별 검사리스트를 규정하고 관리한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 80,
      "레벨": 3,
      "내용": "수탁기관으로 의뢰 이송 전 검체관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 81,
      "레벨": 4,
      "내용": "일반 검사와 동일하게 해당 검사실로 접수하고, 검사실에서 해당 기관으로 의뢰한다.",
