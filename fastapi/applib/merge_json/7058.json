      "내용": "1.3.10. 입퇴실 절차 – 방사성동위원소 치료병실",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "집중치료가 필요한 환자에게 한정된 자원을 효율적으로 활용하여 적절한 의료서비스를 제공하기 위해 표준화된 방사성동위원소 치료병실 입퇴실 절차를 준수하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "RI(Radio Isotope) Therapy Room: 방사성동위원소 치료병실, 방사성동위원소를 이용하여 환자를 치료하는 병실로 원자력안전법에 의거 원자력안전위원장의 허가를 받은 시설",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "입실기준",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "진료 시 방사성동위원소 치료 전에 환자 또는 대리인에게 방사선치료의 개요와 예상 이득, 방사선 피폭량, 잠재적 위험 등을 설명한 후 동의서를 작성한 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "핵의학과 진료를 통하여 방사성동위원소 투여량을 결정하고 전처치가 준비된 환자(저요오드식, 입원 때 필요한 사항, 병실 사용 관련 주의 사항, I-131 투여 후 주의사항 등 안내)",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "입실 후에는 병실 외부 출입과 면회가 금지되고 보호자도 상주할 수 없어 다음의 사항을 충족하는 환자가 입실하여 치료할 수 있다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "인지능력이 있고 원활한 의사소통이 가능한 자",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "신체활동지수(ECOG) 0 또는 1인 자",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "병실 내에서 환자 혼자 스스로 자가 간호(식사, 투약, 개인 위생, 배뇨/배변 관리, 운동 및 활동 능력 등)가 가능하고 의료진과 콜 벨 사용 및 전화를 이용하여 의사소통이 가능한 자",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "소아와 미성년자로 자가 간호 수행이 어려운 환자는 보호자가 동반 입실",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "위의 사항이 충족되지 않을 경우 주치의(담당교수)와 상의 후 입실을 취소할 수 있다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "정서장애, 섬망, 인지장애, 자가 간호 수행이 어렵거나 재실 기간 동안 증상 악화 가능성이 예상되는 경우 입실을 제한한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "의료분야의 방사선안전관리에 관한 기술 기준에 의거하여 진료 환자의 재실 기준은 다음과 같이 적용한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "환자 체내에 잔류하는 방사성동위원소의 방사능이 1.2GBq(33mCi)을 초과하는 경우",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "환자 신체 표면으로부터 1m 거리, 1m 높이에서의 최대 방사선량률(70μSv/h)을 초과하는 경우",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "입실 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "입실기준에 따라 주치의(담당교수)가 환자의 입실을 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "의료진은 입실 시 환자 및 보호자에게 입실 필요성을 설명하고 동의를 받는다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "입실 시점의 환자 상태를 평가하고 입실 기준에 부합하는지를 의무기록에 기록한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "퇴실 기준: 의료분야의 방사선안전관리에 관한 기술 기준에 의거하여 진료 환자의 퇴원 기준은 다음과 같이 적용한다.",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "환자 신체 표면으로부터 1m 거리, 1m 높이에서의 최대 방사선량률이 70μSv/h 이하인 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "환자 퇴원 후 요양 계획 및 주변 환경을 면밀히 고려하여 환자의 가족이나 친지 등이 받는 개인의 유효선량이 5mSv 초과하지 않아야 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "퇴실 절차",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "퇴실 기준에 따라 주치의(담당교수)가 환자의 퇴실을 결정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "의료진은 퇴실 시 환자 상태를 평가하고 퇴실 기준에 부합하는지를 의무기록에 기록한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "퇴원으로 인하여 방사선에 의해 영향을 받을 수 있는 다른 개인의 유효 선량을 합리적으로 가능한 낮게 유지하도록 하기 위하여 주의사항이 기재된 지침 및 퇴원 이후 생활 지침 안내서를 제공한다.",
      "번호": "3)",
      "관련이미지": []
    },
