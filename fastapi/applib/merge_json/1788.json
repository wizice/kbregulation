      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "의료기구와 관련된 감염발생의 위험을 예방하기 위해 의료기구와 관련된 적절한 감염관리 활동을 수행하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "세척(Cleaning): 물과 세제를 사용하여 물품의 표면에 묻어 있는 이물질을 제거하는 과정",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "소독(Disinfection): 아포(spore)를 형성하는 세균을 제외한 대부분의 미생물을 파괴하는 과정으로 미생물의 감염의 위험성을 제거하는 것",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "멸균(Sterilization): 물리적, 화학적인 방법을 이용하여 바이러스, 세균, 진균, 아포(spore)등을 포함한 모든 형태의 미생물을 파괴하는 과정으로 완전한 무균상태 병원체, 비병원체를 가리지 않고 모든 미생물을 사멸시키는 것",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "중앙멸균실 환경관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "출입통제: 멸균실의 환경을 청결하게 유지하기 위해 인위적으로 공간을 구별하여 관리하며 외부인의 출입을 통제한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "구역의 구분",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "오염제거구역(Decontamination area): 각 사용부서에서 반납된 기구와 물품의 수거, 분류, 오염제거를 위해 세정하는 장소로 음압유지가 필요한 구역",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "준청결구역(Semi clean area): 세정된 물품을 멸균을 위해 포장하고 준비 정리하는 구역",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "청결구역(Clean area): 멸균 완료된 물품을 보관하는 장소로 재오염을 막기 위한 공조시설과 특별관리, 통행 제한이 필요한 구역",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "모든 물품 및 장비는 오염지역에서 청결지역으로 세척실에서 포장실로 옮기는 작업흐름을 따라 설치한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "복장관리",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "근무자는 전용 복장과 모자, 신발을 착용한다. 각 구역에서 사용하는 복장을 구분하고, 외부로 나갈 때는 외부용 복장을 착용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "세척실(오염지역) 직원은 복장이 젖거나 오염되면 수시로 갈아입는다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "수동세척 업무 시에는 혈액/체액이나 각종세제로부터 보호하기 위해 손목이 긴 장갑을 착용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "세척실에서 신는 신발은 앞이 막혀 있는 것으로 사용하고 세척실 외부와 구분하여 사용한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "세척을 담당하거나 오염된 기구를 취급할 때는 적절한 개인보호구(가운, 장갑, 마스크, 안면보호구, 모자, 신발 등)를 사용한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "환기, 온도, 습도 관리",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "중앙멸균실의 환기시설은 인접한 공간에서 상대적으로 오염된 공간으로 공기가 흐르도록 설계한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "각 구역별로 문을 닫아 오염제거구역(세척실)과 저온멸균실은 음압, 물품준비 및 포장구역, 멸균품 보관실은 양압을 유지한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "시간당 10회 이상의 공기교환이 이루어져야 하며 적절한 온도(16-24℃) 및 습도(30-70%)를 유지하도록 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "팬(fan)은 강한 공기의 흐름을 생성하고 설계된 공기흐름을 방해하므로 사용하지 않는다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "사용한 의료기구의 세척, 소독, 멸균",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "사용한 의료기구 수거방법",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "사용한 물품의 수거와 청결 또는 멸균 물품의 공급은 구획을 분리하여 교차오염이 되지 않도록 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "오염기구 수거 전용 용기와 멸균기구 공급 전용 용기를 구분하여 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "사용한 의료기구는 밀폐된 용기에 넣어 주변 환경의 오염을 최소화하는 방법으로 이동한다. (밀폐용기를 사용하여 통행량이 적은 동선과 시간 고려)",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "중앙멸균실의 동선을 고려하여 사용한 물품의 반납장소와 멸균물품의 수령장소를 준수한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "직원은 장갑, 가운, 마스크를 착용한 후 사용한 물품을 수거한다. 물품 수거 후 장갑 및 가운을 벗고 새장갑으로 교환 후에 주변 환경을 소독하고 손위생을 실시한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "직원의 개인보호구 착용",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "세척을 담당하거나 오염된 기구를 취급할 때는 적절한 개인보호구(가운, 장갑, 마스크, 안면보호구, 모자, 신발 등)를 착용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "세척",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 4,
      "내용": "의료기구의 세척은 중앙멸균실에서 진행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 4,
      "내용": "소독이나 멸균과정의 가장 첫 번째 단계로 시작한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "사용한 모든 의료기구는 오염원으로 간주하고 진행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "사용한 기구는 가능한 사용 즉시 눈에 보이는 오염을 제거한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "세척과정에서 오염물질이 튀거나 분무될 가능성이 있으면 적합한 개인보호구(가운, 장갑, 마스크, 안면보호구, 모자, 신발 등)를 착용한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 4,
      "내용": "세척과 관련된 세부사항은 [감염관리지침]의 II. 소독과 멸균을 참조한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "기구 위험도에 따른 소독 및 멸균",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "의료환경에서 사용하는 물품은 사용목적과 방법에 따라 고위험, 준위험, 비위험으로 분류하고 제조사의 지침을 준수하여 필요한 소독 및 멸균방법을 적용하며 자세한 사항은 [감염관리지침]의 II. 소독과 멸균을 참조한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 5,
      "내용": "고위험 물품: 세균의 아포를 포함한 어떤 미생물에라도 오염되었다면 감염의 위험이 매우 높은 물품으로, 멸균/화학멸균제를 적용한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 5,
      "내용": "준위험 물품: 점막이나 불완전한 피부에 접촉하는 물품으로, 화학멸균제/높은 수준의 소독제를 적용한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 5,
      "내용": "비위험 물품: 손상이 없는 피부와 접촉하며 점막에 사용하지 않는 물품으로, 중간/낮은 수준의 소독제를 적용한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 3,
      "내용": "소독",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "새로운 소독제의 사용 및 변경은 감염관리위원회의 소독제관리 소위원회의 심의를 거친다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "소독제는 살균력의 범위, 작용시간, 독성, 기구에 미치는 영향 등을 고려하여 선택한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 4,
      "내용": "소독수준의 분류, 소독제의 종류와 특성, 기구별 소독 및 멸균방법은 [감염관리지침]의 II. 소독과 멸균에 따른다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "멸균",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 4,
      "내용": "고위험 의료기구/물품은 멸균하여 사용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 4,
      "내용": "멸균은 아포를 포함한 모든 미생물이 존재하지 않음을 의미한다. 멸균방법은 열(스팀멸균, 신속멸균)이나 화학제제(E·O가스멸균, 포름알데하이드멸균, 과산화수소가스 플라즈마멸균), 방사선(감마멸균)을 이용한다. 자세한 사항은 [감염관리지침]의 II. 소독과 멸균을 참조한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 4,
      "내용": "멸균방법을 선택할 때는 멸균 여부를 확인할 수 있는지, 내부까지 멸균될 수 있는지, 물품의 화학적/물리적 변화가 있는지, 멸균 후 인체나 환경에 유해한 독성이 있는지,",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 4,
      "내용": "경제성 및 제조사의 지침 등을 고려하여 선택한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "물품의 모든 표면이 멸균되도록 포장하고, 공기가 자유롭게 순환할 수 있도록 멸균품 간 여분의 공간을 만들어 배치하며 멸균기 내 용적의 60~70%만 채워서 적재한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 2,
      "내용": "멸균기 관리",
