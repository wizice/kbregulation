      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "입원치료가 필요한 환자에게 적시에 진료를 제공하기 위해 입원 수속에 대한 표준화된 절차를 제공하고 준수하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "입원 수속 방법",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "입원결정",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "입원권한(Admitting Privilege)을 가진 의사가 입원진료가 필요하다고 판단하는 경우 환자 및 보호자와 상의하여 입원 결정하면 입원 또는 입원 접수(입원 예약)를 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "입원을 결정한 의사는 입원결정서를 작성한다. 단, 응급진료센터, 분만실을 통한 입원이나 신생아 입원의 경우에는 주치의(담당교수) 감독하에 전공의(담당의사)가 입원 결정서를 작성할 수 있다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "필요 시 입원 전에 필요한 검사를 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 5,
      "내용": "입원 전 검사란 입원 결정의 근거가 되는 검사이거나, 수술 및 시술 준비를 위한 검사를 총칭한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 5,
      "내용": "입원 전 검사가 필요한 경우 처방한다. 의사는 처방한 검사 결과를 확인하고 최종적으로 입원, 전원 등 여부를 결정한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "입원을 처방한 의사는 입원 전에 환자 및 보호자에게 입원 시 환자의 진단명, 치료계획, 예상되는 결과 등에 대하여 설명한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "입원예약",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "입원원무팀(암병원 원무팀, 각 전문진료기관 원무파트 포함, 이하 입원원무팀으로 표기)은 환자 정보, 진료과, 주치의(담당교수), 입원예정일자 등을 확인하고 입원 예약을 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "주치의(담당교수)가 당일 입원을 요청했으나 불가능한 경우, 진료과와 협의하여 입원 예약을 재설정하고 필요 시 익일로 입원 예약을 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "주치의(담당교수)가 지정한 일자에 입원하지 못할 경우, 진료과와 협의하여 입원 예약일을 재설정하고 필요 시 익일로 입원 예약을 변경한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "입원유의사항안내문(입원절차, 환자 권리와 의무, 기타사항 등)을 제공하고, 입원약정 사항을 설명한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "입원연락 시 환자를 확인(이름, 등록번호 등)하고 입원시간, 병실, 입원 시 준비물(진료카드 등 관련 서류와 개인물품 등)을 안내한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "입원수속 및 입원 시 설명하는 정보",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "입원은 정규시간(월요일-일요일, 08:30-17:30)에 이루어진다. 단, 응급진료센터 경유 입원은 24시간 이루어진다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "입원의 종류에 따른 수속 방법",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 5,
      "내용": "계획된 입원: 진료상 입원 치료가 요구되어 의료진으로부터 입원 결정된 환자 또는 보호자는 입원원무팀(암병원 원무팀, 각 전문진료기관 원무파트 포함, 이하 입원원무팀으로 표기)을 방문하여 입원 접수하며, 담당 직원은 입원 예정일 및 입원 수속 시 제출서류, 병실배정사항에 대해 설명한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 5,
      "내용": "정규시간 이외 입원, 응급진료센터 경유 입원: 응급진료센터 입원원무팀에서 필요한 입원 수속을 한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "입원약정서에 기재된 환자 정보를 확인하고 배정병실과 주치의(담당교수)를 설명한다. 해당되는 경우 상급병실료에 대해 환자 및 대리인에게 설명하고 신청서를 작성한다. 병동 입원생활 안내문 및 진료비 확인 방법(병실료, 비급여 등 입원 중 진료비용)을 안내한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "감염예방을 위해 환자 1명당 보호자 1명만 출입할 수 있는 보호자출입증을 제공하고, 입원수속을 마친 환자는 병동으로 이동하여 간호사에게 입원서류를 전달하도록 안내한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "감염병 유행 등 특수 상황으로 보호자 상주 제한, 선제검사 시행 등이 필요한 경우 추가 안내한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "입원 시 병동 입원생활안내문, 화재예방 등 입원 시 주의사항, 병원 내 시설 안내, 낙상예방지침 등에 대해 환자 및 보호자에게 설명한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "입원수속을 마치면 환자는 병동으로 이동하고, 간호사에게 입원서류를 전달한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "입원 순서배정",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "입원환자 병실배정 순서는 병원 내부 상황, 환자가 필요로 하는 의료서비스(수술, 시술, 응급, 항암, 검사 등)의 긴급성을 고려하여 배정한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "병실배정 시 성별구분, 격리여부를 구분하여 배정하고 주 병동에 우선 배정하며 주 병동에 병상이 없는 경우는 유사 진료군 병동으로 배정한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "입원이 지연되는 환자관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "입원지연이란 환자 또는 병원의 사정으로 입원예정인 환자가 예정일이 경과하였음에도 입원하지 못하였을 경우이다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "매일 입원지연 환자를 파악한다.",
      "번호": "2)",
