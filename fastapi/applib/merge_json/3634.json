      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "환자치료영역의 청소 및 소독",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "환경관리인에 대한 교육과 감독은 환경관리 담당부서(사무팀, 경영지원팀 등)에서 주관하며 교육 내용에는 청소방법, 소독제의 종류 및 사용방법, 청소용구 관리, 개인보호구 사용 등에 대한 내용을 포함한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "청소구역: 환자치료영역이 아닌 행정사무실, 회의실 등",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "소독구역",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "침습적 행위를 수행하는 구역: 수술실, 중재적 치료실, 중환자실, 응급진료센터, 인공신장실 등",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "소독이 필요한 환경: 병동, 외래, 검사실, 화장실 등",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "환자치료영역이 아닌 환경이라도 혈액, 체액, 분비물, 배설물의 오염이 발생한 경우 소독제를 이용하여 청소한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "청소 및 소독주기",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "병실바닥 및 화장실: 1일 2회 이상",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "창문: 주 1회 이상",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "환자 간 커튼: 정기적으로 또는 눈에 띄는 오염이 있을 때, 감염성질환 환자가 이동하거나 퇴원할 때",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "침대 및 침요: 눈에 띄는 오염이 있을 때, 환자가 퇴원할 때",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "벽, 블라인드: 눈에 띄는 오염이 있을 때, 블라인드는 최소 2개월에 1회",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "병실은 매일 청소하며, 병실 내의 접촉빈도가 높은 곳(문손잡이, 침상난간, 스위치 등)은 더 자주 청소, 소독한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "욕실과 화장실, 환자 휴게실과 같이 병동 내 공용으로 사용하는 표면은 소독제로 매일 청소한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "환자가 퇴원 및 병실을 이동한 경우 소독제로 청소한다.",
      "번호": "(8)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 4,
      "내용": "수술실, 고위험 침습적 시술실, 중환자실, 신생아중환자실, 검체를 다루는 검사실 등은 매일 소독제를 이용하여 청소한다.",
      "번호": "(9)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "청소 및 소독 시 주의사항",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "연무 또는 에어로졸을 생성하거나 먼지를 분산시키는 청소나 소독방법은 피한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "개봉한 소독제는 오염되지 않도록 관리한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "세제나 환경소독제를 사용하는 용기는 재사용하지 않으며, 만약 용기를 재사용하는 경우 세척 후 건조시켜 보관한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "환경소독제는 제품 설명서에 따라 희석농도, 사용기간, 사용기한일 등을 준수하여 사용한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "청소용구 및 소독용구 관리",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "청소카트는 표준지침에 따라 청결하게 유지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "일회용 소독티슈나 세척·소독한 걸레를 사용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "사용한 걸레는 환경소독제로 세척하고 건조 후 재사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "매일 일과 후에 정리정돈하고 환경소독제로 표면을 닦는다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "진공청소기를 사용할 경우에는 HEPA 필터가 장착된 것을 사용한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "직원의 개인보호구 착용",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "청소 및 소독 과정에서 감염질환이나 소독제 노출을 예방하기 위하여 적절한 개인보호구(장갑, 가운, 마스크, 보안경 등)를 착용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "격리실 청소 시에는 격리표식에 제시된 개인보호구를 반드시 착용하고 시행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 2,
      "내용": "환자치료영역의 물관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "재활치료실 수치료실",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "환자관리",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 5,
      "내용": "모든 환자는 수조에 들어가기 전 비누를 사용하여 샤워한 후 들어간다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 5,
      "내용": "다음과 같은 환자들은 물을 오염시킬 수 있으므로 수치료 시설 사용을 제한하거나 치료순서를 고려한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 6,
      "내용": "변실금 환자",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 6,
      "내용": "개방된 창상이나 치유되지 않는 장루(stoma)를 가진 환자",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 6,
      "내용": "국소적 감염이 의심되는 피부질환을 가진 환자",
      "번호": "c.",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "물 관리",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 5,
      "내용": "수치료에 사용하는 물은 다층복합 여과기를 사용하고 역세척 시스템을 통해 매일 관리한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 5,
      "내용": "수조의 물, 모래와 활성탄은 정기적으로 교체한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 5,
      "내용": "연 2회 수질검사 전문기관에 수질검사를 의뢰한다. 수질검사방법은『먹는물 수질기준 및 검사 등에 관한 규칙』에 따르며, 수질기준은『체육시설의 설치․이용에 관한 법률 시행규칙(2024. 8. 28.) [별표 6] 안전․위생 기준(제23조 관련)』에 따른다(㏗5.8-8.6, 유리잔류염소 0.4-1.0㎎/L).",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 4,
      "내용": "그 외 세부사항은 [감염관리지침] Ⅶ. 부서별 감염관리_12. 재활치료실에 따른다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 3,
      "내용": "치과 유닛체어",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 4,
      "내용": "수관물빼기",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 5,
      "내용": "매일 시작 전과 일과 후 Unit chair의 수관에서 물을 뺀다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 5,
      "내용": "환자진료 시 물이 나오는 장비를 사용한 경우에는 환자 치료가 끝나자마자 적어도 20~30초간 물과 공기를 빼낸다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 4,
      "내용": "수관소독: 최소한 4주에 1번은 시행해야 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 4,
      "내용": "수관미생물검사",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 5,
      "내용": "정기적으로 실시하고 필요시 추가 검사를 실시한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 5,
      "내용": "기준치 이상의 세균이 검출된 chair는 사용을 즉시 중단하고, 수관 소독을 실시한 후 재검사를 실시한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 4,
      "내용": "그 외 세부 사항은 [감염관리지침] Ⅸ. 환경관리_7. 치과 유닛체어에 따른다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 3,
      "내용": "인공신장실: 정기적으로 RO수 수질관리를 실시한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 4,
      "내용": "투석기계에 공급되는 물은 일반적인 물과는 분리되어 공급해야 하며, 발열물질(pyrogen)의 감소를 위하여 여과나 역삼투압 방식을 거쳐야한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 4,
      "내용": "투석액은 세균과 중금속이 없는 여과수여야한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 4,
      "내용": "투석액과 투석용수는 매월 1회 정기적으로 배양검사(미생물 수를 계산) 및 내독소 검사를 진행하며 세부사항은 [감염관리지침] Ⅶ. 부서별 감염관리_11. 인공신장실에 따른다.",
