        "seq": 40,
        "레벨": 5,
        "내용": "모든 환자는 수조에 들어가기 전 비누를 사용하여 샤워한 후 들어간다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 41,
        "레벨": 5,
        "내용": "다음과 같은 환자들은 물을 오염시킬 수 있으므로 수치료 시설 사용을 제한하거나 치료순서를 고려한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 42,
        "레벨": 6,
        "내용": "변실금 환자",
        "번호": "a.",
        "관련이미지": []
      },
      {
        "seq": 43,
        "레벨": 6,
        "내용": "개방된 창상이나 치유되지 않는 장루(stoma)를 가진 환자",
        "번호": "b.",
        "관련이미지": []
      },
      {
        "seq": 44,
        "레벨": 6,
        "내용": "국소적 감염이 의심되는 피부질환을 가진 환자",
        "번호": "c.",
        "관련이미지": []
      },
      {
        "seq": 45,
        "레벨": 4,
        "내용": "물 관리",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 46,
        "레벨": 5,
        "내용": "수치료에 사용하는 물은 다층복합 여과기를 사용하고 역세척 시스템을 통해 매일 관리한다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 47,
        "레벨": 5,
        "내용": "수조의 물, 모래와 활성탄은 정기적으로 교체한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 48,
        "레벨": 5,
        "내용": "연 2회 수질검사 전문기관에 수질검사를 의뢰한다. 수질검사방법은『먹는물 수질기준 및 검사 등에 관한 규칙』에 따르며, 수질기준은『체육시설의 설치․이용에 관한 법률 시행규칙(2024. 8. 28.) [별표 6] 안전․위생 기준(제23조 관련)』에 따른다(㏗5.8-8.6, 유리잔류염소 0.4-1.0㎎/L).",
        "번호": "ⅲ)",
        "관련이미지": []
      },
      {
        "seq": 49,
        "레벨": 4,
        "내용": "그 외 세부사항은 [감염관리지침] Ⅶ. 부서별 감염관리_12. 재활치료실에 따른다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 50,
        "레벨": 3,
        "내용": "치과 유닛체어",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 51,
        "레벨": 4,
        "내용": "수관물빼기",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 52,
        "레벨": 5,
        "내용": "매일 시작 전과 일과 후 Unit chair의 수관에서 물을 뺀다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 53,
        "레벨": 5,
        "내용": "환자진료 시 물이 나오는 장비를 사용한 경우에는 환자 치료가 끝나자마자 적어도 20~30초간 물과 공기를 빼낸다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 54,
        "레벨": 4,
        "내용": "수관소독: 최소한 4주에 1번은 시행해야 한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 55,
        "레벨": 4,
        "내용": "수관미생물검사",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 56,
        "레벨": 5,
        "내용": "정기적으로 실시하고 필요시 추가 검사를 실시한다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 57,
        "레벨": 5,
        "내용": "기준치 이상의 세균이 검출된 chair는 사용을 즉시 중단하고, 수관 소독을 실시한 후 재검사를 실시한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 58,
        "레벨": 4,
        "내용": "그 외 세부 사항은 [감염관리지침] Ⅸ. 환경관리_7. 치과 유닛체어에 따른다.",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 59,
        "레벨": 3,
        "내용": "인공신장실: 정기적으로 RO수 수질관리를 실시한다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 60,
        "레벨": 4,
        "내용": "투석기계에 공급되는 물은 일반적인 물과는 분리되어 공급해야 하며, 발열물질(pyrogen)의 감소를 위하여 여과나 역삼투압 방식을 거쳐야한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 61,
        "레벨": 4,
        "내용": "투석액은 세균과 중금속이 없는 여과수여야한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 62,
        "레벨": 4,
        "내용": "투석액과 투석용수는 매월 1회 정기적으로 배양검사(미생물 수를 계산) 및 내독소 검사를 진행하며 세부사항은 [감염관리지침] Ⅶ. 부서별 감염관리_11. 인공신장실에 따른다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 63,
        "레벨": 4,
        "내용": "미세물질 검사: 년 1회 주기적으로 미세물질 검사를 시행한다.",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 64,
        "레벨": 3,
        "내용": "음용수 관리",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 65,
        "레벨": 4,
        "내용": "조리장 내: 음용수는 수돗물 사용을 원칙으로 하며, 정기적으로 실시하는 수질검사결과를 확인한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 66,
        "레벨": 4,
        "내용": "정수기 관리",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 67,
        "레벨": 5,
        "내용": "정수기 사용부서 또는 관리부서에서는 정수기 토출구의 오염이 발생하면 즉시 닦아 관리한다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 68,
        "레벨": 5,
        "내용": "조유용 정수기는 주 1회 토출구를 분리하여 세척제로 세척한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 69,
        "레벨": 5,
        "내용": "총무팀은 먹는물 관리법에 의거하여 관리업체에서 정기적으로 filter 교체, 내부소독 및 수질 평가를 진행하는지 점검한다.",
        "번호": "ⅲ)",
        "관련이미지": []
      },
      {
        "seq": 70,
        "레벨": 5,
        "내용": "사용부서에서는 정수기 표면의 청결을 유지하고 관리내용이 관리카드에 잘 기록되는지 확인한다.",
