      {
        "code": "2.1.5.3",
        "name": "2.1.5.3. 진료·치료 거부 및 무단이탈 환자 관리",
        "appendix": [],
        "detail": {
          "documentInfo": {
            "규정명": "2.1.5.3. 진료·치료 거부 및 무단이탈 환자 관리",
            "내규종류": "규정",
            "제정일": "2012.05.",
            "최종개정일": "2025.03.25.",
            "최종검토일": "2025.03.25.",
            "담당부서": "의료질향상 및 환자안전위원회",
            "관련기준": [
              "4주기 의료기관인증기준: 1.5 외출 및 외박 관리",
