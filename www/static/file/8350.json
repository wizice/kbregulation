  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "7.1. 안전문화 프로그램",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원 내 안전문화 프로그램 수립하고, 안전문화 정착을 위한 관련 활동을 지원하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "안전문화(Culture of safety): 병원의 안전문화는 병원에서 제공하는 의료서비스 및 안전관리의 스타일과 숙련도를 결정하는 개인과 그룹의 가치, 태도, 인식, 역량, 행동패턴의 결과물이다. 긍정적인 안전문화가 형성된 병원에서는 상호신뢰에 기반한 의사소통, 안전의 중요성에 대한 인식의 공유, 위험저감활동에 대한 확신의 특징을 보인다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "환자안전사건: 의료서비스 중 발생한 사건사고나 예상치 못한 진료결과에 대하여 의료진 또는 환자로부터 진료혁신센터 환자안전팀에 신고된 사건",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "의료질향상 및 환자안전위원회와 병원운영위원회는 책임감과 투명성을 증진하는 병원 전체의 안전문화 조성을 위해 다음의 활동을 담당한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "안전문화 관련 계획수립, 모니터링, 증진 전략 이행 및 안전문화 활성화를 위한 자원 제공 등을 포함하는 환자안전문화 프로그램을 마련하고 시행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "[부록1. 안전문화 행동강령(Code of Conduct)]을 개발하고 공표하며, 허용되지 않은 행동을 파악하여 개선한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "안전문화에 대해 모든 직원에게 교육하고, 관련 정보를 공유한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "안전문화를 증진하기 위한 환자안전세미나 등의 활동을 지원한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "환자안전사건 및 안전문화 관련사항은 세브란스병원 내규 [7.3.1. 환자안전사건 관리] 절차에 따라 보고하고 관리한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "환자안전사건은 전화, 방문, 전산 및 서면보고를 통해 보고되며, 보고자가 보고로 인해 불이익을 받거나 보복을 당하지 않도록 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "보고된 내용은 프로세스에 따라 적정 시간 안에 검토되며, 분석결과에 따른 개선활동을 진행한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 3,
      "내용": "주기적으로 질지표 또는 설문지 등을 활용하여 행동강령의 이행수준 및 안전문화 관련사항을 모니터링하고, 결과를 개선활동에 반영한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "안전문화 향상을 위해 허용되지 않은 행동을 유도하는 시스템 원인을 분석하고, 결과에 따라 안전문화 증진전략을 수립하여 시행하며, 그 효과를 평가한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "안전문화 활동내용은 의료질향상 및 환자안전위원회와 병원운영위원회에 보고되며, 의료질향상 및 환자안전위원회와 병원운영위원회는 검토 내용을 병원 전체 차원의 질향상과 환자안전 프로그램과 통합한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 20,
