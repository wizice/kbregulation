    "조문내용": [
      {
        "seq": 1,
        "레벨": 0,
        "내용": "3.1. 부서 조직 및 운영",
        "번호": "",
        "관련이미지": []
      },
      {
        "seq": 2,
        "레벨": 1,
        "내용": "(목적)",
        "번호": "1.",
        "관련이미지": []
      },
      {
        "seq": 3,
        "레벨": 2,
        "내용": "병원 부서를 효율적으로 조직, 관리하고 각 부서의 업무 범위를 정의하여 세브란스병원 목표와 연계한 부서운영 계획을 수립하고 조직기능의 전문화와 체계를 확립하여 부서의 원활한 운영과 체계적인 관리를 수행하기 위함이다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 4,
        "레벨": 1,
        "내용": "(정의)",
        "번호": "2.",
        "관련이미지": []
      },
      {
        "seq": 5,
        "레벨": 1,
        "내용": "(절차)",
        "번호": "3.",
        "관련이미지": []
      },
      {
        "seq": 6,
        "레벨": 2,
        "내용": "세브란스병원 조직",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 7,
        "레벨": 3,
        "내용": "세브란스병원에는 병원장, 진료부원장, 연구부원장, 간호부원장, 진료혁신부원장, 기획관리실장, 세브란스헬스체크업의원 원장, 사무국장, 원목실장을 두며, 병원장 직속 기관으로 기획관리실, 원목실 및 제위원회가 있다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 8,
        "레벨": 4,
        "내용": "병원장은 병원의 진료 및 행정업무를 담당하며, 각 부원장과 사무국장은 병원장을 보좌한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 9,
        "레벨": 4,
        "내용": "진료부원장 산하에는 진료부서, 전문센터, 전문클리닉, 교육수련부, 진료협력센터, 첨단유전체센터, 방사선안전관리실, 감염관리실이 있다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 10,
        "레벨": 4,
        "내용": "연구부원장 산하에는 약무국, 영양팀, 의무기록팀, 사회사업팀, 물류팀, 의학공학과, 세포치료센터, 인체유래물은행, 임상연구관리실이 있다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 11,
        "레벨": 4,
        "내용": "간호부원장은 간호국을 담당하며, 간호부원장을 보좌하는 간호1국장, 간호2국장, 간호팀이 있다.",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 12,
        "레벨": 4,
        "내용": "진료혁신센터에는 진료혁신부원장을 보좌하는 1부센터장과 2부센터장을 두고, 그 산하에는 환자경험팀, 환자안전팀이 있다.",
        "번호": "(마)",
        "관련이미지": []
      },
      {
        "seq": 13,
        "레벨": 4,
        "내용": "기획관리실은 기획업무에 관한 사항을 관장하며, 기획관리실장을 보좌하는 기획부실장을 두고, 그 산하에 기획예산팀이 있다.",
        "번호": "(바)",
        "관련이미지": []
      },
      {
        "seq": 14,
        "레벨": 4,
        "내용": "사무국장 산하에는 사무팀, 입원원무팀, 외래원무팀, 보험심사팀, 법무팀이 있다.",
        "번호": "(사)",
        "관련이미지": []
      },
      {
        "seq": 15,
        "레벨": 4,
        "내용": "원목실은 기독교 복음을 교직원과 내원환자에게 전하고 이에 관련한 행정업무를 담당한다.",
        "번호": "(아)",
        "관련이미지": []
      },
      {
        "seq": 16,
        "레벨": 4,
        "내용": "제위원회는 병원 운영에 관한 전반적인 중요사항을 심의하기 위해 구성되며, 기타 운영에 관한 제반사항은 제위원회 운영규칙에 따른다.",
        "번호": "(자)",
        "관련이미지": []
      },
      {
        "seq": 17,
        "레벨": 3,
        "내용": "세브란스병원에는 전문의료기관으로 재활병원, 심장혈관병원, 안과병원, 어린이병원, 연세암병원이 있다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 18,
        "레벨": 3,
        "내용": "기타 부서 조직에 관한 제반사항은 의료원 직제규정에 따른다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 19,
        "레벨": 2,
        "내용": "부서 리더의 역할과 책임",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 20,
        "레벨": 3,
        "내용": "병원의 사명과 비전, 중점목표 및 안전문화에 따라 업무 범위를 계획한다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 21,
        "레벨": 3,
        "내용": "병원 규모 및 특성, 부서 업무의 복잡성과 직원소를 고려하여 부서를 조직하고 운영하며, 직원들을 지휘·감독한다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 22,
        "레벨": 3,
        "내용": "부서 현황 파악과 자원(공간, 인력, 장비 등) 필요 시 병원 정책과 절차에 따라 추가 요청하며, 부족한 자원에 대한 대응계획을 가진다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 23,
        "레벨": 3,
        "내용": "각 부서 내용의 불필요한 중복 및 누락을 피하기 위해 부서 내 또는 타부서와 전문적인 의사소통 및 안전문화 활동을 지원한다.",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 24,
        "레벨": 3,
        "내용": "병원 내규, 임상가이드라인, 프로토콜, 절차, 병원 차원의 질향상 및 환자안전 활동 등에 대한 계획 수립, 개발 및 관련활동을 참여하고 지원한다.",
        "번호": "5)",
        "관련이미지": []
      },
      {
        "seq": 25,
        "레벨": 3,
        "내용": "부서 직원들의 윤리적 업무 수행을 감독하며, 윤리적 사항에 대한 관련활동을 지원한다.",
        "번호": "6)",
        "관련이미지": []
      },
      {
        "seq": 26,
        "레벨": 3,
        "내용": "부서에서 제공하는 서비스의 질을 관리한다.",
        "번호": "7)",
        "관련이미지": []
      },
      {
        "seq": 27,
        "레벨": 3,
        "내용": "부서 직원의 자격요건을 정하고 자격을 갖춘 자를 확보하며, 부서 오리엔테이션과 직무교육을 시행한다.",
        "번호": "8)",
        "관련이미지": []
      },
      {
        "seq": 28,
        "레벨": 3,
        "내용": "부서 리더는 직원들과 협의하여 부서운영 계획을 수립하며, 연례평가를 통하여 책임사항 이행여부를 평가하고, 다음 계획 시 반영한다.",
        "번호": "9)",
        "관련이미지": []
      },
      {
        "seq": 29,
        "레벨": 2,
        "내용": "부서 리더의 자격",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 30,
        "레벨": 3,
        "내용": "각 부서는 해당 업무를 감독하기 위한 교육, 훈련, 경험 등의 자격요건을 갖춘 1인 이상의 리더에 의해 관리되며, 부서 리더의 자격요건 및 직무는 직무기술서에 따른다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 31,
        "레벨": 2,
        "내용": "부서 리더는 병원 전체 공통 문서형식을 사용하여 부서 서비스 범위(Scope of Service)를 작성하며, 병원운영위원회는 환자의 요구에 맞는 서비스를 파악하여, 이에 따라 부서 서비스 범위를 심의, 승인한다.",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 32,
        "레벨": 2,
        "내용": "부서 리더는 다음의 내용을 포함하여 각 부서에서 제공하는 서비스 범위(Scope of Service)를 정의한다.",
        "번호": "5)",
        "관련이미지": []
      },
      {
        "seq": 33,
        "레벨": 3,
        "내용": "업무의 범위: 부서의 권한과 책임이 있는 업무의 범위",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 34,
        "레벨": 3,
        "내용": "업무의 대상: 업무의 종류",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 35,
        "레벨": 3,
        "내용": "부서의 인력(필요 인력의 자격요건, 인원 수 등)",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 36,
        "레벨": 4,
        "내용": "간호 인력: 병동 단위. 팀단위, 전체 간호국 단위로 산출",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 37,
        "레벨": 4,
        "내용": "전공의가 있는 진료과: 수련규칙에 준함",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 38,
        "레벨": 3,
        "내용": "업무절차(서비스 제공방법)",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 39,
        "레벨": 4,
        "내용": "대상: 야간 근무를 하는 모든 부서",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 40,
        "레벨": 4,
        "내용": "내용: 야간근무 매뉴얼, 근무일정표 작성 원칙 등",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 41,
        "레벨": 3,
        "내용": "기타 자원의 배분과 효율적 사용",
        "번호": "5)",
        "관련이미지": []
      },
      {
        "seq": 42,
        "레벨": 2,
        "내용": "부서의 운영과 관리를 위하여 다음의 내용을 포함한 부서 운영계획을 수립 및 운영하고 계획에 따른 수행여부를 주기적으로 평가한다.",
        "번호": "6)",
        "관련이미지": []
      },
      {
        "seq": 43,
        "레벨": 3,
        "내용": "부서의 업무 범위와 현안",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 44,
        "레벨": 3,
        "내용": "구체적인 실행전략 또는 목표",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 45,
        "레벨": 3,
        "내용": "업무수행에 대한 주기적인 평가",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 46,
        "레벨": 2,
        "내용": "부서 리더는 해당 직원에게 부서 서비스 범위(Scope of Service)에 대한 오리엔테이션을 제공한다.",
        "번호": "7)",
        "관련이미지": []
      },
      {
        "seq": 47,
        "레벨": 2,
        "내용": "부서 서비스 범위(Scope of Service) 조정이 필요한 경우, 관련 사항에 대해 병원운영위원회 승인을 받는다.",
        "번호": "8)",
        "관련이미지": []
      },
      {
        "seq": 48,
        "레벨": 2,
        "내용": "각 부서 서비스 범위(Scope of Service)는 그룹웨어 게시판 등에 게시하여 공유한다.",
        "번호": "9)",
        "관련이미지": []
