{
  "문서정보": {
    "규정명": "3.2.5.1. 신체보호대 적용 환자 관리",
    "내규종류": "규정",
    "규정표기명": "3.2.5.1. 신체보호대 적용 환자 관리",
    "제정일": "2006.07.",
    "최종개정일": "2025.03.25.",
    "최종검토일": "2025.03.25.",
    "담당부서": "의료질향상 및 환자안전위원회",
    "유관부서": "간호국, 중환자실운영위원회",
    "관련기준": [
      "4주기 의료기관인증기준: 3.2.5 신체보호대 및 격리·강박",
