  },
  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.5.1. 신체보호대 적용 환자 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자의 권리, 존엄성 및 안전과 안녕을 위해 신체보호대가 부적절하게 사용되는 것을 막고, 임상적으로 꼭 필요하다고 판단되는 상황에서만 제한적으로 사용될 수 있도록 적절한 진료 지침 및 절차를 제공하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "신체보호대(Restraint): 환자 또는 타인을 상해로부터 보호하기 위해 수동적 방법이나 물리적 장치 및 기구를 사용하여 전신 혹은 신체의 일부분의 움직임을 제한하는 것을 말한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "신체보호대 사용 기준",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "사용원칙",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "다른 치료적 접근전략을 사용할 수 있는지 검토하고, 다른 대안의 사용이 불가능하거나 실패한 경우 적용한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "최소한의 시간 동안 적용한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "신체보호대 사용 사유가 해소된 경우 중단한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "적용 기준",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "치료 시 의식 또는 인지기능의 장애로 부상의 위험이 크거나 치료환경 유지에 심각한 어려움이 있는 경우",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 5,
      "내용": "비계획적 인공기도 제거(Unplanned extubation), 각종 Line 및 Tube 등을 제거할 우려가 있는 경우",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 5,
      "내용": "특정한 자세로 안정을 요하는 환자가 지속적으로 자세변경 및 침대 밖으로 나오려고 하는 경우",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "정신건강의학과, 소아정신과 환자의 경우 세브란스병원 내규 [3.2.5.2. 정신건강의학과 격리 및 강박]에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "수술, 검사, 처치 등을 위해 일시적으로 신체보호대를 적용하는 경우는 처방 및 동의서 등 적용 규정에서 제외한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "신체보호대 종류 및 사용 방법",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "신체보호대의 종류: 재킷, 벨트, 장갑 또는 손, 팔꿈치, 사지, 전신 보호대 등",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "사용방법: [부록1. 간호국 업무지침서-신체보호대 사용 시 간호]에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "적용 부위: 허리, 흉부, 손목/발목, 팔꿈치, 손, 전신",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "응급상황에서 쉽게 풀 수 있거나 즉시 자를 수 있는 방법을 사용한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 2,
      "내용": "신체보호대 사용 절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "의사의 처방",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "신체보호대의 적용은 의사의 처방을 따른다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "신체보호대 처방 시 신체보호대 사용 사유, 방법, 신체부위, 종류 등을 포함하여 처방한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "이후 24시간마다 신체보호대 처방을 하며, 구두처방 및 PRN으로 처방하지 않는다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "신체보호대 적용 후 환자의 증상, 행동 조절 및 안정을 위하여 의사의 처방에 따라 약물을 투여할 수 있다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "신체보호대 적용 시 적용 부위, 적용 사유 등을 기록한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "환자 또는 보호자 설명 및 동의서 작성",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "신체보호대 적용 전 환자 및 보호자에게 적용사유, 방법, 신체부위 및 종류 등에 대해 설명하고 동의를 받는다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "동의서에는 처방한 의사와 설명한 의료인의 이름 및 처방/설명 날짜, 보호자가 대신 동의하게 된 사유 등이 포함된다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "불가피한 경우 적용 후 설명하고 동의를 받는다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "신체보호대 사용 환자의 주기적 관찰, 평가, 기록",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "신체보호대 적용 부위의 사지감각, 피부색, 피부온도, 움직임 등을 2시간마다 평가하여 기록한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "8시간마다 신체보호대 적용 지속 여부를 재평가하여 기록한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 4,
      "내용": "신체보호대 제거 시 기록한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 3,
      "내용": "부작용 발생 예방을 위한 활동",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "안전한 환경을 제공한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "필요 시 ADL (Activities of Daily Living)을 보조한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "신체보호대 적용 부위 피부간호를 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 3,
      "내용": "부작용 발생 시 의사에게 알리고 처방에 따라 적절한 중재를 시행한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "소아환자도 동일하게 적용한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 2,
      "내용": "관련 의료진은 신체보호대 적용 환자관리에 대한 교육을 받는다.",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
