    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "전용용기 사용방법",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "의료폐기물은 발생한 때부터 전용용기에 넣어 밀폐포장하여 보관기간내 배출한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "일반쓰레기에 의료폐기물, 음식물이 혼합되지 않도록 “분리배출”을 철저히 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "전용용기 겉면『취급 시 주의사항』에 다음 사항을 반드시 기재한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 5,
      "내용": "사용개시연월일자, 배출자, 폐기물 종류, 수거일자, 중량",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 5,
      "내용": "이 폐기물은 감염의 위험이 있으므로 주의하여 취급하시기 바랍니다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "전용용기는 환경부장관이 고시하는 검사기준에 따라 검사한 용기만 사용하여야 한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "전용용기는 2중 구조로 내부는 오렌지색 비닐 외부는 백색골판지로 구성되어 있다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "의료폐기물 전용용기는 재사용하여서는 아니되며 또한 타용도로 사용할 수 없다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "의료폐기물은 위생적이고 안전하게 처리하여 2차 감염예방과 폐기물관리법을 준수한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "의료폐기물의 수집, 운반",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "외래, 병동 등의 의료폐기물은 전용용기 사용하고 파손여부를 확인한 후 전담수거 요원이 순회하여 전용운반용카로 수거 운반하되 이때 폐기물을 노출하여서는 아니 된다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "의료폐기물은 생활폐기물과 섞이지 않도록 관리하며 밀폐포장한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "의료폐기물 운반 시 개인보호구를 착용한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 2,
      "내용": "의료폐기물의 보관",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "의료폐기물은 발생한 때부터 종류별로 전용용기에 넣어 전용 보관창고에 보관한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "보관창고는 내부가 보이지 않는 구조로 외부인의 출입을 제한한다(관계자 외 출입을 금지함).",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "보관창고 및 냉동(냉장)시설에는 보관 중인 의료폐기물의 종류, 보관량, 보관기간 등을 기재한 표시판을 설치하여야 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "보관창고·냉동(냉장)고에는 보호구, 소독약품·장비를 비치하고 주 1회 이상 약물소독을 실시한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "의료폐기물 보관 시 보관시설과 보관기간 등 보관기준을 준수한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 2,
      "내용": "의료폐기물의 처분",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "위탁업체 선정",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "폐기물관리법 시행규칙 제14조 [별표 5] 폐기물의 처리에 관한 구체적 기준 및 방법, 제28조 제6항 [별표 7] 폐기물처리업의 시설․장비․기술능력의 기준 등 규정에 적합한 허가업체",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "의료폐기물은 소각처리시설로 허가되었는지 적합여부를 검토한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 4,
      "내용": "의료폐기물은 3자 계약(배출자, 운반자, 처리자)하여 위탁처리 하여야 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 3,
      "내용": "위탁처리",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 4,
      "내용": "의료폐기물은 전용용기에 넣어 밀폐 포장된 상태로 전용 운반차량으로 운반한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 4,
      "내용": "의료폐기물 처리시 지정된 장소에서 종류별로 RFID 전자 TAG을 부착하고 환경부 폐기물 적법처리 전산시스템을 통한 배출 신고 후 위탁처리 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 4,
      "내용": "조직물(적출물)은 전용냉동고에 보관하며, 10일 이내에 의료폐기물 처리 위탁업체로 하여금 처리하도록 한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 41,
      "레벨": 4,
      "내용": "위의 각 사항은 관리대장에 기록 비치하고 위탁수량을 정확히 기록관리하고 외부로 임의 반출되어서는 안 된다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 42,
      "레벨": 2,
      "내용": "의료폐기물 관리 프로그램",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 43,
      "레벨": 3,
      "내용": "모니터링",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 44,
      "레벨": 4,
      "내용": "의료폐기물 분리배출 점검은 반기별 1회(연 2회) 정기적으로 실시한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 45,
      "레벨": 4,
      "내용": "의료폐기물의 감독결과는 시설안전관리위원회에 보고한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 46,
      "레벨": 3,
      "내용": "교육",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 47,
      "레벨": 4,
      "내용": "점검 시 개선이 필요한 부분은 차기 교육에 내용을 포함한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 48,
      "레벨": 4,
      "내용": "현장 점검을 통한 개선교육 실시 및 직무교육에 반영한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 49,
      "레벨": 3,
      "내용": "질관리",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 50,
      "레벨": 4,
      "내용": "환경부 적법처리 시스템을 통한 의료폐기물 처리현황을 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 51,
      "레벨": 4,
      "내용": "실태점검 및 데이터 결과를 포함한 의료폐기물 취급관리 개선사항 및 지표관리현황을 위원회(시설안전관리위원회, 의료질향상 및 환자안전위원회, 병원운영위원회)에 연 2회 보고한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 52,
      "레벨": 3,
      "내용": "의료폐기물 관리 프로그램 연간 계획 및 평가",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 53,
      "레벨": 4,
      "내용": "의료폐기물의 프로그램 수행결과, 직원교육, 개선사항 등의 진행사항을 연 2회 시설안전관리위원회에 보고하고, 보완사항은 지속적인 관리계획에 포함시켜 익년도 연간 프로그램 계획에 반영한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 54,
      "레벨": 2,
      "내용": "의료폐기물 책임영역",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 55,
      "레벨": 3,
      "내용": "관리부서: 총괄관리는 시설관리팀에서 주관하며, 각 병원 사무팀 및 의료폐기물 발생 부서인 진료실, 치료실, 병동, 응급실, 수술실, 중환자실 등 각 실에서 부서별 관리를 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 56,
      "레벨": 3,
      "내용": "관리책임자",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 4,
      "내용": "총괄 관리책임자: [정] 시설관리팀장 [부] 환경관리파트장(당연직)",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 4,
      "내용": "부서별 관리책임자: [정] 팀장(부서장) [부] 파트장(당연직)",
      "번호": "(2)",
      "관련이미지": []
    },
    {
