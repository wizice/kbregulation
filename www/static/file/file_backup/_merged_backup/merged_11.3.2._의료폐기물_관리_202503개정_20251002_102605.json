        "관련이미지": []
      },
      {
        "seq": 18,
        "레벨": 4,
        "내용": "전용용기는 환경부장관이 고시하는 검사기준에 따라 검사한 용기만 사용하여야 한다.",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 19,
        "레벨": 4,
        "내용": "전용용기는 2중 구조로 내부는 오렌지색 비닐 외부는 백색골판지로 구성되어 있다.",
        "번호": "(마)",
        "관련이미지": []
      },
      {
        "seq": 20,
        "레벨": 4,
        "내용": "의료폐기물 전용용기는 재사용하여서는 아니되며 또한 타용도로 사용할 수 없다.",
        "번호": "(바)",
        "관련이미지": []
      },
      {
        "seq": 21,
        "레벨": 4,
        "내용": "의료폐기물은 위생적이고 안전하게 처리하여 2차 감염예방과 폐기물관리법을 준수한다.",
        "번호": "(사)",
        "관련이미지": []
      },
      {
        "seq": 22,
        "레벨": 2,
        "내용": "의료폐기물의 수집, 운반",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 23,
        "레벨": 3,
        "내용": "외래, 병동 등의 의료폐기물은 전용용기 사용하고 파손여부를 확인한 후 전담수거 요원이 순회하여 전용운반용카로 수거 운반하되 이때 폐기물을 노출하여서는 아니 된다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 24,
        "레벨": 3,
        "내용": "의료폐기물은 생활폐기물과 섞이지 않도록 관리하며 밀폐포장한다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 25,
        "레벨": 3,
        "내용": "의료폐기물 운반 시 개인보호구를 착용한다.",
