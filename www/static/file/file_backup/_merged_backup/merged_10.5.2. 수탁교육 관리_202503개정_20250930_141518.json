  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "5.2. 수탁교육 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원 내 교육(실습, 연수, 견학 등)을 희망하는 피교육자에게 교육 장소와 편의시설을 제공하며, 운영에 관한 세부 사항을 규정하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "수탁교육: 병원이 외부로부터 요청받아 제공하는 교육으로, 학생 실습, 연수, 견학 등을 포함한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "주관부서: 인재개발팀은 내규 및 공통 절차에 관한 사항을 담당하며, 실질적인 운영과 행정업무는 시행부서에서 담당한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "교육 신청 및 승인",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "병원이나 학교에서 교육을 받고자 하는 개인 또는 기관의 장은 학생실습 협약서, 연수 및 견학 요청 공문과 [부록1. 수탁교육 의뢰서], [부록2. 수탁생 면역력 점검표]등을 작성하여 단위기관장의 승인을 받아야 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "병원이나 학교에서 교육을 받고자 하는 개인 또는 기관은 실제 견학을 시행하는 부서에 협조요청을 해야 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "교육생 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "명찰 발급 절차",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "시행 부서는 교육생이 50명 이상일 경우 교육 15일 이전, 50명 미만일 경우 교육 7일 이전에 사무팀에 명찰 제작을 요청한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "명찰 제작 요청 시 공문(소속기관, 교육기간, 교육부서, 직종 등을 표기한 명단 포함)과 교육생 사진을 사무팀에 제출하며, 명찰에는 교육부서, 교육기간, 직종, 교육의뢰 기관을 기재한다. 단, 1일 이하 단기교육인 경우는 제외한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "명찰 배부 및 반납",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "시행 부서는 수탁교육 의뢰서와 교육생 신원을 확인한 후 명찰을 배부한다. 단, 1일 이하 단기 교육은 “교육(Tour/Training/Practicum)” 표기된 명찰을 사용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "시행 부서는 교육 종료 후 명찰을 반납받아 폐기한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 2,
      "내용": "교육비 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "[부록4. 수탁교육비 관리지침]에 따라 교육비를 받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "오리엔테이션 및 교육 진행",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "교육생은 오리엔테이션을 통해 의료원 소개, 병원생활 안내, 환자 정보 보호, 감염 관리, 소방 안전 등에 대해 교육을 받는다. 다만, 부서의 특성에 따라 항목을 추가할 수 있다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "시행부서는 오리엔테이션 참석자 명단을 3년간 보관한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "교육생을 대상으로 병원 내부 규정에 대한 설명을 하고, [부록3. 수탁교육 동의서]에 서명을 받는다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "준수 사항",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "교육생이 교육 기간 중 병원 장비 또는 비품을 파손하거나 분실한 경우, 이를 변상하여야 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "교육 기간 중 병원 규정을 위반한 경우, 수탁교육을 중단 및 취소할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "외국인 연수생의 경우, 세브란스병원 내규 [10.5.3. 수탁교육 관리 - 의료원 외국인 연수생]에 따른다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "수탁교육 의뢰서",
