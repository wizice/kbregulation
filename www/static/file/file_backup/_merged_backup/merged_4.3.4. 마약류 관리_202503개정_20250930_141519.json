  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.4. 마약류 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "마약류의 체계적인 관리 및 마약류 사고 발생 감소를 위하여 필요한 사항을 효율적으로 규정하고 이를 준수 및 시행함으로써 마약류를 적정하고 안전하게 사용하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "마약류: 마약, 향정신성의약품(이하 ‘향정’이라 함) 및 대마를 말한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "모든 마약류는「마약류 관리에 관한 법률」에 의거하여 보관, 보급, 취급, 폐기한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "원내에서 처방되는 모든 마약류는 마약류관리자(약무팀장 포함 총 4인)의 지시, 감독에 따라 구입, 저장, 조제, 투약 관리되며, [부록1. 세브란스병원 마약류 관리지침]에 따른다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "마약류 처방",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "주사용 마약류는 1회 용량으로 처방한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "외용마약은 1회 용량으로 처방한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "입원환자의 경구용 마약의 처방은 1일 단위로 처방한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "외래환자 및 퇴원환자의 경구용 및 외용 마약의 처방은 식품의약품안전처의 허가사항을 따른다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "마약류 조제",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "마약류의 조제는 의약품 일반의 조제 지침을 따른다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "마약류 운반",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "입원환자의 마약류 조제 및 불출 시 약사는 마약수불대장에 서명한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "마약을 수령한 자는 수령 즉시 마약수불대장에 인수 서명을 입력한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "마약류 운반 시, 파손 및 분실 예방을 위한 운반용기를 사용하며 보관조건을 준수하여 안전하게 운반한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "마약류 및 임시마약류 보관 및 관리",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "마약류 및 임시마약류의 저장시설은 의료기관 내 일반인이 쉽게 발견할 수 없는 장소에 보관한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "마약은 이중으로 잠금장치(철제와 동등 이상의 견고한 재질로 만들어진 금고 포함)가 된 철제금고에 보관한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "향정, 예고임시마약류 또는 임시마약류는 잠금장치가 설치된 장소에 보관한다. 단, 향정의 경우 조제를 목적으로 업무시간 중 조제대에 비치하는 경우는 제외한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "사고마약류 등의 처리",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "각 부서에서 다음에 해당하는 사고가 발생할 때에는 [부록2. 사고마약류 관련 서식]을 작성하여 약무국에 지체없이 보고한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "재해로 인한 상실",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "분실 또는 도난",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "변질·부패 또는 파손",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "약무국은 그 사유가 발생한 것을 안 날부터 5일 이내에 그 사실을 증명하는 서류를 첨부하여 관할 보건소에 제출한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 2,
      "내용": "마약류 취급보고제도에 의거하여 마약류 구입, 사용, 폐기, 조제, 투약 전 과정에 대하여 마약류관리자가 ‘마약류 통합관리시스템(NIMS, Narcotics Information Management System)’을 이용하여 식품의약품안전처장에게 보고한다. (마약류 관리에 관한 법률 제 11조)",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "마약류 관리 직원은 연 1회 마약류적정사용 및 마약류관리에 관한 법률 준수 서약서를 작성하고 이를 준수한다.",
      "번호": "9.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 2,
      "내용": "마약류 취급 관련 의료진은 연 1회 마약류 적정사용과 관련된 교육을 이수한다.",
      "번호": "10.",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 2,
      "내용": "세브란스병원 마약류 관리지침",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "사고마약류 관련 서식(마약류 파손 보고서, 환자반납 발생 보고서)",
      "번호": "2.",
      "관련이미지": []
    },
    {
