    {
      "seq": 1,
      "레벨": 0,
      "내용": "2.1.3. 중증응급환자 이송서비스 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "환자에게 안전한 이송 수단을 제공하고, 환자 이송에 사용되는 이송 차량 및 관련 직원의 적절한 관리를 위함이다",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "이송 차량 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "구급차 운영 및 의료장비, 구급의약품의 유지관리는 관련 법령을 준수한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "구급차 내 장비, 물품, 약물, 감염상태에 대해 관련 법률에 의거하여 매일 점검하고 관리한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "구급차 감염관리는 [감염관리지침]에 따라 시행한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "사용 전 물품과 사용 후 물품은 보관 용기를 따로 구분하여 사용하고, 응급 상황에서 혼동하는 일이 없도록 공간을 분리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "구급차 내에서 감염관리를 위해 필요한 물품은 보관상태와 유효기간을 매일 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "후송 중 구급차 내 환경이 환자의 혈액, 체액, 분비물 등으로 오염된 경우는 환경 소독제를 이용하여 소독한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "후송이 완료되면 폐기물과 소독물품을 정리한다. 내부를 환기시키고 소독제로 닦아낸다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "직원 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "자격",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "면허를 소지한 의사, 간호사",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "응급구조사 자격증을 소지한 응급구조사",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "제 1종 운전면허를 소지한 구급차 운전기사",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "교육",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "면허와 자격 유지를 위하여 보수교육을 이수한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "세브란스병원 내규 [10.5.1. 직원교육] 및 [9.1.3. 위탁서비스 관리]에 따라 필수교육을 이수한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "위탁업체의 관리",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "본원 구급차의 운행이 어려운 경우 위탁업체 구급차를 연계한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "위탁업체는 소유한 구급차를 관련 법률에 의거하여 매일 점검한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "세브란스병원 내규 [9.1.3. 위탁서비스 관리]에 따라 관리부서는 분기별 환자 이송 차량 관리 성과를 모니터링하고, 그 결과를 경영진에 보고한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
