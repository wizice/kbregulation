      {
        "seq": 23,
        "레벨": 3,
        "내용": "강박 도구 관리 방법",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 24,
        "레벨": 4,
        "내용": "환자의 신체손상을 방지할 수 있는 안전한 재질(면소재 혹은 자석 억제대)의 강박 도구를 사용한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 25,
        "레벨": 4,
        "내용": "강박 도구는 매 환자마다 세탁이 완료된 억제대를 사용하며 사용 중 오염되었을 경우 새것으로 교체한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 26,
        "레벨": 2,
        "내용": "격리·강박 시행 절차",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 27,
        "레벨": 3,
        "내용": "정신건강의학과 전문의의 지시",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 28,
        "레벨": 4,
        "내용": "격리 및 강박의 적용은 전문의 지시 하에 의사의 처방에 따라 시행하고 해제한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 29,
        "레벨": 4,
        "내용": "의사는 지속적으로 격리 및 강박 적용이 필요하다고 판단되는 경우 적용 시마다 처방한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 30,
        "레벨": 4,
        "내용": "격리 및 강박 시행 후 환자의 증상, 행동 조절 및 안정을 위하여 의사의 처방에 따라 약물을 투여할 수 있다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 31,
        "레벨": 3,
        "내용": "설명 및 동의: 격리·강박 적용 전 환자 또는 보호의무자에게 적용사유 및 적용방법 등에 대해 설명하고 동의서를 받으며 불가피한 경우 적용 후 설명하고 동의서를 받는다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 32,
        "레벨": 3,
        "내용": "공간: 병동에 안정실에서 시행한다. 안정실은 안전을 위해 산소 공급 코크나 흡입 코크 장치 등, 무엇인가를 걸 수 있는 구조물이 벽에 없어야 하며, 벽은 쿠션 장치가 되어 있어야 한다. 안정실은 안전상의 위험요소가 있지 않은지 격리·강박 전 혹은 후에 그리고 수시로 점검한다. 예외적인 상황인 경우(예, 초고령 환자, 보호자 동반 등)에는 의료진의 판단과 보호자 동의 하에 1인실에서 시행할 수 있다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 33,
        "레벨": 3,
        "내용": "수행 직원: 환자 및 직원의 상해를 방지하기 위해 의료인(의사, 간호사) 포함 최소 2명 이상의 훈련된 직원들이 수행한다.",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 34,
        "레벨": 3,
        "내용": "시행시간",
        "번호": "5)",
        "관련이미지": []
      },
      {
        "seq": 35,
        "레벨": 4,
        "내용": "격리·강박의 1회 처방 최대 허용시간",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 36,
        "레벨": 5,
        "내용": "성인: 격리 12시간, 강박 4시간 이하",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 37,
        "레벨": 5,
        "내용": "19세 미만: 격리 6시간, 강박 2시간 이하",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 38,
        "레벨": 4,
        "내용": "격리·강박의 처방은 전문의의 평가에 의해 연장할 수 있으나 1회 최대 허용시간의 2배수의 시간을 넘기지 않는다. 즉, 성인 기준 격리는 연속 24시간, 강박은 연속 8시간을 초과하여 시행하지 않는다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 39,
        "레벨": 4,
        "내용": "단, 위험성이 뚜렷하게 높아 연속 최대 허용시간을 초과하여 격리나 강박이 필요한 경우 정신건강의학과 전문의의 대면평가를 거쳐 추가로 연장할 수 있다. 이 경우 다학제평가팀의 사후회의를 통해 해당 격리·강박 과정의 적합성을 검토하고 이를 별도의 회의록에 기록하여 보관한다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 40,
        "레벨": 4,
        "내용": "다학제평가팀",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 41,
        "레벨": 5,
        "내용": "다학제팀의 주요 안건은 격리·강박 과정에 대한 사후적합성 검토이며, 필요 시 격리·강박 관리 사항에 대하여 논의할 수 있다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 42,
        "레벨": 5,
        "내용": "구성: 위원장 1명(임상과장), 부위원장 1명(교수), 위원 3명(의국장, 병동파트장, 사회사업사) 등 5명의 운영위원으로 구성된다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 43,
        "레벨": 5,
        "내용": "회의는 위험성이 뚜렷하게 높아 격리·강박에 대한 최대 허용시간(1회 최대 허용시간의 2배수)을 초과하여 격리나 강박을 시행한 경우 사후에 진행한다.",
        "번호": "ⅲ)",
        "관련이미지": []
      },
      {
        "seq": 44,
        "레벨": 5,
        "내용": "회의의 개회는 환자의 진료 과정에 참여하거나 관찰할 수 있는 의료진을 포함하여 환자의 보호자가 요청할 수 있으며 위원장은 이에 따라 회의를 개회한다.",
        "번호": "ⅳ)",
        "관련이미지": []
      },
      {
        "seq": 45,
        "레벨": 3,
        "내용": "격리 및 강박을 시행할 시 아래 내용을 격리·강박 기록지에 작성하도록 한다.",
        "번호": "6)",
        "관련이미지": []
      },
      {
        "seq": 46,
        "레벨": 4,
        "내용": "시행일시, 지시자 및 수행자의 이름과 서명, 참여자명",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 47,
        "레벨": 4,
        "내용": "해제일시, 지시자 및 수행자의 이름과 서명, 참여자명",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 48,
        "레벨": 4,
        "내용": "격리·강박이 필요한 이유",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 49,
        "레벨": 4,
        "내용": "격리·강박이 필요한 구체적 상황(필요시 기재)",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 50,
        "레벨": 4,
        "내용": "격리·강박 모니터링",
        "번호": "(마)",
        "관련이미지": []
      },
      {
        "seq": 51,
        "레벨": 4,
        "내용": "격리·강박 연장 시 이유 및 지시자, 수행자, 시행 및 해제 시간",
        "번호": "(바)",
        "관련이미지": []
      },
      {
        "seq": 52,
        "레벨": 3,
        "내용": "모니터링",
        "번호": "7)",
        "관련이미지": []
      },
      {
        "seq": 53,
        "레벨": 4,
        "내용": "격리",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 54,
        "레벨": 5,
        "내용": "의료진은 최초 15분 이내 방문하여 직접 환자의 정신적, 신체적 상태, 위험행동 여부를 관찰하고 1시간마다 관찰 및 평가를 시행한다. (단, 진정약물을 투여했을 경우 최초 5분 이내 활력징후를 평가)",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 55,
        "레벨": 4,
        "내용": "강박",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 56,
        "레벨": 5,
        "내용": "의료진은 최초 15분 이내 방문하여 직접 환자의 정신적, 신체적 상태를 관찰하고 30분마다 관찰 및 평가를 시행한다. (단, 진정약물을 투여했을 경우 최초 5분 이내 활력징후를 평가)",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 57,
        "레벨": 5,
        "내용": "신체보호대 적용 시 적용한 부위의 사지감각, 피부색, 피부온도와 움직임을 평가하여 기록하고 이후 1시간마다 사지감각, 피부색, 피부온도와 움직임, 활력징후, 자세, 활동, 외상, 위험행동 여부를 평가하여 기록한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 58,
        "레벨": 4,
        "내용": "격리·강박 중 환자의 상태를 모니터를 통해 수시로 확인한다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 59,
        "레벨": 3,
        "내용": "부작용 발생 예방을 위한 활동",
        "번호": "8)",
        "관련이미지": []
      },
      {
        "seq": 60,
        "레벨": 4,
        "내용": "안전한 환경을 유지한다.",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 61,
        "레벨": 4,
        "내용": "필요 시 ADL (Activities of Daily Living)을 보조한다.",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 62,
        "레벨": 4,
        "내용": "2시간마다 강박을 풀고 사지운동을 시켜주고, 필요 시 자세를 변경한다.",
