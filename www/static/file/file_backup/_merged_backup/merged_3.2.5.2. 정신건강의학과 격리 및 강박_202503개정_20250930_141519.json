      "seq": 56,
      "레벨": 5,
      "내용": "의료진은 최초 15분 이내 방문하여 직접 환자의 정신적, 신체적 상태를 관찰하고 30분마다 관찰 및 평가를 시행한다. (단, 진정약물을 투여했을 경우 최초 5분 이내 활력징후를 평가)",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 57,
      "레벨": 5,
      "내용": "신체보호대 적용 시 적용한 부위의 사지감각, 피부색, 피부온도와 움직임을 평가하여 기록하고 이후 1시간마다 사지감각, 피부색, 피부온도와 움직임, 활력징후, 자세, 활동, 외상, 위험행동 여부를 평가하여 기록한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 58,
      "레벨": 4,
      "내용": "격리·강박 중 환자의 상태를 모니터를 통해 수시로 확인한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 59,
      "레벨": 3,
      "내용": "부작용 발생 예방을 위한 활동",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 60,
      "레벨": 4,
      "내용": "안전한 환경을 유지한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 61,
      "레벨": 4,
      "내용": "필요 시 ADL (Activities of Daily Living)을 보조한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 62,
      "레벨": 4,
      "내용": "2시간마다 강박을 풀고 사지운동을 시켜주고, 필요 시 자세를 변경한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 63,
      "레벨": 4,
      "내용": "신체보호대 적용 시 적용 부위 피부간호를 시행한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 64,
      "레벨": 3,
      "내용": "부작용 발생 시 중재 방법: 격리 및 강박 관련 피부손상, 근골격계 이상, 기타 이상 증상 등의 부작용 발생 시 의사에게 알리고 적절한 중재를 적용한다.",
      "번호": "9)",
      "관련이미지": []
    },
    {
      "seq": 65,
      "레벨": 2,
      "내용": "격리·강박 해제",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 66,
      "레벨": 3,
      "내용": "격리나 강박은 가능한 최소한의 시간 동안 시행되는 것이 바람직하므로 격리·강박 사유가 해소된 것으로 평가되면 빠른 시간 내에 해제한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 67,
      "레벨": 3,
      "내용": "다음의 경우 의사의 처방에 따라 격리·강박을 해제한 후 해제 이유를 환자 또는 보호의무자에게 설명하고 환자의 상태를 평가한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 68,
      "레벨": 4,
      "내용": "환자 상태가 안정되어 위험성이 없어진 경우",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 69,
      "레벨": 4,
      "내용": "환자 스스로 충동을 조절할 수 없다고 느껴 환자의 요구로 격리 또는 강박을 적용한 경우 환자의 해지 요구 시",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 70,
      "레벨": 2,
      "내용": "관련 의료진은 격리 및 강박에 대해 신입직원 부서 오리엔테이션 시, 이후 연 1회 이상 교육을 받는다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 71,
      "레벨": 1,
      "내용": "(부록)",
