      },
      {
        "seq": 63,
        "레벨": 4,
        "내용": "신체보호대 적용 시 적용 부위 피부간호를 시행한다.",
        "번호": "(라)",
        "관련이미지": []
      },
      {
        "seq": 64,
        "레벨": 3,
        "내용": "부작용 발생 시 중재 방법: 격리 및 강박 관련 피부손상, 근골격계 이상, 기타 이상 증상 등의 부작용 발생 시 의사에게 알리고 적절한 중재를 적용한다.",
        "번호": "9)",
        "관련이미지": []
      },
      {
        "seq": 65,
        "레벨": 2,
        "내용": "격리·강박 해제",
        "번호": "5)",
        "관련이미지": []
      },
      {
        "seq": 66,
        "레벨": 3,
        "내용": "격리나 강박은 가능한 최소한의 시간 동안 시행되는 것이 바람직하므로 격리·강박 사유가 해소된 것으로 평가되면 빠른 시간 내에 해제한다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 67,
        "레벨": 3,
        "내용": "다음의 경우 의사의 처방에 따라 격리·강박을 해제한 후 해제 이유를 환자 또는 보호의무자에게 설명하고 환자의 상태를 평가한다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 68,
        "레벨": 4,
        "내용": "환자 상태가 안정되어 위험성이 없어진 경우",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 69,
        "레벨": 4,
        "내용": "환자 스스로 충동을 조절할 수 없다고 느껴 환자의 요구로 격리 또는 강박을 적용한 경우 환자의 해지 요구 시",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 70,
        "레벨": 2,
        "내용": "관련 의료진은 격리 및 강박에 대해 신입직원 부서 오리엔테이션 시, 이후 연 1회 이상 교육을 받는다.",
