      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원에서 자원봉사 활동을 수행하는 자원봉사자의 체계적이고 일관된 관리를 통해 자원봉사자의 역할 수행을 지원하고, 병원 서비스와 환자 안전을 증진하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "자원봉사자: 사랑과 봉사정신을 바탕으로 무보수 활동에 참여하는 자를 말한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "자원봉사자 관리",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "자원봉사자의 통합관리는 사회사업팀에서 담당한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "자원봉사자의 일반적인 관리는 본 내규에 따르며, 세부사항은 각 배치부서의 지침에 따른다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "관리절차",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "자원봉사자 신청서 제출",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 4,
      "내용": "오리엔테이션 실시",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "명찰 발부",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "직무기술서 작성",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "근태 관리",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "매년 정기교육 실시",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 2,
      "내용": "자원봉사자의 역할과 책임",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "자원봉사자는 배치 부서에서 부여된 직무기술서에 따른 역할과 책임 범위 내에서 활동을 수행한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "자원봉사자는 각 배치부서의 지도하에 봉사활동을 수행하고, 각 배치부서는 자원봉사자의 활동에 대해 감독할 책임이 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "자원봉사자의 의무",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "고객에 대한 서비스 제공에 최선을 다하며, 자신이 행하는 자원봉사의 가치를 믿는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "자원봉사업무 수행 시 항상 겸손하고 친절한 태도를 지닌다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "고객의 어떤 조건이나 상태에도 차별없이 공정하게 대한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "자원봉사자 담당 직원의 안내와 결정에 성실히 따른다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "자원봉사 과정에서 접한 병원의 업무 내용 및 환자 정보를 비밀로 유지한다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "병원에서 실시하는 자원봉사 교육 및 행사에 반드시 참여한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "동료 자원봉사자 및 직원과 상호 예의를 지키고 좋은 관계를 유지한다.",
      "번호": "7)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "자원봉사자로서 품위를 손상시킬 우려가 있는 행동을 하지 않는다.",
      "번호": "8)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "자원봉사자 교육",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "오리엔테이션",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 4,
      "내용": "신규 자원봉사자를 대상으로 병원소개, 질향상과 환자안전, 소방안전, 감염관리, 환자의 권리와 의무(서비스 마인드), 개인정보 보호, 배정된 업무에 대해 교육을 시행한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "정기 교육",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "봉사활동을 1년 이상 지속한 자원봉사자를 대상으로 매년 정기적인 교육을 시행하며, 교육 내용에는 질향상과 환자안전, 소방안전, 감염관리, 환자의 권리와 의무(서비스 마인드), 개인정보 보호에 대한 내용이 포함된다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "기타 교육",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 4,
      "내용": "필요에 따라 배정된 업무나 자원봉사 활동에 요구되는 추가 교육을 실시한다.",
      "번호": "(1)",
