    },
    {
      "seq": 16,
      "레벨": 5,
      "내용": "수혈 관련 교육 및 홍보에 관한 사항",
      "번호": "⑦",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "운영: 위원회를 반기별로 1회 이상 정기적으로 개최하고, 필요시 위원장이나 재적위원 과반수의 소집요구로 임시회의를 개최할 수 있다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "위원회 운영 결과 경영진 보고: 회의 결과를 회의록으로 작성 보관하며 전체 공지가 필요한 경우 위원장(병원장)의 결재를 받아 각 부서장 및 부서에 알린다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "수혈관리위원회 운영내규를 참조한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 2,
      "내용": "수혈관리실",
