      "내용": "5.1. 직원교육",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "병원 직원의 직무능력 향상과 자격유지 및 업무의 전문성 계발을 위해 직원의 교육 요구도를 파악하여 체계적인 교육시스템을 갖추어 운영하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "교육 대상",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "신입 및 재직 직원",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "필요시 학생, 자원봉사자, 외주용역 및 입점업체 직원을 포함한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "교육 요구도 확인 절차",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "교육 대상, 직무, 교육 종류 등을 고려하여 연간 교육 요구도를 파악한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "연간 교육 계획",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "교육 요구도를 반영하여 연간 교육계획 수립 시 교육 대상, 교육일정, 교육주제, 필요시 예산 등을 포함한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "직원의 개발 필요 역량을 파악하여 교육과정에 반영한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 2,
      "내용": "교육의 종류",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "오리엔테이션",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "병원 공통 교육은 인재개발센터 인재개발팀에서 담당하며, 의료원 현황, 역사 및 가치, 인사/복지제도 등 신입 직원의 조직 적응을 돕는 내용을 포함한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "직무교육은 해당 부서에서 주관하여 직원이 자신의 책임 업무를 명확하고 효율적으로 수행하도록 돕는다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "교육 내용에는 병원의 미션, 경영방침, 부서 운영 목표, 부서 업무 범위, 업무 관련 내규와 지침 등이 포함된다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "학생, 자원봉사자, 외주용역 및 입점업체 직원 등은 병원 및 배정된 업무에 대한 오리엔테이션을 받는다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "필수교육",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "모든 직원은 최소 연 1회 다음의 필수교육을 이수해야 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 5,
      "내용": "질향상과 환자안전, 환자의 권리와 의무, 감염관리, 소방안전, 폭력 예방, 개인정보 보호, 정기안전보건, 환경안전, 아동학대예방, 노인학대예방, 장애인인식개선, 직장내 괴롭힘 예방, 청탁금지, 긴급복지신고의무자 교육",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 4,
      "내용": "심폐소생술 교육은 세브란스병원 내규 [3.2.2.1. 심폐소생술]에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "특성화 교육: 진정교육, 약물교육(마약류적정사용, 항암화학요법 등), 호스피스/완화의료 교육, 지표관리 교육 등 특수 직무에 필요한 교육은 관련 내규 또는 직무 내용에 따라 시행한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "직무교육: 대상자 특성에 따라 전문 기술, 자격/면허 유지, 직무능력 향상 등을 위한 교육을 시행한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "기타교육: 필요시 추가 교육을 시행할 수 있다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 2,
      "내용": "교육 이력 관리",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "교육 이수 후에는 ESS(Employee Self Service) 또는 부서 인사파일에 교육 이력을 기록하고 지속적으로 교육 이력 관리를 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "모든 교육 업무는 인재개발센터 인재개발팀에서 총괄 관리한다.",
      "번호": "6.",
      "관련이미지": []
    },
    {
