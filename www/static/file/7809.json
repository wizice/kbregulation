      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "Syringe Pump를 포함한 Infusion Pump",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "Hemodialysis Machine",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "Ventilator",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "의료 장비 및 기기 알람 관리",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "고위험 알람 의료기기 사용자는 기기의 모든 알람이 적절한 범위로 설정되고 활성화되도록 하고 부서 내의 거리 및 주변 소음 등과 명확히 구별되는지 확인해야 한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 3,
      "내용": "알람이 울리는 경우 담당 의료진은 알람을 즉시 확인하고 원인을 분석하여 적절한 조치를 취해야 한다. 필요 시 주치의(담당교수)에게 보고한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "알람이 울릴 때 쉽게 들을 수 없는 수준으로 볼륨을 줄이거나 음소거해서는 안된다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "적정 알람 설정 및 변경 권한",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "적정 알람 설정 및 변경은 승인된 자에 의해서 수행되며, 담당 의료진은 알람의 변경사항을 인지해야 한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "적정 알람 설정 및 변경 권한자는 알람 조정법에 대해 알고 있어야 한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 3,
      "내용": "고위험 알람 의료기기 예방점검은 세브란스병원 내규 [11.5.1. 의료기기 관리]에 따른다.",
      "번호": "5)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "고위험 알람 의료기기 파라미터 설정 기준 및 권한은 [부록1. 고위험 알람 의료기기 파라미터 설정 기준 및 권한]에서 확인한다.",
      "번호": "6)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 2,
      "내용": "의료기기 알람 오류 및 관련 사건 발생 시 처리 절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "의료기기 사용 중 알람 오류가 발생한 경우 즉시 사용을 중단하고 다른 정상 의료기기를 적용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 3,
      "내용": "오류가 발생한 의료기기는 즉시 “사용 불가”임을 표시하고 의공기술팀에 수리를 요청한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "의료기기 알람 오류 또는 결함, 담당 의료진의 부적절한 대응 등으로 인한 환자안전사건 발생 시 “환자안전 보고체계” 또는 “의료기기부작용보고”에 따라 보고하고, 사건의 재발 및 유사사건 발생을 예방하기 위해 개선활동을 실시하고 관련 직원과 내용을 공유한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "의료기기 알람 시스템 사용자 교육",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "의료기기 알람 시스템을 다루는 모든 직원은 오리엔테이션 시, 신규 도입 의료기기를 다루기 전 임상 알람 시스템의 목적과 적절한 작동법에 대하여 교육받는다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
