      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "고위험 알람 의료기기는 아래와 같이 분류한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
