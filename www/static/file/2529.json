  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "3.3. 비품약 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "신속하고 원활한 환자진료를 위한 비품약의 적절한 관리 절차를 수립하고 이행함으로써 안전하고 정확하게 비품약을 사용하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "비품약: 응급 상황 및 신속한 투여가 필요하거나, 원활한 환자 진료를 위하여 준비한 의약품",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "비품약 선정 범위",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 3,
      "내용": "주사약을 주 대상으로 하고, 응급상황에 필요한 약품을 포함한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 3,
      "내용": "주사약 이외의 약품을 비품약으로 선정할 때에는 그 필요성에 대하여 약물관리위원회의 심의 및 승인을 득한 후 비품약 목록에 추가할 수 있다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "비품약 신청",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 3,
      "내용": "부서의 특성에 따라 비품약으로 필요한 약품은 공문을 통해 약무국으로 요청한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "부서당 비치할 수 있는 약품 수는 20품목 이하를 원칙으로 한다. 단, 특수부서(수술실, 중환자실, 응급진료센터 등)는 예외로 한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 2,
      "내용": "비품약 투여",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "비품약을 투여할 경우, 해당 비품약의 [부록2. 비품약 정보]를 참고하여 처방의 적절성을 확인한 후 투여한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "처방 적절성 검토에는 알러지, 치명적인 약물 상호작용, 환자 체중, 잠재적 장기 독성이 포함된다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "비품약 관리",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "비품약 보관 부서는 [부록3. 간호국 비품약 관리지침]을 준수한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "사용한 비품약 수령 시 약품명, 수량, 유효기간을 확인한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 3,
      "내용": "비품약 보관 부서는 연 4회(분기별) 비품약 목록, 수량, 보관상태 및 유효기간을 점검 및 관리한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "비품약은 잠금장치가 있는 장소에 보관한다.",
      "번호": "4)",
      "관련이미지": []
