  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "5.3. 일회용 물품의 재사용",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "일회용 물품의 재사용에 대한 기준을 제시하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "일회용 물품(Single Used Device): 1회 사용 후 폐기를 원칙으로 하는 물품(Single use로 표기된 물품)",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "재멸균(Resterilization): 포장을 개봉하였으나 사용하지 않은 경우, 혹은 포장이 완전한 상태에서 유효기간의 만료 등으로 다시 멸균과정을 거치는 것",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "일회용 물품의 재사용(Reuse of SUD): 일회용으로 표기된 물품을 reprocessing의 과정을 거쳐 다른 환자에게 사용하는 것",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 2,
      "내용": "일회용 물품의 재과정(Reprocessing of SUD): 환자에게 사용한 1회용 물품을 다른 환자에게 다시 사용할 목적으로 세척, 소독, 포장 및 멸균의 과정을 거치는 것",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 2,
      "내용": "일회용 물품은 재사용하지 않는 것을 원칙으로 한다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "일회용 물품의 재사용이 필요한 경우는 필요성과 멸균방법을 해당부서나 위원회에서 [부록2. 일회용 물품 재사용 허가 신청서]를 작성한 후 감염관리위원회에 상정, 병원운영위원회에서 최종 승인한다.",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 2,
      "내용": "재사용하면 안되는 경우",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "급여/비급여 항목으로 1회 사용 수가가 인정된 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 3,
      "내용": "소독이나 멸균으로 재질의 변화를 가져오는 경우",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 3,
      "내용": "좁고 긴 관이나 코일, 카테터 등 세척이 용이하지 않는 제품",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 2,
      "내용": "재사용을 인정하는 경우",
      "번호": "4.",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 3,
      "내용": "보건복지부에서 재사용 횟수를 감안하여 수가를 고시한 경우",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "시술 시 필수적으로 사용하는 품목이나 보건복지부 불인정 품목으로 비용발생을 할 수 없는 고가의 진료재료",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 2,
      "내용": "일회용 재사용 품목",
      "번호": "5.",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 3,
      "내용": "NS(NeuroSurgery), Midas cutting  burr",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 3,
      "내용": "ENT(Ear, Nose and Throat), Bien cutting  drill  burr",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "PS(Plastic Surgery), Drill cutting  burr",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "Cutting Burr 재사용 시 세척방법은 [부록1. Cutting burr 재사용 시 세척방법]을 참고한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 2,
      "내용": "재사용 횟수",
      "번호": "6.",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 3,
      "내용": "재멸균은 1회에 한하여 허용한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 3,
      "내용": "Stainless 제품: 세척 및 멸균준비 과정에서 확대경을 사용하여 품질 상태를 확인하며, 재사용 준비 과정에서 이상이 확인되면 폐기한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "플라스틱 제품: 1회에 한하여 재사용한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 3,
      "내용": "가능하다면 재사용임을 확인하기 위하여 기구의 직접접촉이 없는 부위에 재사용임을 표시한다.",
      "번호": "4)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 2,
      "내용": "물품의 기능 및 상태 평가",
      "번호": "7.",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 3,
      "내용": "세척 후 포장 전에 확대경을 이용하여 육안으로 확인하고 기능을 확인한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "모양의 변형, 낡거나 마모된 것, 부식된 것, 기구의 색이 변화된 것은 폐기한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 3,
      "내용": "사용시 성능이 저하된 것은 폐기한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 2,
      "내용": "재사용물품에 대한 평가 및 활용",
      "번호": "8.",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 3,
      "내용": "멸균과정을 확인하기 위하여 중앙멸균실의 멸균점검과정(Mechanical, chemical, biological indicator)에 따라 점검한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 3,
      "내용": "연 2회 준비된 재사용 물품 중 각 항목별로 5개를 수거하여 기구의 청결 및 기능상태를 평가한다. 평가결과에 따라 개선활동을 진행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 3,
      "내용": "재사용물품을 사용한 환자의 기록을 보관하여, 문제 발생 시 추적할 수 있도록 한다.",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 1,
      "내용": "(부록)",
      "번호": "제4조",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 2,
      "내용": "Cutting Burr 재사용 시 세척방법",
      "번호": "1.",
      "관련이미지": []
    },
    {
