      },
      {
        "seq": 20,
        "레벨": 4,
        "내용": "소독비누",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 21,
        "레벨": 5,
        "내용": "Betascrub(7.5%), Microshield(4% CHG): 수술실 및 침습적 시술이 행해지는 부서에서 외과적 손소독 시 사용",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 22,
        "레벨": 5,
        "내용": "Microshield(2% CHG): 격리실 및 감염취약부서(중환자실, 인공신장실, 분만실, 조혈모세포이식병동, 신생아실), 일반병동에서의 침습적 시술 전에 사용",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 23,
        "레벨": 4,
        "내용": "손소독제",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 24,
        "레벨": 5,
        "내용": "3M Sanitizer(70% Alcohol gel), Hexadermal(72% Ethanol): 환자접촉 및 진료부서 전체",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 25,
        "레벨": 5,
        "내용": "Avagard(1% CHG/61% Alcohol): 수술실, 인터벤션실 등 침습적 처치가 행해지는 부서",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 26,
        "레벨": 3,
        "내용": "손위생 방법",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 27,
        "레벨": 4,
        "내용": "물과 비누를 사용한 손씻기 방법",
        "번호": "(가)",
        "관련이미지": []
      },
      {
        "seq": 28,
        "레벨": 5,
        "내용": "일반비누를 이용한 손씻기: 흐르는 물에 일반 비누를 사용한다. 일상적인 위생활동에서 적용한다. 화장실, 일반병동, 환자병실에서 시행한다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 29,
        "레벨": 5,
        "내용": "소독비누를 이용한 손씻기: 흐르는 물에 소독제가 함유된 소독비누를 사용한다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 30,
        "레벨": 5,
        "내용": "물과 비누를 사용할 때는 물을 적시고 제조회사에서 요구하는 권고량을 묻힌 후 손가락 끝과 손가락 사이, 엄지손가락 및 손의 표면 모두를 최소한 15초 이상 강하게 문지른다.",
        "번호": "ⅲ)",
        "관련이미지": []
      },
      {
        "seq": 31,
        "레벨": 5,
        "내용": "미지근한 물을 사용한다. 뜨거운 물을 반복적으로 사용 시 피부염이 발생할 수 있으므로 뜨거운 물은 사용하지 않는다.",
        "번호": "ⅳ)",
        "관련이미지": []
      },
      {
        "seq": 32,
        "레벨": 5,
        "내용": "손을 씻는 동안 시계는 벗어 놓거나 팔 위로 올린다. 반지와 손가락 사이를 주의하여 씻는다.",
        "번호": "ⅴ)",
        "관련이미지": []
      },
      {
        "seq": 33,
        "레벨": 5,
        "내용": "손의 건조는 종이타월을 사용한다. 손으로 돌려서 잠그는 수도꼭지를 종이타월을 이용하여 닦은 손이 수도꼭지와 직접 접촉하지 않도록 한다.",
        "번호": "ⅵ)",
        "관련이미지": []
      },
      {
        "seq": 34,
        "레벨": 4,
        "내용": "알코올 기반 손소독제를 사용한 손소독 방법",
        "번호": "(나)",
        "관련이미지": []
      },
      {
        "seq": 35,
        "레벨": 5,
        "내용": "물과 비누의 사용이 제한될 경우, 눈에 보이는 오염이 없을 때 알코올이 함유된 손소독제를 적용한다.",
        "번호": "ⅰ)",
        "관련이미지": []
      },
      {
        "seq": 36,
        "레벨": 5,
        "내용": "손바닥에 손소독제를 덜은 후 양손으로 소독제가 마를 때까지 손과 손가락 표면을 모두 문지른다. 사용량은 일반적으로 엄지손톱만큼의 분량이며 제조회사의 권고사항을 따른다.",
        "번호": "ⅱ)",
        "관련이미지": []
      },
      {
        "seq": 37,
        "레벨": 4,
        "내용": "외과적 손소독 방법: 소독비누 혹은 소독제의 살균 및 정균 효과에 의해 손의 일시적인 오염균과 상주균까지 제거하는 것이다. 제조회사의 권고사항을 준수하여 3분간 세척, 혹은 아바가드 사용 시 올바른 순서로 3회 적용한다. 수술이나 침습적 시술 전에 시행한다.",
        "번호": "(다)",
        "관련이미지": []
      },
      {
        "seq": 38,
        "레벨": 3,
        "내용": "눈에 보이는 오염이 있는 경우, Bacillus anthracis(탄저), Clostridioides difficile에 오염되었거나 오염이 의심되는 경우는 비누와 물로 마찰을 이용하여 손을 씻는다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 39,
        "레벨": 3,
        "내용": "장갑은 손위생을 대신할 수 없으므로 장갑 착용 전, 후에 손위생을 시행한다.",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 40,
        "레벨": 2,
        "내용": "손위생 증진 프로그램 운영",
        "번호": "4)",
        "관련이미지": []
      },
      {
        "seq": 41,
        "레벨": 3,
        "내용": "직원, 환자 및 보호자의 손위생 수행을 증진하기 위해 손소독제를 구비하고, 접근 용이한 세면대를 설치한다. 세면대에는 손위생 수행에 대한 자료를 부착한다.",
        "번호": "1)",
        "관련이미지": []
      },
      {
        "seq": 42,
        "레벨": 3,
        "내용": "매년 교육 및 홍보 등의 손위생 증진활동을 진행한다.",
        "번호": "2)",
        "관련이미지": []
      },
      {
        "seq": 43,
        "레벨": 3,
        "내용": "손위생 수행을 분기별로 모니터링하고 필요한 중재방안을 마련한다. 증진활동 성과는 병원운영위원회 및 관련위원회에 보고한다. 주기적으로 부서별 및 개인별 손위생 수행 결과를 공유한다.",
        "번호": "3)",
        "관련이미지": []
      },
      {
        "seq": 44,
        "레벨": 1,
        "내용": "(부록)",
        "번호": "4.",
        "관련이미지": []
