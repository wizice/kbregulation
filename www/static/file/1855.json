      "내용": "1.5.1. 영양집중지원서비스",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "정맥영양이나 경장영양 등 영양집중지원 서비스를 받는 입원 환자에게 적절한 영양집중지원 서비스가 이루어지도록 필요한 관리 기준 및 절차를 정하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 2,
      "내용": "영양집중지원: 경구 식사를 통해 영양필요량을 충족할 수 없는 환자에게 정맥영양 또는 경장영양을 통해 영양을 공급하는 것",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "정맥영양: 경구섭취나 경장영양 공급이 불가능하거나 불충분한 환자에게 정맥을 통해 필요한 영양을 공급하는 것",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 2,
      "내용": "경장영양: 경구섭취가 불가능하거나 불충분한 환자에게 관을 통해 위나 장으로 필요한 영양을 공급하는 것",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 2,
      "내용": "영양집중지원 대상",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 3,
      "내용": "대상: 정맥영양지원, 경장영양지원 환자 중 영양집중지원팀으로 협의진료가 의뢰된 환자",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 2,
      "내용": "영양집중지원팀",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "구성: 의사, 영양사, 약사, 간호사로 구성한다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 3,
      "내용": "역할",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "환자의 영양상태, 질환, 약물 등을 고려하여 영양평가를 시행하고 치료계획을 수립한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "환자의 영양요구량을 산정한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "경장영양 또는 정맥영양 적응증 여부를 판단한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "영양집중지원을 위한 경로의 적합성을 평가한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 4,
      "내용": "경장영양과 정맥영양의 시작 및 진행방법을 권고한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "영양집중지원 내용에 대한 의무기록을 작성한다.",
      "번호": "(6)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "권고 내용에 따른 모니터링을 수행한다.",
      "번호": "(7)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 2,
      "내용": "영양집중지원 서비스 절차",
      "번호": "3.",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 3,
      "내용": "주치의(담당교수)의 협의진료 의뢰에 의해 영양집중지원 환자에 대한 관리가 개시된다.",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "영양상태, 질환 등을 고려한 영양평가(영양판정)를 시행하고, 영양집중지원팀의 협의를 통한 치료계획(영양중재 계획) 및 시행, 모니터링 과정으로 진행한다.",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "영양평가(영양판정)",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 5,
      "내용": "의무기록 검토, 환자(또는 보호자) 면담, 생화학적 검사결과 조회, 필요한 경우 추가의 인체계측을 통하여 환자의 현재 영양상태와 영양불량의 원인을 규명한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 5,
      "내용": "영양적 위험을 포함하는 진단과 의학적인 상태 및 의학적 치료(혹은 계획) 등 영양집중지원 서비스의 목표 설정과 계획 수립을 위한 기초 자료를 수집한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 4,
      "내용": "영양관리 치료계획 및 서비스 제공",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 5,
      "내용": "경장영양 혹은 정맥영양 적응증 여부 및 영양공급 경로를 결정한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 5,
      "내용": "환자의 영양상태 및 임상상태를 고려하여 영양요구량을 산정한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 5,
      "내용": "영양공급 경로와 영양요구량 등을 고려하여 적절한 경장영양액 혹은 정맥영양액의 종류와 주입량을 결정하고, 시작과 진행 방법을 결정하여 서비스를 제공한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 5,
      "내용": "영양 평가내용 및 영양 치료계획에 대해 ‘영양집중지원팀 협의진료의뢰서’에 작성하여 관련 의료진과 공유한다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "모니터링",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 5,
      "내용": "영양집중지원팀에 의뢰된 환자에 대해 영양상태와 의학적인 중증도에 따라 모니터링을 시행한다.",
      "번호": "①",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 5,
      "내용": "모니터링 결과는 ‘영양집중지원팀 협의진료의뢰서’ 중 ‘재평가 및 모니터링’ 항목에 작성한다.",
      "번호": "②",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 5,
      "내용": "영양섭취량의 부족 혹은 과다, 합병증 발생 등으로 인한 투여 경로 변경, 공급량 조정, 영양액 변경 등의 권고사항을 기록하고, 필요에 따라 주치의(담당교수)와 협의한다.",
      "번호": "③",
      "관련이미지": []
    },
    {
      "seq": 36,
      "레벨": 5,
      "내용": "필요 시, 영양상태 평가를 위한 생화학적 검사, 체중 측정 등을 요청 혹은 시행할 수 있다.",
      "번호": "④",
      "관련이미지": []
    },
    {
      "seq": 37,
      "레벨": 5,
      "내용": "항목",
      "번호": "⑤",
      "관련이미지": []
    },
    {
      "seq": 38,
      "레벨": 6,
      "내용": "정맥영양: 전해질, 간기능, 혈당변화 등 합병증 발현여부, 투여량의 적정성, 경장 혹은 경구 섭취 재개에 따른 투여량의 적정성 등",
      "번호": "a.",
      "관련이미지": []
    },
    {
      "seq": 39,
      "레벨": 6,
      "내용": "경장영양: 위장관 기능, 혈당변화 등 합병증 발현여부, 경장영양 공급의 적정성, 경구 섭취의 재개에 따른 공급량의 적정성 등",
      "번호": "b.",
      "관련이미지": []
    },
    {
      "seq": 40,
      "레벨": 2,
      "내용": "영양 평가내용 및 영양 치료계획에 대해 ‘영양집중지원팀 협의진료의뢰서’에 작성하여 관련 의료진과 공유하며, 관련 사항은 세브란스병원 내규 [3.1.2.1. 협의진료체계]에 따른다.",
