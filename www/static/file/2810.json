  "조문내용": [
    {
      "seq": 1,
      "레벨": 0,
      "내용": "1.4. 자원의 구매와 공급망 관리",
      "번호": "",
      "관련이미지": []
    },
    {
      "seq": 2,
      "레벨": 1,
      "내용": "(목적)",
      "번호": "제1조",
      "관련이미지": []
    },
    {
      "seq": 3,
      "레벨": 2,
      "내용": "진료재료, 의료기기, 의약품 등의 자원의 선정, 합리적인 구매, 사용 결정과 각 자원의 제조부터 납품까지의 공급망 관리를 통하여 환자와 직원의 안전 및 자원의 품질을 보장하기 위함이다.",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 4,
      "레벨": 1,
      "내용": "(정의)",
      "번호": "제2조",
      "관련이미지": []
    },
    {
      "seq": 5,
      "레벨": 1,
      "내용": "(절차)",
      "번호": "제3조",
      "관련이미지": []
    },
    {
      "seq": 6,
      "레벨": 2,
      "내용": "자원의 구매/사용 결정 절차",
      "번호": "1.",
      "관련이미지": []
    },
    {
      "seq": 7,
      "레벨": 3,
      "내용": "진료재료",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 8,
      "레벨": 4,
      "내용": "진료재료(진단과 치료 등 진료에 사용되는 모든 의료소모품과 진단 및 검사용 시약)의 경제적인 구입과 효율적인 관리를 위해 진료재료위원회를 운영하며, 위원회는 관련 제반사항을 심의 · 자문한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 9,
      "레벨": 4,
      "내용": "신규 진료재료 도입이 필요한 부서는 관련 심의서류를 포함한 [신규진료재료 신청서]를 작성하여 위원회에 상정한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 10,
      "레벨": 4,
      "내용": "진료재료위원회의 심의 및 선정 과정을 통해 구매가 결정된다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 11,
      "레벨": 4,
      "내용": "진료재료 선정은 진료재료의 효과와 안정성이 확립된 제품으로 식품의약품안전처에서 허가 승인된 진료재료에 한한다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 12,
      "레벨": 3,
      "내용": "의료기기",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 13,
      "레벨": 4,
      "내용": "교육, 연구 및 진료에 필요한 기자재와 이에 준하는 기자재의 도입 및 반납에 관한 업무의 조정기구로써 기자재위원회를 운영하며, 기자재에 관한 제반 사항을 심의 및 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 14,
      "레벨": 4,
      "내용": "기자재 도입이 필요한 부서는 [유형자산 청구 및 반납 승인서]를 작성하여 기자재심의 주무부서(기획예산부서 또는 총무(사무)부서)에 제출한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 15,
      "레벨": 4,
      "내용": "기자재심의 주무부서는 관계 부서의 의견을 받아 추가 검토 및 확인 사항을 보완하여 기자재위원회에 제출한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 16,
      "레벨": 4,
      "내용": "기자재위원회의 심의 및 선정과정을 통해 구매 결정된다.",
      "번호": "(4)",
      "관련이미지": []
    },
    {
      "seq": 17,
      "레벨": 4,
      "내용": "의료기기 선정은 의료기기의 효과와 안정성이 확립된 제품으로 식품의약품안전처에서 허가 승인된 의료기기에 한한다.",
      "번호": "(5)",
      "관련이미지": []
    },
    {
      "seq": 18,
      "레벨": 3,
      "내용": "의약품",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 19,
      "레벨": 4,
      "내용": "각 임상과에서 신규사용을 요청하는 의약품은 임상 각과 조교수 이상의 교수직이 부서장의 승인을 받은 후 신청한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 20,
      "레벨": 4,
      "내용": "신약의 심의는 약사위원회에서 담당하며, 약품의 안전성, 유효성 및 경제성을 기준으로 신약을 심의 및 선정한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 21,
      "레벨": 4,
      "내용": "약품의 선정은 약품의 효과와 안정성이 확립된 제품으로 식품의약품안전처에서 허가 승인된 약품에 한한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 22,
      "레벨": 2,
      "내용": "자원의 공급망 관리 절차: 중요 자원 목록 선정 → 납품업체 무결성 확인 → 입고 시 확인 → 사용 중, 후 모니터링 → 납품업체 피드백",
      "번호": "2.",
      "관련이미지": []
    },
    {
      "seq": 23,
      "레벨": 3,
      "내용": "진료재료",
      "번호": "1)",
      "관련이미지": []
    },
    {
      "seq": 24,
      "레벨": 4,
      "내용": "진료재료위원회에서 공급망 관리가 필요한 주요 진료재료 목록을 선정하여 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 25,
      "레벨": 4,
      "내용": "물류팀은 선정된 주요 진료재료의 제조에서 납품까지의 공급망을 파악하고 무결성을 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 26,
      "레벨": 4,
      "내용": "각 검수부서(사용부서 및 물류팀 등)에서는 진료재료 입고 시 포장형태, 유효기간, 품명/규격/제조사/입고수량 일치 여부 등을 확인하며 선입선출에 의하여 사용한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 27,
      "레벨": 3,
      "내용": "의료기기",
      "번호": "2)",
      "관련이미지": []
    },
    {
      "seq": 28,
      "레벨": 4,
      "내용": "기자재위원회, 의공기술팀 및 구매팀에서 공급망 관리가 필요한 주요 의료기기 목록을 선정하여 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 29,
      "레벨": 4,
      "내용": "기자재위원회, 의공기술팀 및 구매팀은 구매(도입) 대상 의료기기의 공급망에 대해 국내 의료기기법에 부합되는 의료기기 제조업자, 수입업자에 한하여 심의 검토하며 도입에 따른 제반절차는 [부록4. 자산관리 규정], [부록5. 구입 및 계약 사무규정]에 따른다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 30,
      "레벨": 4,
      "내용": "의료기기 입고 시 사용부서 및 기술부서에서 검수를 시행한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 31,
      "레벨": 3,
      "내용": "의약품",
      "번호": "3)",
      "관련이미지": []
    },
    {
      "seq": 32,
      "레벨": 4,
      "내용": "약사위원회에서 공급망 관리가 필요한 주요 의약품 목록을 선정하여 관리한다.",
      "번호": "(1)",
      "관련이미지": []
    },
    {
      "seq": 33,
      "레벨": 4,
      "내용": "약무국은 선정된 주요 의약품의 제조에서 납품까지의 공급망을 파악하고, 무결성을 확인한다.",
      "번호": "(2)",
      "관련이미지": []
    },
    {
      "seq": 34,
      "레벨": 4,
      "내용": "의약품 입고 시 포장상태 및 배송상태를 확인하며 약품명, 햠량, 규격, 제조사, 유효기간, 입고수량 등을 확인한다.",
      "번호": "(3)",
      "관련이미지": []
    },
    {
      "seq": 35,
      "레벨": 2,
      "내용": "주요 진료재료, 의료기기, 의약품 등의 추적관리를 위하여 품질(Quality)과 안정성(Safety)을 모니터링하며, 결과를 관련위원회 및 병원운영위원회에 보고하고 관련 의사결정과 계획에 반영한다.",
      "번호": "3.",
      "관련이미지": []
    },
